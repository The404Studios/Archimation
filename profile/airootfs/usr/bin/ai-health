#!/usr/bin/env bash
# ai-health -- human-readable Archimation subsystem health summary.
# Flags: --json, --brief.  Exit 0 if green/yellow, 1 if any red.
# Degrades gracefully when a subsystem isn't installed.
set -euo pipefail

# --- constants --------------------------------------------------------------
readonly AI_DAEMON_PORT=8420
readonly AI_CORTEX_PORT=8421
readonly HTTP_TIMEOUT=2
readonly VERSION="0.1"

# --- arg parsing ------------------------------------------------------------
mode="pretty"
for arg in "${@:-}"; do
    case "$arg" in
        --json)  mode="json" ;;
        --brief) mode="brief" ;;
        -h|--help)
            cat <<'EOF'
ai-health -- Archimation subsystem health summary

Usage:
  ai-health          human-readable output
  ai-health --json   machine-readable JSON
  ai-health --brief  one-line status

Exits 0 if green/yellow, 1 if any subsystem is red.
EOF
            exit 0 ;;
        "") ;;
        *) echo "ai-health: unknown flag '$arg' (try --help)" >&2; exit 2 ;;
    esac
done

# --- helpers ----------------------------------------------------------------
# status colors for pretty mode
C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_BOLD=$'\033[1m'; C_OFF=$'\033[0m'
if ! [ -t 1 ] || [ "$mode" != "pretty" ]; then C_GREEN=""; C_YELLOW=""; C_RED=""; C_BOLD=""; C_OFF=""; fi

now_iso() { date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "unknown"; }

has() { command -v "$1" >/dev/null 2>&1; }

unit_active() {
    # echoes: active|failed|inactive|activating|not-installed
    local u="$1"
    has systemctl || { echo "not-installed"; return; }
    systemctl list-unit-files --all --no-pager 2>/dev/null | grep -q "^${u}" \
        || { echo "not-installed"; return; }
    local s; s="$(systemctl is-active "$u" 2>/dev/null || true)"
    case "$s" in active|failed|inactive|activating|deactivating|reloading) echo "$s" ;; *) echo "inactive" ;; esac
}

unit_uptime() {
    # ActiveEnterTimestamp -> humanized delta, or "-"
    has systemctl || { echo "-"; return; }
    local ts; ts="$(systemctl show -p ActiveEnterTimestamp --value "$1" 2>/dev/null || true)"
    [ -z "$ts" ] && { echo "-"; return; }
    local e; e="$(date -d "$ts" +%s 2>/dev/null || echo 0)"
    [ "$e" = 0 ] && { echo "-"; return; }
    local d=$(( $(date +%s) - e ))
    if   [ "$d" -lt 60 ];    then echo "${d}s"
    elif [ "$d" -lt 3600 ];  then echo "$((d/60))m"
    elif [ "$d" -lt 86400 ]; then echo "$((d/3600))h$(( (d%3600)/60 ))m"
    else                          echo "$((d/86400))d$(( (d%86400)/3600 ))h"; fi
}

unit_last_error() {
    has journalctl || { echo "none"; return; }
    local line
    line="$(journalctl -u "$1" -n 50 --no-pager --priority=err 2>/dev/null | tail -5 | grep -v '^-- ' | tail -1 || true)"
    [ -z "$line" ] && echo "none" || echo "$line" | cut -c1-120
}

port_listening() {
    local p="$1"
    if has ss       && ss      -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}\$"; then echo yes; return; fi
    if has netstat  && netstat -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}\$"; then echo yes; return; fi
    echo no
}

http_probe() {
    # 200 | refused | <code> | no-curl
    has curl || { echo "no-curl"; return; }
    local c
    c="$(curl -s --max-time "$HTTP_TIMEOUT" -o /dev/null -w '%{http_code}' "$1" 2>/dev/null || true)"
    case "$c" in 200) echo 200 ;; 000|"") echo refused ;; *) echo "$c" ;; esac
}

trust_loaded() {
    # yes = loaded now; no = installed but not loaded; not-installed = no module file anywhere
    if has lsmod && lsmod 2>/dev/null | grep -qE '^trust '; then echo yes; return; fi
    # Module installed on disk but not currently loaded?
    if has modinfo && modinfo trust >/dev/null 2>&1; then echo no; return; fi
    echo "not-installed"
}

binfmt_registered() {
    [ -d /proc/sys/fs/binfmt_misc ] || { echo no; return; }
    for f in /proc/sys/fs/binfmt_misc/*; do
        [ -e "$f" ] || continue
        case "${f##*/}" in register|status) continue ;; esac
        echo yes; return
    done
    echo no
}

peloader_version_ok() {
    has peloader || { echo "not-installed"; return; }
    peloader --version >/dev/null 2>&1 && echo yes || echo no
}

# --- collect ---------------------------------------------------------------
TS="$(now_iso)"

AID_STATUS="$(unit_active ai-control.service)"
AID_PORT="$(port_listening "$AI_DAEMON_PORT")"
AID_ERR="$(unit_last_error ai-control.service)"
AID_UP="$(unit_uptime ai-control.service)"
AID_HEALTH="$(http_probe "http://127.0.0.1:${AI_DAEMON_PORT}/health")"
AID_SUMMARY="$(http_probe "http://127.0.0.1:${AI_DAEMON_PORT}/system/summary")"

CRTX_STATUS="$(unit_active ai-cortex.service)"
CRTX_PORT="$(port_listening "$AI_CORTEX_PORT")"
CRTX_ERR="$(unit_last_error ai-cortex.service)"
CRTX_UP="$(unit_uptime ai-cortex.service)"

TRUST_MOD="$(trust_loaded)"
TRUST_DEV="$([ -e /dev/trust ] && echo yes || echo no)"

PE_BINFMT="$(binfmt_registered)"
PE_VER="$(peloader_version_ok)"

SCM_STATUS="$(unit_active scm-daemon.service)"
OBJD_STATUS="$(unit_active pe-objectd.service)"

# --- classify: active+port=green, not-installed=yellow, failed=red ---------
classify_daemon() { case "$1" in not-installed) echo yellow ;; active) [ "$2" = yes ] && echo green || echo yellow ;; activating) echo yellow ;; *) echo red ;; esac; }
classify_unit()   { case "$1" in not-installed) echo yellow ;; active) echo green ;; activating) echo yellow ;; *) echo red ;; esac; }
classify_trust()  { case "$1" in yes) echo green ;; not-installed) echo yellow ;; *) echo red ;; esac; }
classify_binfmt() { case "$1" in yes) echo green ;; *) echo yellow ;; esac; }
classify_pever()  { case "$1" in yes) echo green ;; not-installed) echo yellow ;; *) echo red ;; esac; }

AID_COLOR="$(classify_daemon "$AID_STATUS" "$AID_PORT")"
CRTX_COLOR="$(classify_daemon "$CRTX_STATUS" "$CRTX_PORT")"
TRUST_COLOR="$(classify_trust "$TRUST_MOD")"
BINFMT_COLOR="$(classify_binfmt "$PE_BINFMT")"
PEVER_COLOR="$(classify_pever "$PE_VER")"
SCM_COLOR="$(classify_unit "$SCM_STATUS")"
OBJD_COLOR="$(classify_unit "$OBJD_STATUS")"

# --- tally -----------------------------------------------------------------
TOTAL=7; GREEN=0; YELLOW=0; RED=0
for c in "$AID_COLOR" "$CRTX_COLOR" "$TRUST_COLOR" "$BINFMT_COLOR" "$PEVER_COLOR" "$SCM_COLOR" "$OBJD_COLOR"; do
    case "$c" in green) GREEN=$((GREEN+1));; yellow) YELLOW=$((YELLOW+1));; red) RED=$((RED+1));; esac
done

OVERALL=0; [ "$RED" -gt 0 ] && OVERALL=1

# --- output ----------------------------------------------------------------
dot() { case "$1" in green) printf "%sgreen%s" "$C_GREEN" "$C_OFF" ;; yellow) printf "%syellow%s" "$C_YELLOW" "$C_OFF" ;; red) printf "%sred%s" "$C_RED" "$C_OFF" ;; esac; }
hint_trust()  {
    case "$TRUST_MOD" in
        not-installed) echo "    hint: trust-dkms not installed -- 'pacman -S trust-dkms && pacman -S linux-headers && dkms autoinstall'" ;;
        no)            echo "    hint: trust.ko present but not loaded -- 'modprobe trust' (if that fails, check 'dmesg | grep trust')" ;;
    esac
}
hint_binfmt() { if [ "$PE_BINFMT" = no ];    then echo "    hint: no binfmt_misc entries -- try 'systemctl restart systemd-binfmt.service'"; fi; }
hint_daemon() { if [ "$AID_COLOR" = red ];   then echo "    hint: 'systemctl status ai-control.service' and 'journalctl -u ai-control -n 50'"; fi; }

if [ "$mode" = "brief" ]; then
    if [ "$RED" -gt 0 ]; then
        echo "[FAIL] ${GREEN}/${TOTAL} subsystems green, ${YELLOW} warn, ${RED} red"
    elif [ "$YELLOW" -gt 0 ]; then
        echo "[WARN] ${GREEN}/${TOTAL} subsystems green, ${YELLOW} warn"
    else
        echo "[OK] ${GREEN}/${TOTAL} subsystems green"
    fi
    exit "$OVERALL"
fi

if [ "$mode" = "json" ]; then
    # JSON output (hand-rolled; avoids a jq dependency in early-boot environments)
    cat <<EOF
{
  "timestamp": "$TS",
  "overall": "$([ "$OVERALL" = 0 ] && ([ "$YELLOW" -gt 0 ] && echo warning || echo ok) || echo error)",
  "summary": {"total": $TOTAL, "green": $GREEN, "yellow": $YELLOW, "red": $RED},
  "ai_control": {"status": "$AID_STATUS", "port_${AI_DAEMON_PORT}": "$AID_PORT", "uptime": "$AID_UP", "last_error": "$(printf '%s' "$AID_ERR" | sed 's/"/\\"/g')", "health_endpoint": "$AID_HEALTH", "summary_endpoint": "$AID_SUMMARY", "color": "$AID_COLOR"},
  "ai_cortex":  {"status": "$CRTX_STATUS", "port_${AI_CORTEX_PORT}": "$CRTX_PORT", "uptime": "$CRTX_UP", "last_error": "$(printf '%s' "$CRTX_ERR" | sed 's/"/\\"/g')", "color": "$CRTX_COLOR"},
  "trust_kernel": {"module_loaded": "$TRUST_MOD", "dev_trust": "$TRUST_DEV", "color": "$TRUST_COLOR"},
  "pe_loader":  {"binfmt_misc": "$PE_BINFMT", "peloader_version_ok": "$PE_VER", "color_binfmt": "$BINFMT_COLOR", "color_version": "$PEVER_COLOR"},
  "scm_daemon": {"status": "$SCM_STATUS", "color": "$SCM_COLOR"},
  "pe_objectd": {"status": "$OBJD_STATUS", "color": "$OBJD_COLOR"}
}
EOF
    exit "$OVERALL"
fi

# pretty
printf "%sArchimation system health @ %s%s\n" "$C_BOLD" "$TS" "$C_OFF"
echo   "=============================="
printf "AI daemon (ai-control.service):  [%s]\n" "$(dot "$AID_COLOR")"
printf "  status:  %s\n" "$AID_STATUS"
printf "  port %d: %s\n" "$AI_DAEMON_PORT" "$AID_PORT"
printf "  uptime:  %s\n" "$AID_UP"
printf "  last_error: %s\n" "$AID_ERR"
printf "  /health endpoint:        %s\n" "$AID_HEALTH"
printf "  /system/summary endpoint: %s\n" "$AID_SUMMARY"
hint_daemon
echo
printf "AI cortex (ai-cortex.service):   [%s]\n" "$(dot "$CRTX_COLOR")"
printf "  status:  %s\n" "$CRTX_STATUS"
printf "  port %d: %s\n" "$AI_CORTEX_PORT" "$CRTX_PORT"
printf "  uptime:  %s\n" "$CRTX_UP"
printf "  last_error: %s\n" "$CRTX_ERR"
echo
printf "Trust kernel (trust.ko):         [%s]\n" "$(dot "$TRUST_COLOR")"
printf "  loaded:     %s\n" "$TRUST_MOD"
printf "  /dev/trust: %s\n" "$TRUST_DEV"
hint_trust
echo
printf "PE loader:                       [%s/%s]\n" "$(dot "$BINFMT_COLOR")" "$(dot "$PEVER_COLOR")"
printf "  binfmt_misc: %s\n" "$PE_BINFMT"
printf "  peloader --version: %s\n" "$PE_VER"
hint_binfmt
echo
printf "Windows services:\n"
printf "  scm-daemon:  %s  [%s]\n" "$SCM_STATUS" "$(dot "$SCM_COLOR")"
printf "  pe-objectd:  %s  [%s]\n" "$OBJD_STATUS" "$(dot "$OBJD_COLOR")"
echo
if [ "$RED" -gt 0 ]; then
    printf "%sOverall: %d/%d green, %d warn, %s%d red%s%s\n" "$C_BOLD" "$GREEN" "$TOTAL" "$YELLOW" "$C_RED" "$RED" "$C_OFF" "$C_BOLD"
    printf "Run  journalctl -xb  to investigate, or  man ai-help  for the user manual.%s\n" "$C_OFF"
elif [ "$YELLOW" -gt 0 ]; then
    printf "%sOverall: %d/%d green, %d warn, 0 red%s\n" "$C_BOLD" "$GREEN" "$TOTAL" "$YELLOW" "$C_OFF"
else
    printf "%sOverall: all %d subsystems green%s\n" "$C_BOLD" "$TOTAL" "$C_OFF"
fi

exit "$OVERALL"
