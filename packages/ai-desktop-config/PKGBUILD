#!/usr/bin/env python3
"""
Contusion - AI Automation Engine

GTK4/Adwaita desktop GUI for natural-language automation,
macro recording/playback, process management, system monitoring,
application launching, and AI daemon settings.
"""

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib, Gio, Pango, Gdk
import json, subprocess, threading, time, os, re
import urllib.request, urllib.error

os.environ.setdefault("GDK_BACKEND", "x11")
os.environ.setdefault("GSK_RENDERER", "cairo")
os.environ.setdefault("GDK_DPI_SCALE", "0.5")

API = "http://127.0.0.1:8420"
MACROS_PATH = os.path.expanduser("~/.config/contusion/macros.json")
HISTORY_PATH = os.path.expanduser("~/.config/contusion/cmd_history.json")
MAX_HISTORY = 50


def _scaled_window_size(base_w, base_h, max_frac=0.85):
    """Compute window size that respects screen geometry.

    On small screens (<= 900p), use up to 85% of the screen.
    On larger screens, use up to 60%. This prevents oversized
    windows on laptops and QEMU VMs.
    """
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                geom = monitors.get_item(0).get_geometry()
                # Adapt fraction based on screen size
                if geom.height <= 768:
                    frac = 0.85   # Small screens: use most of the space
                elif geom.height <= 900:
                    frac = 0.75
                elif geom.height <= 1080:
                    frac = 0.65
                else:
                    frac = max_frac
                w = min(base_w, int(geom.width * frac))
                h = min(base_h, int(geom.height * frac))
                # Enforce minimum usable size
                w = max(w, 400)
                h = max(h, 300)
                return w, h
    except Exception:
        pass
    return min(base_w, 800), min(base_h, 550)

def _is_compact_screen():
    """Return True if the screen is small (<=900p) and UI should be compact."""
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                return monitors.get_item(0).get_geometry().height <= 900
    except Exception:
        pass
    return True  # Default to compact for safety


