# Maintainer: AI Arch Linux Project
# PKGBUILD for ai-control-daemon - Full system control daemon with REST API

pkgname=ai-control-daemon
pkgver=0.1.0
pkgrel=30
pkgdesc="AI control daemon providing full system access via REST API (screen, keyboard, mouse, filesystem, processes)"
arch=('any')
url="https://github.com/ai-arch-linux/ai-control-daemon"
license=('GPL-3.0-or-later')
depends=(
    'python'
    'python-fastapi'
    'uvicorn'
    'python-httptools'
    'python-starlette'
    'python-websockets'
    'python-evdev'
    'python-pillow'
    'python-pydantic'
    'python-psutil'
    'nftables'
)
optdepends=(
    'windows-services: Windows SCM service management'
    'llama-cpp-python: local LLM inference support'
    'mono: run .NET 4.x PE binaries via mscoree bridge (CLR runtime + mcs compiler)'
)
# python-sdnotify removed: AUR-only. We now use a stdlib-only
# sd_notify implementation in main.py that talks directly to
# NOTIFY_SOCKET (AF_UNIX datagram). No external dep required.
provides=('ai-control-daemon')
backup=(
    'etc/ai-control-daemon/config.toml'
    'etc/pe-compat/cortex.toml'
)
source=()

# Use the project source tree directly (local build)
_srcdir="${startdir}/../../ai-control"

package() {
    cd "$_srcdir"

    # Install daemon Python modules
    #
    # The glob ``daemon/*.py`` intentionally does NOT descend into
    # subdirectories, so ``daemon/tests/`` (the test harness for
    # e.g. ``system_summary.py``) is excluded from the runtime
    # package by construction.  If you add another test directory,
    # keep it under ``daemon/tests/`` so the glob keeps skipping it.
    install -d "$pkgdir/usr/lib/ai-control-daemon"
    install -Dm644 daemon/*.py "$pkgdir/usr/lib/ai-control-daemon/"
    # Ensure __init__.py is installed (may be missed by glob on some systems)
    if [ -f daemon/__init__.py ]; then
        install -Dm644 daemon/__init__.py "$pkgdir/usr/lib/ai-control-daemon/__init__.py"
    fi

    # Install configuration
    install -Dm644 config/ai-control.toml "$pkgdir/etc/ai-control-daemon/config.toml"
    install -Dm644 config/cortex.toml "$pkgdir/etc/pe-compat/cortex.toml"

    # Install systemd service
    install -Dm644 config/ai-control.service "$pkgdir/usr/lib/systemd/system/ai-control.service"

    # Create runtime directories
    install -d "$pkgdir/var/lib/ai-control-daemon"
    install -d "$pkgdir/var/lib/ai-control/patterns"
    install -d "$pkgdir/var/lib/ai-control/signatures"
    install -d "$pkgdir/var/lib/ai-control/win-api-db"
    install -d "$pkgdir/var/log/ai-control-daemon"
    install -d "$pkgdir/run/ai-control-daemon"
    install -d "$pkgdir/tmp/generated-stubs"

    # Install a launcher script
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-control-daemon" <<'LAUNCHER'
#!/bin/bash
# AI Control Daemon launcher
exec /usr/bin/python3 /usr/lib/ai-control-daemon/main.py \
    --config /etc/ai-control-daemon/config.toml "$@"
LAUNCHER

    # Session 68 (Agent G): ship the PowerShell first-boot installer so the
    # ai-install-pwsh.service oneshot has something to exec.  pwsh is
    # AUR-only (powershell-bin) and the MS tarball installer avoids adding
    # an AUR dep to pacstrap; we pull it over the network on first boot only.
    if [ -f "${startdir}/../../scripts/install-pwsh.sh" ]; then
        install -Dm755 "${startdir}/../../scripts/install-pwsh.sh" \
            "$pkgdir/usr/share/ai-control/scripts/install-pwsh.sh"
    fi

    # Session 68: compile and ship the dictionary_v2 template artifact
    # (~8000 NL phrases → typed handler_type).  contusion.py's Stage-1
    # routing probes /var/cache/ai-control/dictionary_v2.pkl.zst first;
    # without this file the v2 fast-path degrades silently to stage-2
    # regex routing, which was the 0/33 set_smoke regression in pkg-17.
    # Compile here so the artifact ships in the package even when the
    # build host has no ai-control-daemon service running.
    if python3 daemon/dictionary_v2.py --build \
        "$pkgdir/var/cache/ai-control/dictionary_v2.pkl.zst" 2>&1 | tail -3; then
        # Strip world-writable perms — _validate_pickle_source() refuses to
        # load a pickle whose parent dir or file is o+w (pickle-injection
        # hardening from S63).
        chmod 755 "$pkgdir/var/cache/ai-control" 2>/dev/null || true
        chmod 644 "$pkgdir/var/cache/ai-control/dictionary_v2.pkl.zst" 2>/dev/null || true
    else
        echo "WARNING: dictionary_v2 build failed -- v2 fast-path will be unavailable on the live ISO" >&2
    fi

    # AI Cortex (the brain)
    install -dm755 "$pkgdir/usr/lib/ai-control-daemon/cortex"
    install -Dm644 cortex/*.py "$pkgdir/usr/lib/ai-control-daemon/cortex/"
    # Ensure __init__.py is installed for cortex package
    if [ -f cortex/__init__.py ]; then
        install -Dm644 cortex/__init__.py "$pkgdir/usr/lib/ai-control-daemon/cortex/__init__.py"
    fi

    # AI Cortex launcher script
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-cortex" <<'LAUNCHER'
#!/bin/bash
cd /usr/lib/ai-control-daemon
exec python3 -m cortex "$@"
LAUNCHER

    # pe-status diagnostic tool
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/pe-status" <<'PESTATUS'
#!/bin/bash
# pe-status - AI Arch Linux System Diagnostics
cd /usr/lib/ai-control-daemon
exec python3 -c "
import asyncio, sys; sys.path.insert(0, '.')
from diagnostics import run_full_diagnostics, format_diagnostics
report = asyncio.run(run_full_diagnostics())
if '--json' in sys.argv:
    import json; print(json.dumps(report, indent=2))
elif '--brief' in sys.argv:
    s=report['summary']
    icon={'ok':'OK','warning':'WARN','error':'FAIL'}.get(report['overall'],'??')
    print(f'[{icon}] {s[\"ok\"]}/{s[\"total\"]} checks passed, {s[\"warnings\"]} warnings, {s[\"errors\"]} errors')
else:
    print(format_diagnostics(report))
sys.exit(2 if report['overall']=='error' else 1 if report['overall']=='warning' else 0)
" "$@"
PESTATUS

    # AI Cortex systemd service
    #
    # Heredoc uses 'EOF' (quoted) so the shell does NOT expand $MAINPID or
    # $NOTIFY_SOCKET at package() time; those belong to systemd's escape
    # namespace at unit-activation time and must survive verbatim.
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system/ai-cortex.service" <<'EOF'
[Unit]
Description=AI Cortex - System Orchestrator
Documentation=https://github.com/ai-arch-linux/ai-control-daemon
# Ordering: cortex needs (a) the object broker for session handles,
# (b) kernel modules (trust.ko), and (c) ai-control so its /health + /events
# endpoints are ready.  Since ai-control is Type=notify, After=ai-control
# now means "ai-control has sent READY=1" — i.e. FastAPI is accepting
# connections.  No retry loop needed inside cortex.
After=pe-objectd.service systemd-modules-load.service ai-control.service
Wants=pe-objectd.service
# Requires= on ai-control — if the daemon dies, the cortex has nothing
# to talk to.  systemd will stop cortex cleanly instead of leaving it
# spinning on ECONNREFUSED.
Requires=ai-control.service
# StartLimit* live in [Unit] as of systemd 230.  Older placement in
# [Service] still works but triggers a deprecation warning in
# systemd-analyze verify.
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
# Session 36: cortex now sends READY=1 + periodic WATCHDOG=1 via stdlib
# AF_UNIX datagram to NOTIFY_SOCKET (same pattern as ai-control), and
# STOPPING=1 on shutdown. No AUR-only python-sdnotify dependency.
Type=notify
NotifyAccess=main
ExecStartPre=/usr/bin/mkdir -p /run/pe-compat /var/lib/pe-compat/trust-history
ExecStart=/usr/bin/ai-cortex
Restart=on-failure
RestartSec=5
# Cortex cold-start does: imports, event-bus setup, REST API on :8421,
# and the autonomy controller's first tick.  45s is ample on TCG QEMU.
TimeoutStartSec=45
# Cortex has a graceful shutdown path (orchestrator.notify + task drain);
# give it 10s before SIGKILL.
TimeoutStopSec=10
KillMode=mixed
KillSignal=SIGTERM
Environment=PYTHONUNBUFFERED=1
# Heartbeat posted every 30s from _watchdog_heartbeat_loop() -- half the
# WatchdogSec value per systemd's recommendation.
WatchdogSec=60

[Install]
WantedBy=multi-user.target
EOF
}
