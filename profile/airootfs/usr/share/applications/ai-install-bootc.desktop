[Desktop Entry]
Version=1.0
Type=Application
Name=Install ArchWindows (bootc — recommended)
GenericName=OS Installer (bootc mode)
Comment=Install via immutable OCI image with atomic upgrades and rollback
Exec=xfce4-terminal --hold --title="ArchWindows bootc Installer" -e "sudo /usr/bin/ai-install-bootc"
Icon=system-software-install
Terminal=false
Categories=System;Settings;
Keywords=install;setup;disk;bootc;ostree;oci;atomic;archwindows;
StartupNotify=true
