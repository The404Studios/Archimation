def _load_css():
    """Load Contusion custom CSS into the default display."""
    try:
        provider = Gtk.CssProvider()
        provider.load_from_data(CONTUSION_CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
    except Exception:
        pass


def api_call(method, endpoint, data=None):
    """Thread-safe API call. Returns dict with 'error' key on failure."""
    try:
        body = json.dumps(data or {}).encode() if data else None
        req = urllib.request.Request(
            f"{API}{endpoint}", data=body, method=method)
        req.add_header("Content-Type", "application/json")
        with urllib.request.urlopen(req, timeout=5) as r:
            return json.loads(r.read().decode())
    except Exception as e:
        return {"error": str(e)}


def load_macros():
    try:
        with open(MACROS_PATH) as f:
            return json.load(f)
    except Exception:
        return []


def save_macros(macros):
    os.makedirs(os.path.dirname(MACROS_PATH), exist_ok=True)
    with open(MACROS_PATH, "w") as f:
        json.dump(macros, f, indent=2)


def load_cmd_history():
    try:
        with open(HISTORY_PATH) as f:
            return json.load(f)
    except Exception:
        return []


def save_cmd_history(hist):
    os.makedirs(os.path.dirname(HISTORY_PATH), exist_ok=True)
    with open(HISTORY_PATH, "w") as f:
        json.dump(hist[:MAX_HISTORY], f, indent=2)


def read_cpu_usage():
    """Read CPU usage from /proc/stat (two samples 0.2s apart)."""
    try:
        def _read():
            with open("/proc/stat") as f:
                parts = f.readline().split()
            vals = [int(x) for x in parts[1:9]]
            idle = vals[3] + vals[4]
            return idle, sum(vals)
        idle1, total1 = _read()
        time.sleep(0.2)
        idle2, total2 = _read()
        dt = total2 - total1
        if dt == 0:
            return 0.0
        return round((1.0 - (idle2 - idle1) / dt) * 100, 1)
    except Exception:
        return -1.0


def read_mem_usage():
    """Read memory from /proc/meminfo. Returns (used_mb, total_mb, pct)."""
    try:
        info = {}
        with open("/proc/meminfo") as f:
            for line in f:
                parts = line.split()
                if len(parts) >= 2:
                    info[parts[0].rstrip(":")] = int(parts[1])
        total = info.get("MemTotal", 0)
        avail = info.get("MemAvailable", info.get("MemFree", 0))
        used = total - avail
        total_mb = round(total / 1024, 1)
        used_mb = round(used / 1024, 1)
        pct = round(used / total * 100, 1) if total > 0 else 0.0
        return used_mb, total_mb, pct
    except Exception:
        return 0, 0, 0


def read_disk_usage(path="/"):
    """Read disk usage via os.statvfs. Returns (used_gb, total_gb, pct)."""
    try:
        st = os.statvfs(path)
        total = st.f_frsize * st.f_blocks
        free = st.f_frsize * st.f_bavail
        used = total - free
        total_gb = round(total / (1024**3), 1)
        used_gb = round(used / (1024**3), 1)
        pct = round(used / total * 100, 1) if total > 0 else 0.0
        return used_gb, total_gb, pct
    except Exception:
        return 0, 0, 0


def _clear_listbox(lb):
    """Remove all rows from a Gtk.ListBox."""
    while True:
        row = lb.get_row_at_index(0)
        if row is None:
            break
        lb.remove(row)


class ContusionApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.ai_arch.contusion")
        self.connect("activate", self._on_activate)
        self.history = []
        self.cmd_history = load_cmd_history()
        self.daemon_online = False
        self.trust_level = "Unknown"
        self.last_action_ts = "Never"
        self.auto_running = False
        self._proc_sort_key = "cpu"
        self._proc_sort_reverse = True
        self._proc_filter = ""
        self._proc_data = []

    def _on_activate(self, app):
        _load_css()
        self._compact = _is_compact_screen()
        self._margin = 4 if self._compact else 12
        self._page_margin = 12 if self._compact else 24
        self._page_top = 8 if self._compact else 16
        self._spacing = 4 if self._compact else 8

        # Compact CSS for small screens
        if self._compact:
            try:
                _cprov = Gtk.CssProvider()
                _cprov.load_from_data(b"headerbar.compact{min-height:32px;padding:2px 0}headerbar.compact button{min-height:24px;padding:2px 6px}.compact-label{font-size:9px}")
                Gtk.StyleContext.add_provider_for_display(Gdk.Display.get_default(), _cprov, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION + 1)
            except Exception:
                pass

        self.win = Adw.ApplicationWindow(application=app)
        self.win.set_title("Contusion \u2014 AI Automation Engine")
        _w, _h = _scaled_window_size(720, 500)
        self.win.set_default_size(_w, _h)

        # Toast overlay wraps the entire content for notifications
        self.toast_overlay = Adw.ToastOverlay()

        hdr = Adw.HeaderBar()
        if self._compact:
            hdr.add_css_class("compact")
        ref = Gtk.Button(icon_name="view-refresh-symbolic")
        ref.set_tooltip_text("Refresh")
        ref.connect("clicked", lambda _: self._refresh())
        hdr.pack_end(ref)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        outer.append(hdr)

        # Daemon offline banner (hidden by default)
        self.offline_banner = Adw.Banner()
        self.offline_banner.set_title(
            "AI Daemon Offline \u2014 connection to port 8420 "
            "failed. Retrying...")
        self.offline_banner.set_button_label("Retry Now")
        self.offline_banner.connect(
            "button-clicked", lambda _: self._check_connection())
        self.offline_banner.set_revealed(False)
        outer.append(self.offline_banner)

        split = Adw.NavigationSplitView()

        # --- sidebar ---
        sb_page = Adw.NavigationPage(title="Contusion")
        sb_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.sidebar = Gtk.ListBox()
        self.sidebar.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.sidebar.add_css_class("navigation-sidebar")

        sections = [
            ("Automations", "system-run-symbolic"),
