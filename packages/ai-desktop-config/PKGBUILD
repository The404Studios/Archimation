    # --- Shell configuration (.bashrc) ---
    # Installed to a non-conflicting path to avoid pacstrap conflict with the
    # `bash` package's default /etc/skel/.bashrc. customize_airootfs.sh copies
    # this file to /etc/skel/.bashrc and /home/arch/.bashrc after pacstrap.
    install -Dm644 /dev/stdin "$pkgdir/usr/share/ai-desktop-config/skel/bashrc" <<'BASHRC'
#!/bin/bash
# AI Arch Linux - Shell Configuration

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# ─── History ──────────────────────────────────────────────
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoreboth:erasedups
shopt -s histappend

# ─── Shell options ────────────────────────────────────────
shopt -s checkwinsize
shopt -s globstar 2>/dev/null
shopt -s autocd 2>/dev/null

# ─── Tab completion ───────────────────────────────────────
if [ -r /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
fi

# ─── Prompt ───────────────────────────────────────────────
# Colors
C_RESET='\[\033[0m\]'
C_BLUE='\[\033[38;5;111m\]'
C_PURPLE='\[\033[38;5;141m\]'
C_GREEN='\[\033[38;5;114m\]'
C_YELLOW='\[\033[38;5;222m\]'
C_GRAY='\[\033[38;5;243m\]'
C_RED='\[\033[38;5;203m\]'

# Git branch in prompt
__git_branch() {
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --always 2>/dev/null)
    [ -n "$branch" ] && echo " ${branch}"
}

# Set prompt
PS1="${C_BLUE}\u${C_GRAY}@${C_PURPLE}\h ${C_GREEN}\w${C_YELLOW}\$(__git_branch)${C_RESET}\n${C_BLUE}❯${C_RESET} "

# Root prompt
if [ "$(id -u)" -eq 0 ]; then
    PS1="${C_RED}\u${C_GRAY}@${C_PURPLE}\h ${C_GREEN}\w${C_RESET}\n${C_RED}#${C_RESET} "
fi

# ─── Aliases ──────────────────────────────────────────────
alias ls='ls --color=auto -F'
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias ip='ip --color=auto'

# System
alias update='sudo pacman -Syu'
alias install='sudo pacman -S'
alias remove='sudo pacman -Rns'
alias search='pacman -Ss'
alias cleanup='sudo pacman -Sc && sudo paccache -rk1'

# AI Control
alias ai-status='pe-status'
alias ai-health='curl -s http://127.0.0.1:8420/health | python3 -m json.tool'
alias ai-diag='pe-status --json | python3 -m json.tool'
alias ai='ai-assist'

# PE Loader
alias run-exe='peloader'
alias games='pe-status && echo && ls ~/Games/*.exe 2>/dev/null || echo "No games found in ~/Games/"'

# Git shortcuts
alias gs='git status'
alias gl='git log --oneline -20'
alias gd='git diff'

# ─── Environment ──────────────────────────────────────────
export EDITOR=nano
export VISUAL=nano
export PAGER=less
export LESS='-R --mouse'

# ─── Greeting ─────────────────────────────────────────────
# Show system info on first terminal (skip in sub-shells)
if [ -z "$TMUX" ] && [ -z "$AI_GREETED" ]; then
    export AI_GREETED=1
    clear
    if command -v fastfetch &>/dev/null; then
        fastfetch
    fi
fi
BASHRC

