    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-control-panel" <<'AIAPP'
#!/usr/bin/env python3
"""
AI Control Panel - Desktop GUI for controlling the AI system.

Provides:
- System status overview (CPU, RAM, disk, network)
- AI daemon status and controls
- Trust system observer
- Task automation (give commands to AI)
- PE Loader game management
- Service management
"""

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib, Gio, Pango, Gdk
import json
import subprocess
import threading
import urllib.request
import urllib.error
import os

# GTK4 rendering fallbacks for older/incompatible GPUs (e.g., GT218M nouveau).
os.environ.setdefault("GDK_BACKEND", "x11")
os.environ.setdefault("GSK_RENDERER", "cairo")
os.environ.setdefault("GDK_DPI_SCALE", "0.5")

API_BASE = "http://127.0.0.1:8420"


def _scaled_window_size(base_w, base_h, max_frac=0.85):
    """Compute window size that respects screen geometry."""
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                geom = monitors.get_item(0).get_geometry()
                if geom.height <= 768:
                    frac = 0.85
                elif geom.height <= 900:
                    frac = 0.75
                elif geom.height <= 1080:
                    frac = 0.65
                else:
                    frac = max_frac
                w = max(400, min(base_w, int(geom.width * frac)))
                h = max(300, min(base_h, int(geom.height * frac)))
                return w, h
    except Exception:
        pass
    return min(base_w, 700), min(base_h, 500)


def _is_compact_screen():
    """Return True if the screen is small (<=900p) and UI should be compact."""
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                return monitors.get_item(0).get_geometry().height <= 900
    except Exception:
        pass
    return True  # Default to compact for safety


# Compact-mode CSS: tighter header bar and buttons on small screens
_COMPACT_CSS = """
headerbar.compact { min-height: 32px; padding-top: 2px; padding-bottom: 2px; }
headerbar.compact button { min-height: 24px; padding: 2px 6px; }
.compact-label { font-size: 9px; }
"""


def _apply_compact_css():
    try:
        provider = Gtk.CssProvider()
        provider.load_from_data(_COMPACT_CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
    except Exception:
        pass


class AIControlPanel(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.ai_arch.control_panel")
        self.connect("activate", self.on_activate)

    def on_activate(self, app):
        _compact = _is_compact_screen()
        self._compact = _compact
        self._margin = 4 if _compact else 12
        self._page_margin = 12 if _compact else 24
        self._page_top = 8 if _compact else 16
        self._spacing = 4 if _compact else 8

        if _compact:
            _apply_compact_css()

        win = Adw.ApplicationWindow(application=app)
        win.set_title("AI Control Panel")
        w, h = _scaled_window_size(700, 500)
        win.set_default_size(w, h)

        # Header bar
        header = Adw.HeaderBar()
        if _compact:
            header.add_css_class("compact")
        refresh_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        refresh_btn.set_tooltip_text("Refresh")
        refresh_btn.connect("clicked", self.on_refresh)
        header.pack_end(refresh_btn)

        # Main content: navigation sidebar + pages
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main_box.append(header)

        # Split view: sidebar + content
        split = Adw.NavigationSplitView()

        # Sidebar
        sidebar_page = Adw.NavigationPage(title="AI Control")
        sidebar_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

        sidebar_list = Gtk.ListBox()
        sidebar_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        sidebar_list.add_css_class("navigation-sidebar")

        _sb_margin = 6 if _compact else 12
        _sb_pad = 4 if _compact else 8
        pages = [
            ("System Status", "computer-symbolic"),
            ("AI Tasks", "system-run-symbolic"),
            ("Games", "applications-games-symbolic"),
            ("Services", "preferences-system-symbolic"),
            ("Trust System", "security-high-symbolic"),
            ("Network", "network-wired-symbolic"),
        ]

        for name, icon in pages:
            row = Gtk.ListBoxRow()
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=_sb_margin)
            box.set_margin_start(_sb_margin)
            box.set_margin_end(_sb_margin)
            box.set_margin_top(_sb_pad)
            box.set_margin_bottom(_sb_pad)
            img = Gtk.Image.new_from_icon_name(icon)
            lbl = Gtk.Label(label=name)
            lbl.set_halign(Gtk.Align.START)
            box.append(img)
            box.append(lbl)
            row.set_child(box)
            row.page_name = name
            sidebar_list.append(row)

        sidebar_box.append(sidebar_list)
        sidebar_page.set_child(sidebar_box)

        # Content area — stack of pages
        self.content_stack = Gtk.Stack()
        self.content_stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)

        self.content_stack.add_named(self._build_system_page(), "System Status")
        self.content_stack.add_named(self._build_tasks_page(), "AI Tasks")
        self.content_stack.add_named(self._build_games_page(), "Games")
        self.content_stack.add_named(self._build_services_page(), "Services")
        self.content_stack.add_named(self._build_trust_page(), "Trust System")
        self.content_stack.add_named(self._build_network_page(), "Network")

        content_page = Adw.NavigationPage(title="Dashboard")
        content_page.set_child(self.content_stack)

        split.set_sidebar(sidebar_page)
        split.set_content(content_page)

        main_box.append(split)
        win.set_content(main_box)

        sidebar_list.connect("row-selected", self.on_page_selected)
        sidebar_list.select_row(sidebar_list.get_row_at_index(0))

        win.present()

        # Start periodic refresh
        GLib.timeout_add_seconds(5, self._auto_refresh)

    def on_page_selected(self, listbox, row):
        if row and hasattr(row, 'page_name'):
            self.content_stack.set_visible_child_name(row.page_name)

    def on_refresh(self, btn):
        self._refresh_data()

    def _auto_refresh(self):
        self._refresh_data()
        return True  # Continue timer

    def _api_get(self, endpoint):
        """Make GET request to AI daemon API."""
        try:
            req = urllib.request.Request(f"{API_BASE}{endpoint}")
            req.add_header("Content-Type", "application/json")
            with urllib.request.urlopen(req, timeout=3) as resp:
                return json.loads(resp.read().decode())
        except Exception:
            return None

    def _api_post(self, endpoint, data=None):
        """Make POST request to AI daemon API."""
        try:
            body = json.dumps(data or {}).encode()
            req = urllib.request.Request(f"{API_BASE}{endpoint}", data=body, method="POST")
            req.add_header("Content-Type", "application/json")
            with urllib.request.urlopen(req, timeout=10) as resp:
                return json.loads(resp.read().decode())
        except Exception as e:
            return {"error": str(e)}

