#!/usr/bin/env python3
"""
Services Manager - GTK4/Adwaita GUI for managing Windows PE and Linux services.

Provides:
- Tabbed view: Windows Services (SCM) and Linux Services (systemd)
- Service list with status badges (Running/Stopped/Failed)
- Start/Stop/Restart/Enable/Disable controls
- Detailed service view with dependencies, PID, uptime, logs
- Toggle between Show All / Running Only
"""

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib, Gdk, Pango
import json
import subprocess
import threading
import urllib.request
import urllib.error
import os
import time

os.environ.setdefault("GDK_BACKEND", "x11")
os.environ.setdefault("GSK_RENDERER", "cairo")

API_BASE = "http://127.0.0.1:8420"


def _scaled_window_size(base_w, base_h, max_frac=0.85):
    """Compute window size that respects screen geometry."""
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                geom = monitors.get_item(0).get_geometry()
                if geom.height <= 768:
                    frac = 0.85
                elif geom.height <= 900:
                    frac = 0.75
                elif geom.height <= 1080:
                    frac = 0.65
                else:
                    frac = max_frac
                w = max(400, min(base_w, int(geom.width * frac)))
                h = max(300, min(base_h, int(geom.height * frac)))
                return w, h
    except Exception:
        pass
    return min(base_w, 700), min(base_h, 500)


def _api_get(endpoint):
    """GET request to the AI daemon API."""
    try:
        req = urllib.request.Request(f"{API_BASE}{endpoint}")
        req.add_header("Content-Type", "application/json")
        with urllib.request.urlopen(req, timeout=5) as resp:
            return json.loads(resp.read().decode())
    except Exception:
        return None


def _api_post(endpoint, data=None):
    """POST request to the AI daemon API."""
    try:
        body = json.dumps(data or {}).encode()
        req = urllib.request.Request(f"{API_BASE}{endpoint}", data=body, method="POST")
        req.add_header("Content-Type", "application/json")
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read().decode())
    except Exception as e:
        return {"error": str(e)}


def _status_label(state):
    """Return human-readable status text."""
    s = str(state).lower()
    if s in ("active", "running", "4"):
        return "Running"
    elif s in ("failed", "error"):
        return "Failed"
    elif s in ("inactive", "stopped", "1", "dead"):
        return "Stopped"
    elif s in ("2", "start_pending"):
        return "Starting"
    elif s in ("3", "stop_pending"):
        return "Stopping"
    return state


_APP_CSS = """
.status-running { color: #73daca; font-weight: bold; }
.status-stopped { color: #565f89; font-weight: bold; }
.status-failed  { color: #f7768e; font-weight: bold; }
.type-badge     { font-size: 10px; padding: 2px 8px; border-radius: 4px; }
.type-windows   { background: alpha(#7aa2f7, 0.15); color: #7aa2f7; }
.type-linux     { background: alpha(#73daca, 0.15); color: #73daca; }
.type-pe        { background: alpha(#bb9af7, 0.15); color: #bb9af7; }
.log-view       { font-family: monospace; font-size: 11px; }
.detail-heading { font-size: 13px; font-weight: bold; }
"""


def _load_css():
    try:
        provider = Gtk.CssProvider()
        provider.load_from_data(_APP_CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
    except Exception:
        pass


class ServicesManager(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.ai_arch.services_manager")
        self.connect("activate", self._on_activate)
        self._win_services = []
        self._linux_services = []
        self._show_running_only = False

    def _on_activate(self, app):
        _load_css()

        self.win = Adw.ApplicationWindow(application=app)
        self.win.set_title("Services Manager")
        w, h = _scaled_window_size(780, 560)
        self.win.set_default_size(w, h)

        self.toast_overlay = Adw.ToastOverlay()

        # Main navigation view for list -> detail drilling
        self._nav_view = Adw.NavigationView()
        self.toast_overlay.set_child(self._nav_view)

        # Build the main list page
        list_page = self._build_list_page()
        self._nav_view.push(list_page)

        self.win.set_content(self.toast_overlay)
        self.win.present()

        # Initial data load
        self._refresh_all()

        # Auto-refresh every 10 seconds
        GLib.timeout_add_seconds(10, self._auto_refresh)

    def _auto_refresh(self):
        self._refresh_all()
        return True

    # ------------------------------------------------------------------
    # List Page
    # ------------------------------------------------------------------

    def _build_list_page(self):
        page = Adw.NavigationPage(title="Services Manager")
        toolbar_view = Adw.ToolbarView()

        # Header bar
        header = Adw.HeaderBar()

        # Refresh button
        refresh_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        refresh_btn.set_tooltip_text("Refresh services")
        refresh_btn.connect("clicked", lambda _: self._refresh_all())
        header.pack_end(refresh_btn)

        # Show All / Running Only toggle
        self._filter_toggle = Gtk.ToggleButton(label="Show All")
        self._filter_toggle.set_tooltip_text("Toggle between all services and running only")
        self._filter_toggle.connect("toggled", self._on_filter_toggled)
        header.pack_end(self._filter_toggle)

        toolbar_view.add_top_bar(header)

        # Tab view with two tabs
        self._tab_view = Adw.TabView()
        self._tab_bar = Adw.TabBar()
        self._tab_bar.set_view(self._tab_view)

        content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content_box.append(self._tab_bar)
        content_box.append(self._tab_view)
        toolbar_view.set_content(content_box)

        # --- Windows Services tab ---
        win_scroll = Gtk.ScrolledWindow(vexpand=True)
        self._win_clamp = Adw.Clamp(maximum_size=800, margin_top=8, margin_bottom=8,
                                     margin_start=12, margin_end=12)
        self._win_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self._win_group = Adw.PreferencesGroup(title="Windows Services (SCM)")
        self._win_box.append(self._win_group)
        self._win_clamp.set_child(self._win_box)
        win_scroll.set_child(self._win_clamp)
        win_tab = self._tab_view.append(win_scroll)
        win_tab.set_title("Windows Services")

        # --- Linux Services tab ---
        linux_scroll = Gtk.ScrolledWindow(vexpand=True)
        self._linux_clamp = Adw.Clamp(maximum_size=800, margin_top=8, margin_bottom=8,
                                       margin_start=12, margin_end=12)
        self._linux_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self._linux_group = Adw.PreferencesGroup(title="Linux Services (systemd)")
        self._linux_box.append(self._linux_group)
        self._linux_clamp.set_child(self._linux_box)
        linux_scroll.set_child(self._linux_clamp)
        linux_tab = self._tab_view.append(linux_scroll)
        linux_tab.set_title("Linux Services")

        # Status bar
        self._status_label = Gtk.Label(label="Loading services...")
        self._status_label.set_halign(Gtk.Align.START)
        self._status_label.set_margin_start(12)
        self._status_label.set_margin_end(12)
        self._status_label.set_margin_top(4)
        self._status_label.set_margin_bottom(4)
        self._status_label.add_css_class("dim-label")
        toolbar_view.add_bottom_bar(self._status_label)

        page.set_child(toolbar_view)
        return page

    def _on_filter_toggled(self, btn):
        self._show_running_only = btn.get_active()
        btn.set_label("Running Only" if self._show_running_only else "Show All")
        self._repopulate()

    # ------------------------------------------------------------------
    # Data Fetching
    # ------------------------------------------------------------------

    def _refresh_all(self):
        def fetch():
            win_data = _api_get("/win-services")
            linux_data = _api_get("/services")
            scm_status = _api_get("/win-services-scm/status")
            GLib.idle_add(self._on_data_received, win_data, linux_data, scm_status)
        threading.Thread(target=fetch, daemon=True).start()

    def _on_data_received(self, win_data, linux_data, scm_status):
        # Parse Windows services
        if win_data and isinstance(win_data, dict) and win_data.get("success"):
            self._win_services = self._parse_scm_output(win_data.get("stdout", ""))
        elif win_data and isinstance(win_data, list):
            self._win_services = win_data
        elif win_data and isinstance(win_data, dict) and "services" in win_data:
            self._win_services = win_data["services"]

        # Parse Linux services
        if linux_data and isinstance(linux_data, list):
            self._linux_services = linux_data
        elif linux_data and isinstance(linux_data, dict) and isinstance(linux_data.get("services"), list):
            self._linux_services = linux_data["services"]

        # Update status bar
        scm_ok = scm_status and scm_status.get("running", False) if scm_status else False
        win_count = len(self._win_services)
        linux_count = len(self._linux_services)
        win_running = sum(1 for s in self._win_services if self._is_running(s))
        linux_running = sum(1 for s in self._linux_services if self._is_running(s))
        scm_text = "SCM: Online" if scm_ok else "SCM: Offline"
        self._status_label.set_text(
            f"{scm_text}  |  Windows: {win_running}/{win_count} running  |  "
            f"Linux: {linux_running}/{linux_count} running"
        )

        self._repopulate()
        return False

    def _parse_scm_output(self, stdout):
        """Parse sc query output into service dicts."""
        services = []
        if not stdout:
            return services
        current = {}
        for line in stdout.split("\n"):
            line = line.strip()
            if not line:
                if current.get("name"):
                    services.append(current)
                    current = {}
                continue
            if ":" in line:
                key, _, val = line.partition(":")
                key = key.strip().lower().replace(" ", "_")
                val = val.strip()
                if key == "service_name":
                    current["name"] = val
                elif key == "display_name":
                    current["display_name"] = val
                elif key == "state":
                    current["state"] = val
                elif key == "type":
                    current["type"] = val
                elif key == "pid":
                    current["pid"] = val
                elif key == "binary_path":
                    current["binary_path"] = val
                elif key == "dependencies":
                    current["dependencies"] = val
                else:
                    current[key] = val
        if current.get("name"):
            services.append(current)
        return services

    def _is_running(self, svc):
        state = str(svc.get("active", svc.get("state", svc.get("sub", "")))).lower()
        return state in ("active", "running", "4")

    # ------------------------------------------------------------------
    # Populate Service Lists
    # ------------------------------------------------------------------

    def _repopulate(self):
        self._rebuild_group("windows")
        self._rebuild_group("linux")

    def _rebuild_group(self, svc_type):
        if svc_type == "windows":
            parent_box = self._win_box
            services = self._win_services
            title = "Windows Services (SCM)"
        else:
            parent_box = self._linux_box
            services = self._linux_services
            title = "Linux Services (systemd)"

        # Remove old group, create new one
        old_group = self._win_group if svc_type == "windows" else self._linux_group
        parent_box.remove(old_group)

        new_group = Adw.PreferencesGroup(title=title)
        if svc_type == "windows":
            self._win_group = new_group
        else:
            self._linux_group = new_group
        parent_box.append(new_group)

        if self._show_running_only:
            services = [s for s in services if self._is_running(s)]

        if not services:
            if svc_type == "windows":
                row = Adw.ActionRow(title="No Windows services found")
                row.set_subtitle("SCM daemon may not be running, or no PE services installed")
            else:
                row = Adw.ActionRow(title="No Linux services found")
                row.set_subtitle("AI daemon may not be responding")
            new_group.add(row)
            return

        sort_key = (lambda s: s.get("name", "")) if svc_type == "windows" \
                   else (lambda s: s.get("unit", s.get("name", "")))
        for svc in sorted(services, key=sort_key):
            self._add_service_row(new_group, svc, svc_type)

    def _add_service_row(self, group, svc, svc_type):
        name = svc.get("name", svc.get("unit", "unknown"))
        state = svc.get("active", svc.get("state", "unknown"))
        description = svc.get("description", svc.get("display_name", ""))
        sub = svc.get("sub", "")

        row = Adw.ActionRow(title=name)
        row.set_activatable(True)
        if description:
            row.set_subtitle(description)

        # Status label as prefix
        status_text = _status_label(state)
        status_lbl = Gtk.Label(label=status_text)
        status_lbl.set_valign(Gtk.Align.CENTER)
        css_class = "status-running" if status_text == "Running" else \
                    "status-failed" if status_text == "Failed" else "status-stopped"
        status_lbl.add_css_class(css_class)
        row.add_prefix(status_lbl)

        # Type badge
        type_lbl = Gtk.Label(label=svc_type.upper())
        type_lbl.set_valign(Gtk.Align.CENTER)
        type_lbl.add_css_class("type-badge")
        type_lbl.add_css_class(f"type-{svc_type}")
        type_lbl.set_margin_end(8)
        row.add_suffix(type_lbl)

        # Action buttons
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        btn_box.set_valign(Gtk.Align.CENTER)

        is_running = status_text == "Running"

        if not is_running:
            start_btn = Gtk.Button(icon_name="media-playback-start-symbolic")
            start_btn.set_tooltip_text("Start")
            start_btn.add_css_class("flat")
            start_btn.connect("clicked", lambda _, n=name, t=svc_type: self._svc_action(n, "start", t))
            btn_box.append(start_btn)

        if is_running:
            stop_btn = Gtk.Button(icon_name="media-playback-stop-symbolic")
            stop_btn.set_tooltip_text("Stop")
            stop_btn.add_css_class("flat")
            stop_btn.connect("clicked", lambda _, n=name, t=svc_type: self._svc_action(n, "stop", t))
            btn_box.append(stop_btn)

            restart_btn = Gtk.Button(icon_name="view-refresh-symbolic")
            restart_btn.set_tooltip_text("Restart")
            restart_btn.add_css_class("flat")
            restart_btn.connect("clicked", lambda _, n=name, t=svc_type: self._svc_action(n, "restart", t))
            btn_box.append(restart_btn)

        row.add_suffix(btn_box)

        # Chevron for detail navigation
        chevron = Gtk.Image.new_from_icon_name("go-next-symbolic")
        chevron.set_valign(Gtk.Align.CENTER)
        chevron.add_css_class("dim-label")
        row.add_suffix(chevron)

        # Clicking the row opens detail view
        row.connect("activated", lambda _, n=name, t=svc_type, s=svc: self._show_detail(n, t, s))

        group.add(row)

    # ------------------------------------------------------------------
    # Service Actions
    # ------------------------------------------------------------------

    def _svc_action(self, name, action, svc_type):
        def do_action():
            if svc_type == "windows":
                if action == "restart":
                    _api_post(f"/win-services/{name}/stop")
                    time.sleep(1)
                    result = _api_post(f"/win-services/{name}/start")
                else:
                    result = _api_post(f"/win-services/{name}/{action}")
            else:
                result = _api_post(f"/services/{action}", {"service": name})

            def show_result():
                success = result and (result.get("success", False) or "error" not in result)
                toast = Adw.Toast(title=f"{action.capitalize()} {name}: {'OK' if success else 'Failed'}")
                toast.set_timeout(3)
                self.toast_overlay.add_toast(toast)
                self._refresh_all()
                return False
            GLib.idle_add(show_result)
        threading.Thread(target=do_action, daemon=True).start()

    def _svc_enable_disable(self, name, enable):
        def do_it():
            action = "enable" if enable else "disable"
            try:
                proc = subprocess.run(
                    ["systemctl", action, name],
                    capture_output=True, text=True, timeout=15
                )
                ok = proc.returncode == 0
            except Exception:
                ok = False
            def show():
                verb = "Enable" if enable else "Disable"
                toast = Adw.Toast(title=f"{verb} {name}: {'OK' if ok else 'Failed'}")
                toast.set_timeout(3)
                self.toast_overlay.add_toast(toast)
                return False
            GLib.idle_add(show)
        threading.Thread(target=do_it, daemon=True).start()

    # ------------------------------------------------------------------
    # Detail View
    # ------------------------------------------------------------------

    def _show_detail(self, name, svc_type, svc_data):
        page = Adw.NavigationPage(title=name)
        toolbar_view = Adw.ToolbarView()

        header = Adw.HeaderBar()
        toolbar_view.add_top_bar(header)

        scroll = Gtk.ScrolledWindow(vexpand=True)
        clamp = Adw.Clamp(maximum_size=700, margin_top=12, margin_bottom=12,
                          margin_start=16, margin_end=16)

        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)

        # --- Info group ---
        info_group = Adw.PreferencesGroup(title="Service Information")

        name_row = Adw.ActionRow(title="Name")
        name_row.set_subtitle(name)
        info_group.add(name_row)

        desc = svc_data.get("description", svc_data.get("display_name", ""))
        if desc:
            desc_row = Adw.ActionRow(title="Description")
            desc_row.set_subtitle(desc)
            info_group.add(desc_row)

        type_row = Adw.ActionRow(title="Type")
        type_row.set_subtitle(svc_type.capitalize())
        info_group.add(type_row)

        state = svc_data.get("active", svc_data.get("state", "unknown"))
        status_row = Adw.ActionRow(title="Status")
        status_text = _status_label(state)
        status_lbl = Gtk.Label(label=status_text)
        css_class = "status-running" if status_text == "Running" else \
                    "status-failed" if status_text == "Failed" else "status-stopped"
        status_lbl.add_css_class(css_class)
        status_lbl.set_valign(Gtk.Align.CENTER)
        status_row.add_suffix(status_lbl)
        info_group.add(status_row)

        pid = svc_data.get("pid", "")
        if pid and str(pid) != "0":
            pid_row = Adw.ActionRow(title="PID")
            pid_row.set_subtitle(str(pid))
            info_group.add(pid_row)

        binary = svc_data.get("binary_path", "")
        if binary:
            bin_row = Adw.ActionRow(title="Binary Path")
            bin_row.set_subtitle(binary)
            info_group.add(bin_row)

        sub = svc_data.get("sub", "")
        if sub:
            sub_row = Adw.ActionRow(title="Sub-state")
            sub_row.set_subtitle(sub)
            info_group.add(sub_row)

        main_box.append(info_group)

        # --- Dependencies group ---
        deps = svc_data.get("dependencies", "")
        if deps:
            dep_group = Adw.PreferencesGroup(title="Dependencies")
            for dep in (deps.split(",") if "," in deps else deps.split()):
                dep = dep.strip()
                if dep:
                    dep_row = Adw.ActionRow(title=dep)
                    dep_group.add(dep_row)
            main_box.append(dep_group)

        # --- Actions group ---
        actions_group = Adw.PreferencesGroup(title="Actions")
        is_running = status_text == "Running"

        start_row = Adw.ActionRow(title="Start Service")
        start_row.set_subtitle("Launch the service process")
        start_btn = Gtk.Button(icon_name="media-playback-start-symbolic")
        start_btn.set_valign(Gtk.Align.CENTER)
        start_btn.add_css_class("suggested-action")
        start_btn.set_sensitive(not is_running)
        start_btn.connect("clicked", lambda _: self._svc_action(name, "start", svc_type))
        start_row.add_suffix(start_btn)
        start_row.set_activatable_widget(start_btn)
        actions_group.add(start_row)

        stop_row = Adw.ActionRow(title="Stop Service")
        stop_row.set_subtitle("Terminate the service process")
        stop_btn = Gtk.Button(icon_name="media-playback-stop-symbolic")
        stop_btn.set_valign(Gtk.Align.CENTER)
        stop_btn.add_css_class("destructive-action")
        stop_btn.set_sensitive(is_running)
        stop_btn.connect("clicked", lambda _: self._svc_action(name, "stop", svc_type))
        stop_row.add_suffix(stop_btn)
        stop_row.set_activatable_widget(stop_btn)
        actions_group.add(stop_row)

        restart_row = Adw.ActionRow(title="Restart Service")
        restart_row.set_subtitle("Stop and start the service")
        restart_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        restart_btn.set_valign(Gtk.Align.CENTER)
        restart_btn.set_sensitive(is_running)
        restart_btn.connect("clicked", lambda _: self._svc_action(name, "restart", svc_type))
        restart_row.add_suffix(restart_btn)
        restart_row.set_activatable_widget(restart_btn)
        actions_group.add(restart_row)

        if svc_type == "linux":
            enable_row = Adw.ActionRow(title="Enable on Boot")
            enable_row.set_subtitle("Start this service automatically at boot")
            enable_btn = Gtk.Button(label="Enable")
            enable_btn.set_valign(Gtk.Align.CENTER)
            enable_btn.connect("clicked", lambda _: self._svc_enable_disable(name, True))
            enable_row.add_suffix(enable_btn)
            enable_row.set_activatable_widget(enable_btn)
            actions_group.add(enable_row)

            disable_row = Adw.ActionRow(title="Disable on Boot")
            disable_row.set_subtitle("Prevent this service from starting at boot")
            disable_btn = Gtk.Button(label="Disable")
            disable_btn.set_valign(Gtk.Align.CENTER)
            disable_btn.add_css_class("destructive-action")
            disable_btn.connect("clicked", lambda _: self._svc_enable_disable(name, False))
            disable_row.add_suffix(disable_btn)
            disable_row.set_activatable_widget(disable_btn)
            actions_group.add(disable_row)

        main_box.append(actions_group)

        # --- Logs group ---
        log_group = Adw.PreferencesGroup(title="Recent Log Output")
        log_frame = Gtk.Frame()
        log_frame.set_margin_top(4)

        log_view = Gtk.TextView(editable=False, wrap_mode=Gtk.WrapMode.WORD_CHAR,
                                cursor_visible=False, top_margin=8, bottom_margin=8,
                                left_margin=8, right_margin=8)
        log_view.add_css_class("log-view")
        log_view.set_vexpand(False)
        log_view.set_size_request(-1, 200)

        log_scroll = Gtk.ScrolledWindow()
        log_scroll.set_child(log_view)
        log_scroll.set_min_content_height(200)
        log_scroll.set_max_content_height(300)
        log_frame.set_child(log_scroll)
        log_group.add(log_frame)
        main_box.append(log_group)

        # Fetch logs in background
        self._fetch_logs(name, svc_type, log_view)

        # Fetch extra detail for Linux services
        if svc_type == "linux":
            self._fetch_linux_detail(name, info_group)

        clamp.set_child(main_box)
        scroll.set_child(clamp)
        toolbar_view.set_content(scroll)
        page.set_child(toolbar_view)
        self._nav_view.push(page)

    def _fetch_logs(self, name, svc_type, text_view):
        def fetch():
            try:
                unit = name if svc_type == "linux" else "scm-daemon"
                proc = subprocess.run(
                    ["journalctl", "-u", unit, "-n", "20", "--no-pager", "-o", "short-iso"],
                    capture_output=True, text=True, timeout=10
                )
                output = proc.stdout or proc.stderr or "(no log output)"
            except Exception as e:
                output = f"(could not fetch logs: {e})"
            def update():
                buf = text_view.get_buffer()
                buf.set_text(output)
                return False
            GLib.idle_add(update)
        threading.Thread(target=fetch, daemon=True).start()

    def _fetch_linux_detail(self, name, info_group):
        def fetch():
            try:
                proc = subprocess.run(
                    ["systemctl", "show", name,
                     "--property=ActiveEnterTimestamp,MainPID,ActiveState,SubState,"
                     "Description,Requires,WantedBy,RequiredBy"],
                    capture_output=True, text=True, timeout=10
                )
                props = {}
                for line in proc.stdout.strip().split("\n"):
                    if "=" in line:
                        k, _, v = line.partition("=")
                        props[k.strip()] = v.strip()
                def update():
                    ts = props.get("ActiveEnterTimestamp", "")
                    if ts and ts != "n/a" and props.get("ActiveState") == "active":
                        uptime_row = Adw.ActionRow(title="Active Since")
                        uptime_row.set_subtitle(ts)
                        info_group.add(uptime_row)
                    main_pid = props.get("MainPID", "0")
                    if main_pid and main_pid != "0":
                        pid_row = Adw.ActionRow(title="Main PID")
                        pid_row.set_subtitle(main_pid)
                        info_group.add(pid_row)
                    requires = props.get("Requires", "")
                    if requires:
                        dep_row = Adw.ActionRow(title="Requires")
                        dep_row.set_subtitle(requires)
                        info_group.add(dep_row)
                    wanted_by = props.get("WantedBy", "")
                    if wanted_by:
                        wb_row = Adw.ActionRow(title="Wanted By")
                        wb_row.set_subtitle(wanted_by)
                        info_group.add(wb_row)
                    required_by = props.get("RequiredBy", "")
                    if required_by:
                        rb_row = Adw.ActionRow(title="Required By")
                        rb_row.set_subtitle(required_by)
                        info_group.add(rb_row)
                    return False
                GLib.idle_add(update)
            except Exception:
                pass
        threading.Thread(target=fetch, daemon=True).start()


def main():
    app = ServicesManager()
    app.run(None)


if __name__ == "__main__":
    main()
