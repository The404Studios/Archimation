    def _auto_refresh(self):
        self._check_connection()
        return True

    def _monitor_tick(self):
        """Auto-refresh monitor page every 3 seconds."""
        if (self.stack.get_visible_child_name()
                == "Monitor"):
            self._refresh_monitor()
        return True


def main():
    app = ContusionApp()
    app.run()


if __name__ == "__main__":
    main()
CONTUSION_APP

    # ==========================================================================
    # AI SCREENSHOT HELPER (multi-mode: full/region/window/delay)
    # ==========================================================================
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-screenshot" <<'AISCREENSHOT'
#!/bin/bash
# ai-screenshot - Multi-mode screenshot with clipboard copy & AI daemon integration
# Usage: ai-screenshot [full|region|window|delay [seconds]]
#
# Modes:
#   full    - Capture the entire screen (default)
#   region  - Interactive region selection (click and drag)
#   window  - Capture the focused window
#   delay   - Full screen after a countdown (default 5 seconds)

MODE="${1:-full}"
DEST_DIR="${HOME}/Pictures"
mkdir -p "$DEST_DIR"
FNAME="Screenshot_$(date +%Y-%m-%d_%H-%M-%S).png"
FPATH="$DEST_DIR/$FNAME"

# Check for screenshot tool
if ! command -v scrot &>/dev/null && ! command -v import &>/dev/null; then
    notify-send -i dialog-error -t 3000 "Screenshot Failed" "No screenshot tool found (install scrot)"
    exit 1
fi

capture_full() {
    if command -v scrot &>/dev/null; then
        scrot -q 90 "$FPATH"
    else
        import -window root "$FPATH"
    fi
}

capture_region() {
    if command -v scrot &>/dev/null; then
        scrot -s -q 90 "$FPATH"
    else
        import "$FPATH"
    fi
}

capture_window() {
    if command -v scrot &>/dev/null; then
        scrot -u -q 90 "$FPATH"
    else
        import -window "$(xdotool getactivewindow)" "$FPATH"
    fi
}

capture_delay() {
    local SECS="${2:-5}"
    notify-send -i applets-screenshooter -t $((SECS * 1000))         "Screenshot" "Capturing in ${SECS} seconds..."
    if command -v scrot &>/dev/null; then
        scrot -d "$SECS" -q 90 "$FPATH"
    else
        sleep "$SECS"
        import -window root "$FPATH"
    fi
}

case "$MODE" in
    full)   capture_full ;;
    region) capture_region ;;
    window) capture_window ;;
    delay)  capture_delay "$@" ;;
    *)
        echo "Usage: ai-screenshot [full|region|window|delay [seconds]]" >&2
        exit 1
        ;;
esac

if [ -f "$FPATH" ]; then
    # Copy to clipboard
    xclip -selection clipboard -t image/png -i "$FPATH" 2>/dev/null

    # Notify with preview
    notify-send -i applets-screenshooter -t 4000         "Screenshot Saved" "$FNAME (copied to clipboard)"

    # Optionally notify AI daemon (fire-and-forget)
    curl -s -X POST --connect-timeout 1         -H "Content-Type: application/json"         -d "{\"action\": \"screenshot\", \"path\": \"$FPATH\", \"mode\": \"$MODE\"}"         http://127.0.0.1:8420/automate/notify 2>/dev/null &
fi
AISCREENSHOT

    # ==========================================================================
    # SYSTEM UPDATE CHECKER (notifies user of available Arch package updates)
    # ==========================================================================
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-update-checker" <<'UPDATECHECKER'
#!/bin/bash
# ai-update-checker - Check for available system updates and notify the user
# Part of AI Arch Linux. Requires pacman-contrib (provides checkupdates).

COUNT=$(checkupdates 2>/dev/null | wc -l)
if [ "$COUNT" -gt 0 ]; then
    UPDATES=$(checkupdates 2>/dev/null | head -5)
    EXTRA=""
    if [ "$COUNT" -gt 5 ]; then
        EXTRA="\n... and $((COUNT - 5)) more"
    fi
    notify-send "System Updates Available" \
        "$COUNT packages can be updated:\n$UPDATES$EXTRA" \
        --icon=software-update-available \
        --urgency=low \
        --app-name="AI Arch Linux"
fi
UPDATECHECKER

    # --- systemd user timer for update checks (every 4 hours) ---
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/user/ai-update-checker.service" <<'UPDATESVC'
[Unit]
Description=Check for available Arch package updates
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/ai-update-checker
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/%U/bus
UPDATESVC

    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/user/ai-update-checker.timer" <<'UPDATETIMER'
