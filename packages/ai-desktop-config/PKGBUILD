    # --- Lock screen wrapper (blurred + dimmed wallpaper via i3lock) ---
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-lock-screen" <<'LOCKSCRIPT'
#!/bin/bash
# ai-lock-screen - blurred/dimmed wallpaper lock screen using i3lock
# Fallback chain: cached blur -> generate blur -> solid color (#1a1b26)

WALLPAPER_PNG="/usr/share/backgrounds/ai-arch/default.png"
WALLPAPER_SVG="/usr/share/backgrounds/ai-arch/default.svg"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ai-arch"
LOCK_CACHE="$CACHE_DIR/lockscreen.png"
LOCK_STAMP="$CACHE_DIR/lockscreen.stamp"
FALLBACK_COLOR="1a1b26"

get_screen_res() {
    if command -v xdpyinfo &>/dev/null; then
        xdpyinfo 2>/dev/null | awk '/dimensions:/{print $2}' | head -1
    elif command -v xrandr &>/dev/null; then
        xrandr 2>/dev/null | awk '/ connected.*[0-9]+x[0-9]+/{for(i=1;i<=NF;i++) if($i~/^[0-9]+x[0-9]+/) {print $i; exit}}'
    fi
}

# Locate a usable wallpaper source, converting SVG if needed
find_wallpaper() {
    [ -f "$WALLPAPER_PNG" ] && { echo "$WALLPAPER_PNG"; return 0; }
    if [ -f "$WALLPAPER_SVG" ]; then
        local tmp="$CACHE_DIR/wallpaper-src.png"
        if command -v rsvg-convert &>/dev/null; then
            rsvg-convert -w 1920 -h 1080 "$WALLPAPER_SVG" -o "$tmp" 2>/dev/null && { echo "$tmp"; return 0; }
        elif command -v convert &>/dev/null; then
            convert "$WALLPAPER_SVG" -resize 1920x1080 "$tmp" 2>/dev/null && { echo "$tmp"; return 0; }
        fi
    fi
    return 1
}

# Check if cached lock image still matches wallpaper + resolution
cache_valid() {
    [ -f "$LOCK_CACHE" ] && [ -f "$LOCK_STAMP" ] || return 1
    local src="$1" res="$2"
    local src_id
    src_id="$(stat -c '%Y%s' "$src" 2>/dev/null || stat -f '%m%z' "$src" 2>/dev/null)"
    local want="$src_id $res"
    [ "$(cat "$LOCK_STAMP" 2>/dev/null)" = "$want" ]
}

# Write stamp so future runs can skip regeneration
write_stamp() {
    local src="$1" res="$2"
    local src_id
    src_id="$(stat -c '%Y%s' "$src" 2>/dev/null || stat -f '%m%z' "$src" 2>/dev/null)"
    echo "$src_id $res" > "$LOCK_STAMP"
}

# Generate blurred + dimmed lock image at exact screen resolution
generate_lock_image() {
    local src="$1" sw="$2" sh="$3"
    if command -v convert &>/dev/null; then
        convert "$src" -resize "${sw}x${sh}!" -blur 0x8 -modulate 60 "$LOCK_CACHE" 2>/dev/null && return 0
    elif command -v ffmpeg &>/dev/null; then
        ffmpeg -loglevel error -y -i "$src" \
            -vf "scale=${sw}:${sh}:flags=bilinear,boxblur=10:10,eq=brightness=-0.15" \
            -frames:v 1 "$LOCK_CACHE" 2>/dev/null && return 0
    fi
    # No blur tools -- plain resize as last resort
    cp "$src" "$LOCK_CACHE" 2>/dev/null
}

# --- Main ---
mkdir -p "$CACHE_DIR" 2>/dev/null

RES="$(get_screen_res)"
RES="${RES:-1920x1080}"
SW="${RES%%x*}"; SH="${RES##*x}"

SRC="$(find_wallpaper)"
if [ -n "$SRC" ]; then
    # Fast path: serve from cache if wallpaper + resolution unchanged
    if cache_valid "$SRC" "$RES"; then
        exec i3lock -n -i "$LOCK_CACHE"
    fi
    # Slow path: regenerate blur (< 1s on modern hardware)
    if generate_lock_image "$SRC" "$SW" "$SH"; then
        write_stamp "$SRC" "$RES"
        exec i3lock -n -i "$LOCK_CACHE"
    fi
fi

# Final fallback: solid dark color
exec i3lock -n -c "$FALLBACK_COLOR"
LOCKSCRIPT

    install -Dm644 /dev/stdin "$pkgdir/etc/skel/.config/autostart/xss-lock.desktop" <<'XSSLOCK_AUTO'
