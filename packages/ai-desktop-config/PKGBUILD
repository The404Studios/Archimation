# Bash completion for ai-assist (AI Arch Linux CLI)
_ai_assist_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Handle based on previous word
    case "$prev" in
        ai|ai-assist)
            COMPREPLY=($(compgen -W "automate macro launch apps processes status install remove update search diagnose config logs security contusion scan analyze discover memory help version history clear" -- "$cur"))
            return 0
            ;;
        diagnose|status|version|history|clear|apps|processes)
            COMPREPLY=()
            return 0
            ;;
        scan|analyze)
            # Complete with running PIDs
            COMPREPLY=($(compgen -W "$(ps -e -o pid= 2>/dev/null | tr -s ' ')" -- "$cur"))
            return 0
            ;;
        discover)
            COMPREPLY=($(compgen -W "priority $(ps -e -o pid= 2>/dev/null | tr -s ' ')" -- "$cur"))
            return 0
            ;;
        memory)
            COMPREPLY=($(compgen -W "processes $(ps -e -o pid= 2>/dev/null | tr -s ' ')" -- "$cur"))
            return 0
            ;;
        config)
            COMPREPLY=($(compgen -W "show set reset --help" -- "$cur"))
            return 0
            ;;
        logs)
            COMPREPLY=($(compgen -W "daemon trust cortex -f --help" -- "$cur"))
            return 0
            ;;
        security)
            COMPREPLY=($(compgen -W "status audit emergency-stop --help" -- "$cur"))
            return 0
            ;;
        contusion)
            COMPREPLY=($(compgen -W "search stats app --help" -- "$cur"))
            return 0
            ;;
        macro)
            COMPREPLY=($(compgen -W "record play list stop" -- "$cur"))
            return 0
            ;;
        update)
            COMPREPLY=($(compgen -W "check list install system" -- "$cur"))
            return 0
            ;;
        install|remove|search|launch)
            # Let default file/command completion handle these
            return 0
            ;;
        set)
            # After "config set", suggest config keys
            if [ "${COMP_WORDS[COMP_CWORD-2]}" = "config" ]; then
                COMPREPLY=($(compgen -W "server.host server.port auth.enabled logging.level screen.capture_method input.method audit.log trust.poll_interval automation.full_access" -- "$cur"))
                return 0
            fi
            ;;
        daemon|trust|cortex)
            # After "logs daemon/trust/cortex", suggest -f
            if [ "${COMP_WORDS[COMP_CWORD-2]}" = "logs" ]; then
                COMPREPLY=($(compgen -W "-f" -- "$cur"))
                return 0
            fi
            ;;
    esac

    # Default: if first arg position, show top-level commands
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=($(compgen -W "automate macro launch apps processes status install remove update search diagnose config logs security contusion scan analyze discover memory help version history clear" -- "$cur"))
    fi
}
complete -F _ai_assist_completion ai-assist
complete -F _ai_assist_completion ai
