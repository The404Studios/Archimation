    # --- Action handlers ---

    def on_run_task(self, widget):
        cmd = self.task_entry.get_text().strip()
        if not cmd:
            return
        self.task_entry.set_text("")
        buf = self.task_output.get_buffer()
        buf.insert(buf.get_end_iter(), f"\n$ {cmd}\n")

        def run():
            result = self._api_post("/system/command", {"command": cmd, "timeout": 30})
            GLib.idle_add(self._show_task_result, result)

        threading.Thread(target=run, daemon=True).start()

    def _show_task_result(self, result):
        buf = self.task_output.get_buffer()
        if result and "stdout" in result:
            buf.insert(buf.get_end_iter(), result["stdout"])
        if result and "stderr" in result:
            buf.insert(buf.get_end_iter(), result["stderr"])
        if result and "error" in result:
            buf.insert(buf.get_end_iter(), f"Error: {result['error']}\n")
        return False

    def on_install_game(self, btn):
        dialog = Gtk.FileDialog()
        dialog.set_title("Select Game Installer (.exe)")
        filter_exe = Gtk.FileFilter()
        filter_exe.set_name("Windows Executables")
        filter_exe.add_pattern("*.exe")
        filter_exe.add_pattern("*.EXE")
        filters = Gio.ListStore.new(Gtk.FileFilter)
        filters.append(filter_exe)
        dialog.set_filters(filters)
        dialog.open(self.get_active_window(), None, self._on_game_file_selected)

    def _on_game_file_selected(self, dialog, result):
        try:
            file = dialog.open_finish(result)
            if file:
                path = file.get_path()
                subprocess.Popen(["/usr/bin/pe-run-game", path])
        except Exception:
            pass

    def on_scan_games(self, btn):
        """Scan for .exe files in common game directories."""
        def scan():
            games_dirs = [
                os.path.expanduser("~/.pe-compat/drives/c/Games"),
                os.path.expanduser("~/.pe-compat/drives/c/Program Files"),
                os.path.expanduser("~/Games"),
            ]
            found = []
            for d in games_dirs:
                if os.path.isdir(d):
                    for root, dirs, files in os.walk(d):
                        for f in files:
                            if f.lower().endswith('.exe'):
                                full = os.path.join(root, f)
                                found.append((f, full))
            GLib.idle_add(self._populate_games_list, found)

        threading.Thread(target=scan, daemon=True).start()

    def _populate_games_list(self, games):
        # Clear existing
        while True:
            row = self.games_list.get_row_at_index(0)
            if row is None:
                break
            self.games_list.remove(row)

        for name, path in sorted(games):
            row = Gtk.ListBoxRow()
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            box.set_margin_start(12)
            box.set_margin_end(12)
            box.set_margin_top(6)
            box.set_margin_bottom(6)
            icon = Gtk.Image.new_from_icon_name("application-x-executable")
            label = Gtk.Label(label=name)
            label.set_halign(Gtk.Align.START)
            label.set_hexpand(True)
            path_label = Gtk.Label(label=os.path.dirname(path))
            path_label.add_css_class("dim-label")
            box.append(icon)
            box.append(label)
            box.append(path_label)
            row.set_child(box)
            row.exe_path = path
            self.games_list.append(row)
        return False

    def on_play_game(self, btn):
        row = self.games_list.get_selected_row()
        if row and hasattr(row, 'exe_path'):
            subprocess.Popen(["/usr/bin/pe-run-game", row.exe_path])

    def on_create_game_shortcut(self, btn):
        row = self.games_list.get_selected_row()
        if row and hasattr(row, 'exe_path'):
            subprocess.Popen(["/usr/bin/pe-create-shortcut", row.exe_path])

    def _run_action(self, cmd):
        def run():
            self._api_post("/system/command", {"command": cmd, "timeout": 60})
        threading.Thread(target=run, daemon=True).start()

    def _confirm_action(self, title, message, cmd):
        """Show a confirmation dialog before running a dangerous action."""
        win = self.get_active_window()
        dialog = Adw.AlertDialog(heading=title, body=message)
        dialog.add_response("cancel", "Cancel")
        dialog.add_response("confirm", "Confirm")
        dialog.set_response_appearance("confirm", Adw.ResponseAppearance.DESTRUCTIVE)
        dialog.set_default_response("cancel")
        dialog.set_close_response("cancel")
        dialog.connect("response", lambda d, resp: self._run_action(cmd) if resp == "confirm" else None)
        dialog.present(win)

    def _refresh_data(self):
        def refresh():
            # System info
            info = self._api_get("/system/info")
            if info:
                text = (
                    f"Hostname: {info.get('hostname', 'N/A')}\n"
                    f"Kernel: {info.get('kernel', 'N/A')}\n"
                    f"CPU: {info.get('cpu_percent', 'N/A')}% used\n"
                    f"Memory: {info.get('memory_used_gb', 'N/A')} / {info.get('memory_total_gb', 'N/A')} GB\n"
                    f"Disk: {info.get('disk_used_gb', 'N/A')} / {info.get('disk_total_gb', 'N/A')} GB\n"
                    f"Uptime: {info.get('uptime', 'N/A')}"
                )
                GLib.idle_add(self.sys_status_label.set_text, text)

            # Daemon health
            health = self._api_get("/health")
            if health:
                GLib.idle_add(self.daemon_status_label.set_text,
                            f"Status: Online | Version: {health.get('version', '?')}")
            else:
                GLib.idle_add(self.daemon_status_label.set_text,
                            "Status: Offline (daemon not running)")

            # Trust data
            trust = self._api_get("/trust/subjects")
            if trust:
                text = json.dumps(trust, indent=2)[:2000]
                GLib.idle_add(self.trust_status_label.set_text, text)
            else:
                GLib.idle_add(self.trust_status_label.set_text,
                            "Trust system not available (kernel module not loaded)")

            # Services list
            services = self._api_get("/services")
            if services:
                def populate_services(svc_data):
                    # Clear existing rows
                    while True:
                        row = self.services_list.get_row_at_index(0)
                        if row is None:
                            break
                        self.services_list.remove(row)
                    # Add one row per service
                    for svc in (svc_data if isinstance(svc_data, list) else []):
                        name   = svc.get("unit", svc.get("name", "?"))
                        state  = svc.get("active", svc.get("active_state", "?"))
                        sub    = svc.get("sub", svc.get("sub_state", ""))
                        label_text = f"{name}  —  {state}" + (f" ({sub})" if sub else "")
                        row = Gtk.ListBoxRow()
                        lbl = Gtk.Label(label=label_text)
                        lbl.set_halign(Gtk.Align.START)
                        lbl.set_margin_start(12)
                        lbl.set_margin_end(12)
                        lbl.set_margin_top(6)
                        lbl.set_margin_bottom(6)
                        if state == "active":
                            lbl.add_css_class("success")
                        elif state == "failed":
                            lbl.add_css_class("error")
                        row.set_child(lbl)
                        self.services_list.append(row)
                GLib.idle_add(populate_services, services)

            # Network
            net = self._api_get("/network/ip")
            if net:
                text = json.dumps(net, indent=2)[:1000]
                GLib.idle_add(self.network_status_label.set_text, text)

        threading.Thread(target=refresh, daemon=True).start()


def main():
    app = AIControlPanel()
    app.run(None)


if __name__ == "__main__":
    main()
