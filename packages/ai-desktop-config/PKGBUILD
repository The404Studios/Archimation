application/vnd.arch-linux.package=ai-pkg-install.desktop
application/zip=org.gnome.FileRoller.desktop
application/x-7z-compressed=org.gnome.FileRoller.desktop
application/x-compressed-tar=org.gnome.FileRoller.desktop
application/gzip=org.gnome.FileRoller.desktop
application/x-tar=org.gnome.FileRoller.desktop
application/x-rar=org.gnome.FileRoller.desktop
application/x-bzip2-compressed-tar=org.gnome.FileRoller.desktop
MIMEAPPS

    # Also install system-wide defaults
    install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/mimeapps.list" <<'SYSMIME'
[Default Applications]
application/x-msdos-program=pe-loader.desktop
application/x-dosexec=pe-loader.desktop
