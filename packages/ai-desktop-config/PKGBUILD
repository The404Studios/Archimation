def get_all_timezones():
    """Return sorted list of all available timezones."""
    tz_dir = "/usr/share/zoneinfo"
    zones = []
    for root, dirs, files in os.walk(tz_dir):
        # Skip non-timezone directories
        dirs[:] = [d for d in dirs if d not in (
            "posix", "right", "Etc", "SystemV", "+VERSION"
        )]
        for f in files:
            if f in ("posixrules", "tzdata.zi", "leapseconds", "leap-seconds.list",
                      "zone.tab", "zone1970.tab", "iso3166.tab", "SECURITY"):
                continue
            rel = os.path.relpath(os.path.join(root, f), tz_dir)
            if "/" in rel and not rel.startswith("."):
                zones.append(rel)
    return sorted(set(zones))


def get_block_devices():
    """Get list of block devices suitable for installation."""
    try:
        result = subprocess.run(
            ["lsblk", "-J", "-o", "NAME,SIZE,TYPE,MODEL,TRAN,MOUNTPOINTS,PKNAME,RM"],
            capture_output=True, text=True, timeout=10,
        )
        data = json.loads(result.stdout)
    except Exception:
        return []

    # Find the device backing the live ISO
    live_devices = set()
    try:
        with open("/proc/cmdline", "r") as f:
            cmdline = f.read()
        # Look for archiso boot device
        for part in cmdline.split():
            if part.startswith("archisobasedir=") or part.startswith("img_dev="):
                dev = part.split("=", 1)[1]
                # Extract base device name
                base = re.sub(r'p?\d+$', '', os.path.basename(dev))
                live_devices.add(base)
    except Exception:
        pass

    # Also detect by checking what's mounted as the ISO
    try:
        result2 = subprocess.run(
            ["findmnt", "-n", "-o", "SOURCE", "/run/archiso/bootmnt"],
            capture_output=True, text=True, timeout=5,
        )
        if result2.returncode == 0:
            src = result2.stdout.strip()
            base = re.sub(r'p?\d+$', '', os.path.basename(src))
            live_devices.add(base)
    except Exception:
        pass

    devices = []
    for dev in data.get("blockdevices", []):
        dtype = dev.get("type", "")
        name = dev.get("name", "")

        # Only show whole disks
        if dtype != "disk":
            continue

        # Skip the live ISO device
        if name in live_devices:
            continue

        # Skip loop devices, ram disks, etc.
        if name.startswith(("loop", "ram", "zram", "sr")):
            continue

        # Skip removable media that's likely the live USB
        # (but still include USB drives that aren't the boot device)
        rm = dev.get("rm", False)

        size = dev.get("size", "0B")
        model = dev.get("model", "").strip() if dev.get("model") else "Unknown"
        tran = dev.get("tran", "").upper() if dev.get("tran") else ""

        # Determine interface label
        if "nvme" in name:
            iface = "NVMe"
        elif tran == "SATA":
            iface = "SATA"
        elif tran == "USB":
            iface = "USB"
        elif tran:
            iface = tran
        else:
            iface = "Unknown"

        devices.append({
            "name": name,
            "path": f"/dev/{name}",
            "size": size,
            "model": model,
            "interface": iface,
            "removable": rm,
            "recommended": "nvme" in name,
        })

    return devices


def get_ram_gb():
    """Return total RAM in GB (rounded)."""
    try:
        with open("/proc/meminfo") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    kb = int(line.split()[1])
                    return round(kb / (1024 * 1024))
    except Exception:
        pass
    return 8


class InstallerApp(Adw.Application):
    """Multi-page disk installer wizard."""

    def __init__(self):
        super().__init__(application_id="org.ai_arch.installer")
        self.connect("activate", self._on_activate)

        # State
        self._devices = []
        self._selected_device = None
        self._use_swap = True
        self._swap_size_gb = min(get_ram_gb(), 8)
        self._username = "arch"
        self._password = ""
        self._hostname = "archwindows"
        self._timezone = "America/New_York"
        self._enable_ai = True
        self._install_thread = None
        self._install_cancelled = False
        self._log_buffer = ""

    def _on_activate(self, app):
        # Check if running as root
        if os.geteuid() != 0:
            dialog = Gtk.MessageDialog(
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text="Root privileges required",
                secondary_text="The installer must be run as root.\n\n"
                               "Use: pkexec /usr/bin/ai-installer",
            )
            dialog.connect("response", lambda d, r: sys.exit(1))
            dialog.present()
            return

        # Check if running from live ISO
        try:
            is_live = os.path.isdir("/run/archiso") or \
                      "archiso" in open("/proc/cmdline").read()
        except (OSError, IOError):
            is_live = os.path.isdir("/run/archiso")
        if not is_live:
            dialog = Gtk.MessageDialog(
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.YES_NO,
                text="Not running from live ISO",
                secondary_text="This installer is designed to run from the "
                               "AI Arch Linux live ISO.\n\n"
                               "Running from an installed system may cause "
                               "data loss. Continue anyway?",
            )
            dialog.connect("response", self._on_live_check_response)
            dialog.present()
            return

        self._build_ui()

    def _on_live_check_response(self, dialog, response):
        dialog.destroy()
        if response == Gtk.ResponseType.YES:
            self._build_ui()
        else:
            self.quit()

    def _build_ui(self):
        self._compact = False
        try:
            display = Gdk.Display.get_default()
            if display:
                mon = display.get_monitors().get_item(0)
                if mon and mon.get_geometry().height <= 900:
                    self._compact = True
        except Exception:
            self._compact = True
        self._page_margin = 16 if self._compact else 32
        self._page_top = 12 if self._compact else 24
        self._spacing = 4 if self._compact else 8

        self.win = Adw.ApplicationWindow(application=self)
        self.win.set_title("Install AI Arch Linux")
        _inst_w = 650 if self._compact else 750
        _inst_h = 500 if self._compact else 600
        self.win.set_default_size(_inst_w, _inst_h)
        self.win.set_resizable(True)

        # Apply custom CSS
        css = Gtk.CssProvider()
        css.load_from_string("""
            .accent-text { color: #7aa2f7; }
            .warning-text { color: #e0af68; }
            .error-text { color: #f7768e; }
            .success-text { color: #9ece6a; }
            .dim-text { color: #565f89; }
            .title-1 { font-size: 28px; font-weight: 300; }
            .title-2 { font-size: 20px; font-weight: 500; }
            .device-row { padding: 12px; border-radius: 8px; }
            .device-row:hover { background-color: alpha(#7aa2f7, 0.1); }
            .device-selected { background-color: alpha(#7aa2f7, 0.15);
                               border: 1px solid alpha(#7aa2f7, 0.4); }
            .recommended-badge { background-color: alpha(#9ece6a, 0.2);
                                 color: #9ece6a; padding: 2px 8px;
                                 border-radius: 4px; font-size: 11px; }
            .log-view { font-family: JetBrains Mono, monospace;
                        font-size: 11px; }
            .step-active { color: #7aa2f7; font-weight: bold; }
            .step-done { color: #9ece6a; }
            .step-pending { color: #565f89; }
        """)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        # Main layout: stack for pages
        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
        self._stack.set_transition_duration(300)

        # Build all pages
        self._stack.add_named(self._make_welcome_page(), "welcome")
        self._stack.add_named(self._make_disk_page(), "disk")
        self._stack.add_named(self._make_partition_page(), "partition")
        self._stack.add_named(self._make_user_page(), "user")
        self._stack.add_named(self._make_install_page(), "install")
        self._stack.add_named(self._make_complete_page(), "complete")

        # Navigation bar at bottom
        nav_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=self._spacing)
        nav_bar.set_halign(Gtk.Align.END)
        nav_bar.set_margin_top(4 if self._compact else 8)
        nav_bar.set_margin_bottom(8 if self._compact else 16)
        nav_bar.set_margin_end(self._page_margin)
        nav_bar.set_margin_start(self._page_margin)

        self._back_btn = Gtk.Button(label="Back")
        self._back_btn.connect("clicked", self._go_back)

        self._next_btn = Gtk.Button(label="Next")
        self._next_btn.add_css_class("suggested-action")
        self._next_btn.connect("clicked", self._go_next)

        self._cancel_btn = Gtk.Button(label="Cancel")
        self._cancel_btn.add_css_class("destructive-action")
        self._cancel_btn.connect("clicked", self._on_cancel)

        nav_bar.append(self._cancel_btn)
        spacer = Gtk.Box()
        spacer.set_hexpand(True)
        nav_bar.append(spacer)
        nav_bar.append(self._back_btn)
        nav_bar.append(self._next_btn)

        # Main vertical layout
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main_box.append(self._stack)
        main_box.append(Gtk.Separator())
        main_box.append(nav_bar)

        self._stack.set_vexpand(True)

        self.win.set_content(main_box)
        self._update_nav_buttons()
        self.win.present()

    # ------------------------------------------------------------------
    # Page names and navigation order
    # ------------------------------------------------------------------
    _pages = ["welcome", "disk", "partition", "user", "install", "complete"]

    def _current_page(self):
        return self._stack.get_visible_child_name()

    def _current_index(self):
        return self._pages.index(self._current_page())

    def _go_back(self, btn):
        idx = self._current_index()
        if idx > 0:
            self._stack.set_visible_child_name(self._pages[idx - 1])
            self._update_nav_buttons()

    def _go_next(self, btn):
        page = self._current_page()
        idx = self._current_index()

        # Validation per page
        if page == "disk":
            if not self._selected_device:
                self._show_toast("Please select a disk to install to.")
                return

        if page == "user":
            if not self._validate_user_inputs():
                return

        if page == "partition":
            # Moving from partition to user page
            pass

        # If we're on the user page and clicking "Install", start installation
        if page == "user":
            self._stack.set_visible_child_name("install")
            self._update_nav_buttons()
            self._start_installation()
            return

        if idx < len(self._pages) - 1:
            next_page = self._pages[idx + 1]
            # Skip install/complete in forward nav (handled by install button)
            if next_page in ("install", "complete"):
                return
            self._stack.set_visible_child_name(next_page)
            self._update_nav_buttons()
            # Refresh disk list when entering disk page
            if next_page == "disk":
                self._refresh_disks()

    def _update_nav_buttons(self):
        page = self._current_page()
        idx = self._current_index()

        self._back_btn.set_visible(idx > 0 and page not in ("install", "complete"))
        self._cancel_btn.set_visible(page not in ("install", "complete"))

        if page == "user":
            self._next_btn.set_label("Install Now")
            self._next_btn.remove_css_class("suggested-action")
            self._next_btn.add_css_class("destructive-action")
            self._next_btn.set_visible(True)
        elif page == "install":
            self._next_btn.set_visible(False)
        elif page == "complete":
            self._next_btn.set_visible(False)
            self._back_btn.set_visible(False)
            self._cancel_btn.set_visible(False)
        else:
            self._next_btn.set_label("Next")
            self._next_btn.remove_css_class("destructive-action")
            self._next_btn.add_css_class("suggested-action")
            self._next_btn.set_visible(True)

    def _show_toast(self, msg):
        """Show a brief notification in the window."""
        # Simple fallback: just log it. The UI pages show errors inline.
        print(f"[installer] {msg}")

    # ------------------------------------------------------------------
    # Page 1: Welcome
    # ------------------------------------------------------------------
    def _make_welcome_page(self):
        _wm = 20 if self._compact else 40
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8 if self._compact else 16)
        page.set_valign(Gtk.Align.CENTER)
        page.set_halign(Gtk.Align.CENTER)
        page.set_margin_top(_wm)
        page.set_margin_bottom(_wm)
        page.set_margin_start(_wm)
        page.set_margin_end(_wm)

        # Icon
        icon = Gtk.Image.new_from_icon_name("ai-installer")
        icon.set_pixel_size(56 if self._compact else 96)
        page.append(icon)

        # Title
        title = Gtk.Label(label="Install AI Arch Linux to Disk")
        title.add_css_class("title-1")
        page.append(title)

        # Subtitle
        subtitle = Gtk.Label(
            label="This wizard will guide you through installing the full\n"
                  "AI Arch Linux operating system to a physical drive."
        )
        subtitle.set_justify(Gtk.Justification.CENTER)
        subtitle.add_css_class("dim-label")
        page.append(subtitle)

        # Feature list
        features_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        features_box.set_margin_top(24)
        features_box.set_halign(Gtk.Align.START)

        features = [
            "Native Windows .exe execution via PE loader",
            "AI-powered system control daemon",
            "37+ Windows DLL compatibility stubs",
            "XFCE desktop with Windows 11 appearance",
            "Full gaming support: Steam, Lutris, DXVK",
            "Biologically-inspired trust kernel module",
        ]
        for feat in features:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            check = Gtk.Label(label="\u2713")
            check.add_css_class("success-text")
            row.append(check)
            row.append(Gtk.Label(label=feat))
            features_box.append(row)

        page.append(features_box)

        # Warning
        warn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
