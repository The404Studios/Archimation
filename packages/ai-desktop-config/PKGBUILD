    # ==========================================================================
    # AI-ASSIST — AI-powered command-line assistant
    # ==========================================================================
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-assist" <<'AIASSIST'
#!/bin/bash
# ai-assist - AI-powered command-line assistant for Linux
# Part of AI Arch Linux. Works offline with built-in pattern matching.

set -uo pipefail

VERSION="3.0.0"
_REAL_HOME="${HOME:-$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f6)}"
_REAL_HOME="${_REAL_HOME:-/root}"
HISTORY_FILE="${_REAL_HOME}/.ai-assist-history"

# Ctrl+C: in interactive mode, cancel current line; in direct mode, exit
INTERACTIVE=0
trap 'echo; if [ "$INTERACTIVE" -eq 1 ]; then ai_say "Interrupted. Type ${C_CYAN}exit${C_RESET} to quit."; else exit 130; fi' INT

# ─── AI Daemon API ──────────────────────────────────────────
_AI_BASE="http://127.0.0.1:8420"
_AI_TOKEN=""
_daemon_alive() { curl -sf --max-time 2 "${_AI_BASE}/health" >/dev/null 2>&1; }
_get_token() {
    [ -n "$_AI_TOKEN" ] && return
    _AI_TOKEN=$(curl -sf --max-time 3 -X POST "${_AI_BASE}/auth/token" \
        -H 'Content-Type: application/json' -d '{"trust_level":100}' 2>/dev/null \
        | sed -n 's/.*"token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p') || true
}
_api_call() {
    local method="$1" path="$2" body="${3:-}"
    _daemon_alive || return 1
    _get_token
    local -a h=(); [ -n "$_AI_TOKEN" ] && h+=(-H "Authorization: Bearer ${_AI_TOKEN}")
    local r
    if [ -n "$body" ]; then
        r=$(curl -sf --max-time 10 -X "$method" "${h[@]}" \
            -H 'Content-Type: application/json' -d "$body" "${_AI_BASE}${path}" 2>/dev/null) || return 1
    else
        r=$(curl -sf --max-time 10 -X "$method" "${h[@]}" "${_AI_BASE}${path}" 2>/dev/null) || return 1
    fi
    echo "$r"
}

# ─── Colors ──────────────────────────────────────────────────
C_RESET='\033[0m'
C_BLUE='\033[1;34m'
C_GREEN='\033[1;32m'
C_RED='\033[1;31m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_DIM='\033[2m'
C_BOLD='\033[1m'
C_MAGENTA='\033[1;35m'
C_WHITE='\033[1;37m'

ai_say()    { echo -e "${C_BLUE}[ai]${C_RESET} $*"; }
ai_cmd()    { echo -e "${C_CYAN}  -> ${C_DIM}$*${C_RESET}"; }
ai_ok()     { echo -e "${C_GREEN}  [OK]${C_RESET} $*"; }
ai_err()    { echo -e "${C_RED}  [!!]${C_RESET} $*"; }
ai_warn()   { echo -e "${C_YELLOW}  [!!]${C_RESET} $*"; }
ai_header() { echo -e "\n${C_BOLD}${C_MAGENTA}=== $* ===${C_RESET}"; }
_check_ok()   { echo -e "  ${C_GREEN}[PASS]${C_RESET} $*"; }
_check_fail() { echo -e "  ${C_RED}[FAIL]${C_RESET} $*"; }
_check_warn() { echo -e "  ${C_YELLOW}[WARN]${C_RESET} $*"; }

# Config file location
_AI_CONFIG="/etc/ai-control/ai-control.toml"
_AI_CONFIG_DEFAULT="/usr/share/ai-control/ai-control.toml.default"
_CORTEX_BASE="http://127.0.0.1:8421"

# ─── Cortex API helper ──────────────────────────────────────
_cortex_call() {
    local method="$1" path="$2" body="${3:-}"
    local r
    if [ -n "$body" ]; then
        r=$(curl -sf --max-time 10 -X "$method" \
            -H 'Content-Type: application/json' -d "$body" "${_CORTEX_BASE}${path}" 2>/dev/null) || return 1
    else
        r=$(curl -sf --max-time 10 -X "$method" "${_CORTEX_BASE}${path}" 2>/dev/null) || return 1
    fi
    echo "$r"
}

# ─── Diagnose command ────────────────────────────────────────
cmd_diagnose() {
    ai_header "AI System Health Check"
    local passes=0 fails=0 warns=0

    # 1. AI Daemon
    echo -e "\n${C_BOLD}  Services${C_RESET}"
    if curl -sf --max-time 3 "${_AI_BASE}/health" >/dev/null 2>&1; then
        _check_ok "AI daemon running at ${_AI_BASE}"
        ((passes++))
    else
        _check_fail "AI daemon not responding at ${_AI_BASE}"
        ((fails++))
    fi

    # 2. Trust kernel module
    if lsmod 2>/dev/null | grep -q '^trust'; then
        _check_ok "Trust kernel module loaded"
        ((passes++))
    else
        _check_fail "Trust kernel module not loaded"
        ((fails++))
    fi

    # 3. PE loader binfmt
    if [ -f /proc/sys/fs/binfmt_misc/PE ] && [ -r /proc/sys/fs/binfmt_misc/PE ]; then
        local pe_status
        pe_status=$(head -1 /proc/sys/fs/binfmt_misc/PE 2>/dev/null)
        if [ "$pe_status" = "enabled" ]; then
            _check_ok "PE loader registered (binfmt_misc: enabled)"
            ((passes++))
        else
            _check_warn "PE loader registered but status: ${pe_status}"
            ((warns++))
        fi
    else
        _check_fail "PE loader not registered in binfmt_misc"
        ((fails++))
    fi

    # 4. SCM daemon
    if systemctl is-active scm-daemon.service &>/dev/null; then
        _check_ok "SCM daemon running"
        ((passes++))
    else
        _check_fail "SCM daemon not running"
        ((fails++))
    fi

    # 5. Cortex
    if _cortex_call GET /health >/dev/null 2>&1; then
        _check_ok "AI Cortex responding"
        ((passes++))
    else
        _check_warn "AI Cortex not responding"
        ((warns++))
    fi

    # System resources
    echo -e "\n${C_BOLD}  Resources${C_RESET}"

    # Disk space
    local root_usage
    root_usage=$(df / 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
    if [ -n "$root_usage" ]; then
        if [ "$root_usage" -lt 80 ]; then
            _check_ok "Disk usage: ${root_usage}% (/ filesystem)"
            ((passes++))
        elif [ "$root_usage" -lt 95 ]; then
            _check_warn "Disk usage: ${root_usage}% (/ filesystem) -- getting full"
            ((warns++))
        else
            _check_fail "Disk usage: ${root_usage}% (/ filesystem) -- critically full!"
            ((fails++))
        fi
    fi

    # Memory
    local mem_pct
    mem_pct=$(free 2>/dev/null | awk '/^Mem:/{printf "%.0f", $3/$2*100}')
    if [ -n "$mem_pct" ]; then
        local mem_used mem_total
        mem_used=$(free -h 2>/dev/null | awk '/^Mem:/{print $3}')
        mem_total=$(free -h 2>/dev/null | awk '/^Mem:/{print $2}')
        if [ "$mem_pct" -lt 85 ]; then
            _check_ok "Memory: ${mem_used} / ${mem_total} (${mem_pct}%)"
            ((passes++))
        elif [ "$mem_pct" -lt 95 ]; then
            _check_warn "Memory: ${mem_used} / ${mem_total} (${mem_pct}%) -- high usage"
            ((warns++))
        else
            _check_fail "Memory: ${mem_used} / ${mem_total} (${mem_pct}%) -- critically low!"
            ((fails++))
        fi
    fi

    # CPU temperature
    if command -v sensors &>/dev/null; then
        local cpu_temp
        cpu_temp=$(sensors 2>/dev/null | grep -oP 'Package.*?\+\K[0-9]+' | head -1)
        if [ -z "$cpu_temp" ]; then
            cpu_temp=$(sensors 2>/dev/null | grep -oP 'Core 0.*?\+\K[0-9]+' | head -1)
        fi
        if [ -n "$cpu_temp" ]; then
            if [ "$cpu_temp" -lt 80 ]; then
                _check_ok "CPU temperature: ${cpu_temp}C"
                ((passes++))
            elif [ "$cpu_temp" -lt 95 ]; then
                _check_warn "CPU temperature: ${cpu_temp}C -- running hot"
                ((warns++))
            else
                _check_fail "CPU temperature: ${cpu_temp}C -- overheating!"
                ((fails++))
            fi
        fi
    else
        echo -e "  ${C_DIM}  CPU temp: lm_sensors not installed${C_RESET}"
    fi

    # Summary
    echo -e "\n${C_BOLD}  Summary${C_RESET}"
    echo -e "  ${C_GREEN}${passes} passed${C_RESET}  ${C_YELLOW}${warns} warnings${C_RESET}  ${C_RED}${fails} failed${C_RESET}"
    if [ "$fails" -eq 0 ] && [ "$warns" -eq 0 ]; then
        echo -e "\n  ${C_GREEN}${C_BOLD}All systems healthy.${C_RESET}"
    elif [ "$fails" -eq 0 ]; then
        echo -e "\n  ${C_YELLOW}${C_BOLD}System operational with warnings.${C_RESET}"
    else
        echo -e "\n  ${C_RED}${C_BOLD}System has failures. Run 'ai logs daemon' for details.${C_RESET}"
    fi
    echo
}

# ─── Config command ──────────────────────────────────────────
cmd_config() {
    local subcmd="${1:-show}"
    shift 2>/dev/null || true

    case "$subcmd" in
        show)
            ai_header "AI Daemon Configuration"
            if [ -f "$_AI_CONFIG" ]; then
                echo -e "  ${C_DIM}File: ${_AI_CONFIG}${C_RESET}\n"
                while IFS= read -r line; do
                    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
                    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
                        echo -e "\n  ${C_BOLD}${C_MAGENTA}[${BASH_REMATCH[1]}]${C_RESET}"
                    elif [[ "$line" =~ ^[[:space:]]*\# ]]; then
                        echo -e "  ${C_DIM}${line}${C_RESET}"
                    elif [[ "$line" =~ ^([^=]+)=(.+)$ ]]; then
                        local ckey cval
                        ckey=$(echo "${BASH_REMATCH[1]}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                        cval=$(echo "${BASH_REMATCH[2]}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                        echo -e "  ${C_CYAN}${ckey}${C_RESET} = ${C_GREEN}${cval}${C_RESET}"
                    fi
                done < "$_AI_CONFIG"
                echo
            else
                ai_err "Config file not found: ${_AI_CONFIG}"
                ai_say "Try: ${C_CYAN}sudo cp /usr/share/ai-control/ai-control.toml.default ${_AI_CONFIG}${C_RESET}"
            fi
            ;;
        set)
            local key="$1" value="$2"
            if [ -z "$key" ] || [ -z "$value" ]; then
                ai_err "Usage: ${C_CYAN}ai config set <key> <value>${C_RESET}"
                ai_say "Example: ${C_CYAN}ai config set logging.level DEBUG${C_RESET}"
                return 1
            fi
            if [ ! -f "$_AI_CONFIG" ]; then
                ai_err "Config file not found: ${_AI_CONFIG}"
                return 1
            fi
            local section="" skey="$key"
            if [[ "$key" == *.* ]]; then
                section="${key%%.*}"
                skey="${key#*.}"
            fi
            local escaped_val
            escaped_val=$(printf '%s' "$value" | sed 's/[&/\]/\\&/g')
            if [ -n "$section" ]; then
                if sudo sed -n "/^\[${section}\]/,/^\[/p" "$_AI_CONFIG" | grep -q "^[[:space:]]*${skey}[[:space:]]*="; then
                    sudo sed -i "/^\[${section}\]/,/^\[/{s|^\([[:space:]]*${skey}[[:space:]]*=[[:space:]]*\).*|\1${escaped_val}|}" "$_AI_CONFIG"
                    ai_ok "Set ${C_CYAN}[${section}] ${skey}${C_RESET} = ${C_GREEN}${value}${C_RESET}"
                    ai_say "Restart daemon to apply: ${C_CYAN}sudo systemctl restart ai-control${C_RESET}"
                else
                    ai_err "Key '${skey}' not found in section [${section}]"
                fi
            else
                if grep -q "^[[:space:]]*${skey}[[:space:]]*=" "$_AI_CONFIG"; then
                    sudo sed -i "s|^\([[:space:]]*${skey}[[:space:]]*=[[:space:]]*\).*|\1${escaped_val}|" "$_AI_CONFIG"
                    ai_ok "Set ${C_CYAN}${skey}${C_RESET} = ${C_GREEN}${value}${C_RESET}"
                    ai_say "Restart daemon to apply: ${C_CYAN}sudo systemctl restart ai-control${C_RESET}"
                else
                    ai_err "Key '${skey}' not found in config"
                fi
            fi
            ;;
        reset)
            ai_warn "This will reset the AI daemon config to defaults."
            echo -ne "${C_YELLOW}  Are you sure? [y/N]: ${C_RESET}"
            read -r ans
            if [[ "$ans" =~ ^[Yy]$ ]]; then
                if [ -f "$_AI_CONFIG_DEFAULT" ]; then
                    sudo cp "$_AI_CONFIG_DEFAULT" "$_AI_CONFIG"
                    ai_ok "Config reset to defaults."
                    ai_say "Restart daemon to apply: ${C_CYAN}sudo systemctl restart ai-control${C_RESET}"
                else
                    ai_err "Default config not found at: ${_AI_CONFIG_DEFAULT}"
                fi
            else
                ai_say "Cancelled."
            fi
            ;;
        --help|-h)
            ai_say "Usage: ${C_CYAN}ai config <subcommand>${C_RESET}"
            echo -e "  ${C_CYAN}show${C_RESET}                  Display current configuration"
            echo -e "  ${C_CYAN}set <key> <value>${C_RESET}     Set a config value (use section.key format)"
            echo -e "  ${C_CYAN}reset${C_RESET}                 Restore default configuration"
            echo -e ""
            echo -e "  Examples:"
            echo -e "    ${C_DIM}ai config show${C_RESET}"
            echo -e "    ${C_DIM}ai config set logging.level DEBUG${C_RESET}"
            echo -e "    ${C_DIM}ai config set server.port 8420${C_RESET}"
            ;;
        *)
            ai_err "Unknown config subcommand: ${subcmd}"
            ai_say "Try: ${C_CYAN}ai config --help${C_RESET}"
            ;;
    esac
}

# ─── Logs command ────────────────────────────────────────────
cmd_logs() {
    local target="${1:-daemon}"
    shift 2>/dev/null || true
    local follow=0
    for arg in "$target" "$@"; do
        [ "$arg" = "-f" ] && follow=1
    done
    [ "$target" = "-f" ] && target="daemon"

    case "$target" in
        daemon)
            ai_say "AI daemon logs:"
            if [ "$follow" -eq 1 ]; then
                ai_cmd "journalctl -u ai-control -f"
                journalctl -u ai-control -f 2>/dev/null || ai_err "Could not read journal for ai-control"
            else
                ai_cmd "journalctl -u ai-control -n 50 --no-pager"
                journalctl -u ai-control -n 50 --no-pager 2>/dev/null || ai_err "Could not read journal for ai-control"
            fi
            ;;
        trust)
            ai_say "Trust kernel module logs:"
            if [ "$follow" -eq 1 ]; then
                ai_cmd "dmesg -w | grep trust"
                dmesg -w 2>/dev/null | grep --line-buffered -i trust || ai_err "Could not follow dmesg"
            else
                ai_cmd "dmesg | grep trust"
                dmesg 2>/dev/null | grep -i trust | tail -50 || ai_err "Could not read dmesg (try with sudo)"
            fi
            ;;
        cortex)
            ai_say "Cortex decision engine logs:"
            if [ "$follow" -eq 1 ]; then
                ai_cmd "journalctl -u ai-cortex -f"
                journalctl -u ai-cortex -f 2>/dev/null || {
                    ai_warn "No journald unit for cortex. Trying log file..."
                    tail -f /var/log/ai-control-daemon/cortex.log 2>/dev/null || ai_err "Cortex logs not found"
                }
            else
                ai_cmd "journalctl -u ai-cortex -n 50 --no-pager"
                journalctl -u ai-cortex -n 50 --no-pager 2>/dev/null || {
                    ai_warn "No journald unit for cortex. Trying log file..."
                    tail -50 /var/log/ai-control-daemon/cortex.log 2>/dev/null || ai_err "Cortex logs not found"
                }
            fi
            ;;
        --help|-h)
            ai_say "Usage: ${C_CYAN}ai logs <target> [-f]${C_RESET}"
            echo -e "  ${C_CYAN}daemon${C_RESET}    AI control daemon logs (default)"
            echo -e "  ${C_CYAN}trust${C_RESET}     Trust kernel module logs (dmesg)"
            echo -e "  ${C_CYAN}cortex${C_RESET}    Cortex decision engine logs"
            echo -e "  ${C_CYAN}-f${C_RESET}        Follow mode (live tail)"
            echo -e ""
            echo -e "  Examples:"
            echo -e "    ${C_DIM}ai logs daemon${C_RESET}"
            echo -e "    ${C_DIM}ai logs trust -f${C_RESET}"
            echo -e "    ${C_DIM}ai logs -f${C_RESET}          (follows daemon by default)"
            ;;
        *)
            ai_err "Unknown log target: ${target}"
            ai_say "Valid targets: ${C_CYAN}daemon${C_RESET}, ${C_CYAN}trust${C_RESET}, ${C_CYAN}cortex${C_RESET}"
            ;;
    esac
}

# ─── Security command ────────────────────────────────────────
cmd_security() {
    local subcmd="${1:-status}"
    shift 2>/dev/null || true

    case "$subcmd" in
        status)
            ai_header "Security Status"

            # Trust system
            echo -e "\n${C_BOLD}  Trust System${C_RESET}"
            if lsmod 2>/dev/null | grep -q '^trust'; then
                _check_ok "Trust kernel module loaded"
            else
                _check_fail "Trust kernel module not loaded"
            fi

            local trust_resp
            if trust_resp=$(_api_call GET /trust/subjects); then
                local subject_count
                subject_count=$(echo "$trust_resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    subjects = data if isinstance(data, list) else data.get('subjects', [])
    print(len(subjects))
except: print('?')
" 2>/dev/null)
                echo -e "  ${C_CYAN}Trust subjects:${C_RESET} ${subject_count:-unknown}"
            fi

            local anomaly_resp
            if anomaly_resp=$(_api_call GET /trust/anomalies); then
                local anomaly_count
                anomaly_count=$(echo "$anomaly_resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    anomalies = data if isinstance(data, list) else data.get('anomalies', [])
    print(len(anomalies))
except: print('?')
" 2>/dev/null)
                if [ "${anomaly_count:-0}" = "0" ]; then
                    _check_ok "No trust anomalies detected"
                else
                    _check_warn "${anomaly_count} trust anomalies detected"
                fi
            fi

            # Auth status
            echo -e "\n${C_BOLD}  Authentication${C_RESET}"
            if [ -f "$_AI_CONFIG" ]; then
                local auth_enabled
                auth_enabled=$(sed -n '/^\[auth\]/,/^\[/{s/^[[:space:]]*enabled[[:space:]]*=[[:space:]]*//p}' "$_AI_CONFIG" 2>/dev/null | tr -d ' "')
                if [ "$auth_enabled" = "true" ]; then
                    _check_ok "Token authentication enabled"
                else
                    _check_warn "Token authentication disabled"
                fi
            fi

            # Firewall
            echo -e "\n${C_BOLD}  Firewall${C_RESET}"
            local fw_resp
            if fw_resp=$(_api_call GET /firewall/status); then
                local fw_active
                fw_active=$(echo "$fw_resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data.get('active', data.get('enabled', 'unknown')))
except: print('unknown')
" 2>/dev/null)
                if [ "$fw_active" = "True" ] || [ "$fw_active" = "true" ]; then
                    _check_ok "Firewall active"
                else
                    _check_warn "Firewall inactive"
                fi
            else
                if command -v nft &>/dev/null && sudo nft list ruleset &>/dev/null 2>&1; then
                    _check_ok "nftables active"
                elif command -v iptables &>/dev/null && sudo iptables -L &>/dev/null 2>&1; then
                    _check_ok "iptables active"
                else
                    _check_warn "No firewall detected"
                fi
            fi

            # Cortex autonomy
            echo -e "\n${C_BOLD}  AI Cortex${C_RESET}"
            local cortex_resp
            if cortex_resp=$(_cortex_call GET /autonomy); then
                echo "$cortex_resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    score = data.get('score', '?')
    ceiling = data.get('ceiling_name', data.get('ceiling', '?'))
    domains = data.get('domains', {})
    print(f'  Score: {score}  Ceiling: {ceiling}')
    if domains:
        for d, v in domains.items():
            level = v if not isinstance(v, dict) else v.get('level', v)
            print(f'    {d}: {level}')
except: pass
" 2>/dev/null
            else
                echo -e "  ${C_DIM}Cortex not responding${C_RESET}"
            fi
            echo
            ;;
        audit)
            ai_header "Recent Audit Entries"
            local resp
            if resp=$(_api_call GET "/audit/recent?count=25"); then
                echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    entries = data if isinstance(data, list) else data.get('entries', data.get('events', []))
    if not entries:
        print('  No recent audit entries.')
    else:
        for e in entries[-25:]:
            ts = str(e.get('timestamp', e.get('time', '')))[:19]
            action = e.get('action', e.get('event', e.get('type', '?')))
            detail = e.get('detail', e.get('message', e.get('description', '')))
            level = e.get('level', 'info')
            color = '\033[32m' if level == 'info' else '\033[33m' if level == 'warning' else '\033[31m'
            print(f'  {ts}  {color}{action}\033[0m  {detail}')
except Exception as ex:
    print(f'  Error parsing audit data: {ex}')
" 2>/dev/null || echo "  $resp"
            else
                ai_warn "Daemon unavailable. Trying audit log file..."
                local audit_log="/var/log/ai-control-daemon/audit.log"
                if [ -f "$audit_log" ]; then
                    tail -25 "$audit_log" | while IFS= read -r aline; do
                        echo "  $aline"
                    done
                else
                    ai_err "No audit data available."
                fi
            fi
            echo
            ;;
        emergency-stop)
            ai_warn "EMERGENCY STOP will drop ALL cortex autonomy domains to OBSERVE (level 0)."
            ai_warn "The AI system will halt all autonomous operations immediately."
            echo -ne "${C_RED}${C_BOLD}  Confirm emergency stop? [yes/NO]: ${C_RESET}"
            read -r ans
            if [ "$ans" = "yes" ]; then
                ai_say "Triggering emergency stop..."
                local resp
                if resp=$(_cortex_call POST /emergency-stop "{}"); then
                    echo -e "  ${C_RED}${C_BOLD}EMERGENCY STOP ACTIVATED${C_RESET}"
                    echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(f'  Score: {data.get(\"score\", \"?\")}  Ceiling: {data.get(\"ceiling\", \"?\")}')
    print(f'  {data.get(\"message\", \"All domains set to OBSERVE\")}')
except: pass
" 2>/dev/null
                    ai_say "Use cortex API to restore autonomy levels when ready."
                else
                    ai_err "Could not reach cortex. Trying daemon fallback..."
                    if _api_call POST /contusion/run '{"command":"systemctl stop ai-cortex"}' >/dev/null 2>&1; then
                        ai_warn "Cortex service stopped as fallback."
                    else
                        ai_err "Emergency stop failed. Manually run: ${C_CYAN}sudo systemctl stop ai-cortex${C_RESET}"
                    fi
                fi
            else
                ai_say "Cancelled. (Must type 'yes' to confirm.)"
            fi
            ;;
        --help|-h)
            ai_say "Usage: ${C_CYAN}ai security <subcommand>${C_RESET}"
            echo -e "  ${C_CYAN}status${C_RESET}           Show trust levels, auth, firewall status (default)"
            echo -e "  ${C_CYAN}audit${C_RESET}            Show recent audit log entries"
            echo -e "  ${C_CYAN}emergency-stop${C_RESET}   Trigger emergency stop (requires confirmation)"
            ;;
        *)
            ai_err "Unknown security subcommand: ${subcmd}"
            ai_say "Try: ${C_CYAN}ai security --help${C_RESET}"
            ;;
    esac
}

# ─── Contusion subcommands ───────────────────────────────────
cmd_contusion() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        search)
            local query="$*"
            if [ -z "$query" ]; then
                ai_err "Usage: ${C_CYAN}ai contusion search <query>${C_RESET}"
                return 1
            fi
            ai_say "Searching command dictionary for: ${C_CYAN}${query}${C_RESET}"
            local resp
            if resp=$(_api_call POST /contusion/dictionary/search "{\"query\":\"${query}\"}"); then
                echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    results = data.get('results', [])
    if not results:
        print('  No matches found.')
    else:
        print(f'  Found {len(results)} match(es):\n')
        for r in results[:20]:
            name = r.get('name', r.get('command', '?'))
            desc = r.get('description', r.get('desc', ''))
            cat = r.get('category', '')
            sec = r.get('security', '')
            line = f'  \033[1;36m{name}\033[0m'
            if cat: line += f'  \033[2m[{cat}]\033[0m'
            if sec: line += f'  \033[33m({sec})\033[0m'
            print(line)
            if desc: print(f'    {desc}')
except Exception as ex:
    print(f'  Error: {ex}')
" 2>/dev/null || echo "  $resp"
            else
                ai_err "Contusion engine unavailable."
            fi
            ;;
        stats)
            ai_say "Contusion dictionary statistics:"
            local resp
            if resp=$(_api_call GET /contusion/dictionary/stats); then
                echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    stats = data.get('stats', data)
    print()
    for k, v in stats.items():
        if isinstance(v, dict):
            print(f'  \033[1m{k}:\033[0m')
            for sk, sv in v.items():
                print(f'    \033[36m{sk}\033[0m: {sv}')
        elif isinstance(v, list):
            print(f'  \033[1m{k}:\033[0m {len(v)} items')
        else:
            print(f'  \033[36m{k}\033[0m: {v}')
except Exception as ex:
    print(f'  Error: {ex}')
" 2>/dev/null || echo "  $resp"
            else
                ai_err "Contusion engine unavailable."
            fi
            ;;
        app)
            local name="$1"
            if [ -z "$name" ]; then
                ai_err "Usage: ${C_CYAN}ai contusion app <name>${C_RESET}"
                return 1
            fi
            ai_say "App profile: ${C_CYAN}${name}${C_RESET}"
            local resp
            if resp=$(_api_call GET "/contusion/dictionary/app/${name}"); then
                echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    app_data = data.get('app', data)
    print()
    for k, v in app_data.items():
        if isinstance(v, list):
            print(f'  \033[1m{k}:\033[0m')
            for item in v:
                print(f'    - {item}')
        elif isinstance(v, dict):
            print(f'  \033[1m{k}:\033[0m')
            for sk, sv in v.items():
                print(f'    \033[36m{sk}\033[0m: {sv}')
        else:
            print(f'  \033[36m{k}\033[0m: {v}')
except Exception as ex:
    print(f'  Error: {ex}')
" 2>/dev/null || echo "  $resp"
            else
                ai_err "App '${name}' not found or Contusion unavailable."
            fi
            ;;
        --help|-h)
            ai_say "Usage: ${C_CYAN}ai contusion <subcommand>${C_RESET}"
            echo -e "  ${C_CYAN}search <query>${C_RESET}   Search command dictionary"
            echo -e "  ${C_CYAN}stats${C_RESET}            Show dictionary statistics"
            echo -e "  ${C_CYAN}app <name>${C_RESET}       Show app profile details"
            ;;
        "")
            ai_err "Missing subcommand."
            ai_say "Try: ${C_CYAN}ai contusion --help${C_RESET}"
            ;;
        *)
            ai_err "Unknown contusion subcommand: ${subcmd}"
            ai_say "Try: ${C_CYAN}ai contusion --help${C_RESET}"
            ;;
    esac
}

# ─── Scan command ───────────────────────────────────────────
cmd_scan() {
    local pid="$1"
    if [ -z "$pid" ]; then
        echo -e "${C_RED}Usage: ai scan <pid>${C_RESET}"
        return 1
    fi
    echo -e "${C_CYAN}[ai]${C_RESET} Scanning PID $pid for patterns..."
    local result
    result=$(_api_call POST "/scanner/scan/$pid")
    if [ $? -eq 0 ]; then
        local count
        count=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('result',{}).get('matches',[])))" 2>/dev/null)
        echo -e "${C_GREEN}  Found ${count:-0} pattern matches${C_RESET}"
        echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for m in d.get('result',{}).get('matches',[])[:20]:
    cat = m.get('category','?')
    desc = m.get('description','?')
    va = m.get('va', 0)
    print(f'  [{cat:12s}] {desc} (VA: {va:#x})')
" 2>/dev/null
    else
        echo -e "${C_RED}  Scan failed${C_RESET}"
    fi
}

# ─── Analyze command ────────────────────────────────────────
cmd_analyze() {
    local pid="$1"
    if [ -z "$pid" ]; then
        echo -e "${C_RED}Usage: ai analyze <pid>${C_RESET}"
        return 1
    fi
    echo -e "${C_CYAN}[ai]${C_RESET} Analyzing PID $pid..."
    local result
    result=$(_api_call POST "/scanner/analyze/$pid")
    if [ $? -eq 0 ]; then
        echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('result', {})
exe = d.get('exe_name', d.get('executable', '?'))
print(f'  Executable: {exe}')

dlls = d.get('required_dlls', [])
if dlls:
    print(f'\n  Required DLLs ({len(dlls)}):')
    for dll in dlls[:20]:
        name = dll if isinstance(dll, str) else dll.get('name', '?')
        status = '' if isinstance(dll, str) else f'  [{dll.get(\"status\", \"\")}]'
        print(f'    {name}{status}')

drivers = d.get('drivers', [])
if drivers:
    print(f'\n  Drivers ({len(drivers)}):')
    for drv in drivers[:10]:
        name = drv if isinstance(drv, str) else drv.get('name', '?')
        print(f'    {name}')

ac = d.get('anti_cheat', d.get('anticheat', {}))
if ac:
    print(f'\n  Anti-Cheat:')
    if isinstance(ac, dict):
        for k, v in ac.items():
            print(f'    {k}: {v}')
    elif isinstance(ac, list):
        for item in ac:
            print(f'    {item}')

drm = d.get('drm', {})
if drm:
    print(f'\n  DRM:')
    if isinstance(drm, dict):
        for k, v in drm.items():
            print(f'    {k}: {v}')
    elif isinstance(drm, list):
        for item in drm:
            print(f'    {item}')

summary = d.get('summary', d.get('notes', ''))
if summary:
    print(f'\n  Summary: {summary}')
" 2>/dev/null || echo "  $result"
    else
        echo -e "${C_RED}  Analysis failed. Is the daemon running?${C_RESET}"
    fi
}

# ─── Discover command ───────────────────────────────────────
cmd_discover() {
    case "$1" in
        priority)
            echo -e "${C_CYAN}[ai]${C_RESET} Implementation priority list:"
            _api_call GET "/discovery/priority" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for i, item in enumerate(d.get('result',[])[:25], 1):
    pri = item.get('priority','?')
    dll = item.get('dll','?')
    func = item.get('function','?')
    count = item.get('call_count',0)
    procs = ', '.join(item.get('processes',[]))
    color = '\033[91m' if pri == 'critical' else '\033[93m' if pri == 'high' else '\033[0m'
    print(f'  {color}{i:2d}. [{pri:8s}] {dll}!{func} (called {count}x by: {procs})\033[0m')
" 2>/dev/null
            ;;
        "")
            echo -e "${C_RED}Usage: ai discover <pid> | ai discover priority${C_RESET}"
            ;;
        *)
            echo -e "${C_CYAN}[ai]${C_RESET} Discovering stubs for PID $1..."
            _api_call POST "/discovery/analyze/$1" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('result',{})
print(f'  Executable: {d.get(\"exe_name\",\"?\")}')
print(f'  Total imports: {d.get(\"total_imports\",0)}')
print(f'  Resolved: {d.get(\"resolved_imports\",0)}')
print(f'  Stubbed: {d.get(\"stubbed_imports\",0)}')
print()
for r in d.get('recommendations',[])[:15]:
    print(f'  [{r[\"priority\"]:8s}] {r[\"dll\"]}!{r[\"function\"]} ({r[\"call_count\"]}x)')
" 2>/dev/null
            ;;
    esac
}

# ─── Memory command ─────────────────────────────────────────
cmd_memory() {
    local pid="$1"
    if [ -z "$pid" ]; then
        echo -e "${C_CYAN}[ai]${C_RESET} Tracked PE processes:"
        _api_call GET "/memory/processes" | python3 -c "
import sys, json
for p in json.load(sys.stdin).get('result',[]):
    print(f'  PID {p[\"pid\"]:6d}  {p[\"exe\"]:20s}  {p[\"regions\"]} regions  {p[\"dlls\"]} DLLs  {p[\"anomalies\"]} anomalies')
" 2>/dev/null
        return
    fi
    echo -e "${C_CYAN}[ai]${C_RESET} Memory map for PID $pid:"
    _api_call GET "/memory/process/$pid/dlls" | python3 -c "
import sys, json
for dll, info in json.load(sys.stdin).get('result',{}).get('dlls',{}).items():
    print(f'  {dll:30s}  base={info.get(\"base\",0):#x}  sections={info.get(\"sections\",[])}')
" 2>/dev/null
}

# ─── Safety check ────────────────────────────────────────────
DANGEROUS_PATTERNS='rm -rf /|rm -rf /\*|mkfs\.|dd if=|:\(\)\{|chmod -R 777 /|> /dev/sd'

confirm_dangerous() {
    local cmd="$1"
    if echo "$cmd" | grep -qE "$DANGEROUS_PATTERNS"; then
        ai_warn "This command could be dangerous:"
        ai_cmd "$cmd"
        echo -ne "${C_YELLOW}  Are you sure? [y/N]: ${C_RESET}"
        read -r ans
        [[ "$ans" =~ ^[Yy]$ ]] && return 0 || return 1
    fi
    return 0
}

# ─── Execute with learning mode ──────────────────────────────
run_cmd() {
    local cmd="$1"
    local desc="${2:-}"
    [ -n "$desc" ] && ai_say "$desc"
    ai_cmd "$cmd"
    if confirm_dangerous "$cmd"; then
        echo "$cmd" >> "$HISTORY_FILE" 2>/dev/null || true
        eval "$cmd"
        local rc=$?
        if [ $rc -eq 0 ]; then
            ai_ok "Done."
        else
            ai_err "Command exited with code $rc."
        fi
        return $rc
    else
        ai_say "Cancelled."
        return 1
    fi
}

# ─── Built-in skill router ──────────────────────────────────
process_input() {
    local input="$1"
    # Normalize: lowercase, trim
    local q
    q=$(echo "$input" | tr '[:upper:]' '[:lower:]' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    # Empty input
    [ -z "$q" ] && return 0

    # Exit commands
    case "$q" in
        exit|quit|bye|q) echo; ai_say "Goodbye!"; exit 0 ;;
        help|"?")
            echo -e "\n${C_BOLD}${C_MAGENTA}  AI Assist v${VERSION}${C_RESET} - AI-powered command-line assistant"
            echo -e "  ${C_DIM}Part of AI Arch Linux. Type a command or ask in plain English.${C_RESET}"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Automation & Apps${C_RESET}"
            echo -e "  ${C_CYAN}automate \"desc\"${C_RESET}       Send a natural-language task to Contusion"
            echo -e "  ${C_CYAN}macro${C_RESET} record|play|list|stop   Macro recording and playback"
            echo -e "  ${C_CYAN}launch <app>${C_RESET}          Launch an app from the Contusion library"
            echo -e "  ${C_CYAN}apps${C_RESET}                  List available apps"
            echo -e "  ${C_CYAN}processes${C_RESET}             Show running processes with CPU/MEM"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Diagnostics & Monitoring${C_RESET}"
            echo -e "  ${C_CYAN}diagnose${C_RESET}              Run full system health check"
            echo -e "  ${C_CYAN}status${C_RESET}                AI daemon + service status"
            echo -e "  ${C_CYAN}logs${C_RESET} daemon|trust|cortex [-f]  View system logs"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Configuration${C_RESET}"
            echo -e "  ${C_CYAN}config${C_RESET} show|set|reset  View/modify daemon configuration"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Security & Trust${C_RESET}"
            echo -e "  ${C_CYAN}security status${C_RESET}       Trust levels, auth, firewall status"
            echo -e "  ${C_CYAN}security audit${C_RESET}        Recent audit log entries"
            echo -e "  ${C_CYAN}security emergency-stop${C_RESET}  Halt all AI autonomy"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Contusion Engine${C_RESET}"
            echo -e "  ${C_CYAN}contusion search <q>${C_RESET}  Search command dictionary"
            echo -e "  ${C_CYAN}contusion stats${C_RESET}       Dictionary statistics"
            echo -e "  ${C_CYAN}contusion app <name>${C_RESET}  App profile details"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  PE Analysis${C_RESET}"
            echo -e "  ${C_CYAN}scan <pid>${C_RESET}            Scan PE process for patterns"
            echo -e "  ${C_CYAN}analyze <pid>${C_RESET}         High-level PE process analysis"
            echo -e "  ${C_CYAN}discover <pid>${C_RESET}        Stub discovery for PE process"
            echo -e "  ${C_CYAN}discover priority${C_RESET}     Implementation priority list"
            echo -e "  ${C_CYAN}memory [pid]${C_RESET}          Memory map viewer / list PE processes"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Packages & System${C_RESET}"
            echo -e "  ${C_CYAN}install/remove X${C_RESET}     Package management"
            echo -e "  ${C_CYAN}update system${C_RESET}         Full system upgrade"
            echo -e "  ${C_CYAN}update check${C_RESET}          Check for available updates"
            echo -e "  ${C_CYAN}update list${C_RESET}           List available updates"
            echo -e "  ${C_CYAN}update install${C_RESET}        Install all updates (pacman -Syu)"
            echo -e "  ${C_CYAN}search for X${C_RESET}          Search packages"
            echo -e "  ${C_CYAN}disk space${C_RESET}            Storage info"
            echo -e "  ${C_CYAN}memory${C_RESET}                RAM usage"
            echo -e "  ${C_CYAN}system info${C_RESET}           System overview"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Files / Network / Git${C_RESET}"
            echo -e "  ${C_CYAN}find files named X${C_RESET}    Search for files"
            echo -e "  ${C_CYAN}my ip${C_RESET}                 Show IP address"
            echo -e "  ${C_CYAN}ping X${C_RESET}                Connectivity test"
            echo -e "  ${C_CYAN}clone/commit/push${C_RESET}     Git operations"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Services${C_RESET}"
            echo -e "  ${C_CYAN}start/stop/restart X${C_RESET}  Manage systemd services"
            echo -e ""
            echo -e "${C_BOLD}${C_GREEN}  Other${C_RESET}"
            echo -e "  ${C_CYAN}how do I X${C_RESET}            Get help on a topic"
            echo -e "  ${C_CYAN}!command${C_RESET}              Run any command directly"
            echo -e "  ${C_CYAN}version${C_RESET} / ${C_CYAN}history${C_RESET} / ${C_CYAN}clear${C_RESET} / ${C_CYAN}exit${C_RESET}"
            echo -e ""
            echo -e "  ${C_DIM}Tip: Most commands support --help for detailed usage.${C_RESET}"
            return 0 ;;
        version) ai_say "ai-assist v${VERSION}"; return 0 ;;
        status)
            ai_say "AI Daemon Status:"
            if resp=$(_api_call GET /health); then
                ai_ok "Daemon running at ${_AI_BASE}"
                echo "  $resp"
                if info=$(_api_call GET /system/info); then
                    ai_say "System info:"
                    echo "  $info"
                fi
            else
                ai_err "Daemon is not running."
            fi
            ai_say "Systemd services:"
            systemctl is-active ai-control.service 2>/dev/null | \
                sed "s/^active$/  ai-control: \e[32mactive\e[0m/;s/^inactive$/  ai-control: \e[31minactive\e[0m/" | \
                while IFS= read -r l; do echo -e "$l"; done
            systemctl is-active sshd.service 2>/dev/null | \
                sed "s/^active$/  sshd:       \e[32mactive\e[0m/;s/^inactive$/  sshd:       \e[31minactive\e[0m/" | \
                while IFS= read -r l; do echo -e "$l"; done
            ai_say "System overview:"
            echo "  $(uname -r) | $(uptime -p 2>/dev/null || uptime)"
            free -h 2>/dev/null | awk '/^Mem:/{printf "  RAM: %s used / %s total\n", $3, $2}'
            return 0 ;;
        history)
            if [ -f "$HISTORY_FILE" ]; then
                ai_say "Recent commands:"
                tail -20 "$HISTORY_FILE" | nl
            else
                ai_say "No history yet."
            fi
            return 0 ;;
        clear) clear; return 0 ;;
    esac

    # ── New structured commands (diagnose, config, logs, security, contusion) ──
    if [[ "$q" =~ ^diagnose([[:space:]]+--help)?$ ]]; then
        if [[ "$q" == *"--help"* ]]; then
            ai_say "Usage: ${C_CYAN}ai diagnose${C_RESET}"
            echo -e "  Run a comprehensive health check of all AI system components."
            echo -e "  Checks: daemon, trust module, PE loader, SCM, cortex, disk, memory, CPU temp."
        else
            cmd_diagnose
        fi
        return 0
    fi
    if [[ "$q" =~ ^config([[:space:]]+(.*))?$ ]]; then
        local args="${BASH_REMATCH[2]:-show}"
        # shellcheck disable=SC2086
        cmd_config $args
        return 0
    fi
    if [[ "$q" =~ ^logs([[:space:]]+(.*))?$ ]]; then
        local args="${BASH_REMATCH[2]:-daemon}"
        # shellcheck disable=SC2086
        cmd_logs $args
        return 0
    fi
    if [[ "$q" =~ ^security([[:space:]]+(.*))?$ ]]; then
        local args="${BASH_REMATCH[2]:-status}"
        # shellcheck disable=SC2086
        cmd_security $args
        return 0
    fi
    if [[ "$q" =~ ^contusion([[:space:]]+(.*))?$ ]]; then
        local args="${BASH_REMATCH[2]:-}"
        # shellcheck disable=SC2086
        cmd_contusion $args
        return 0
    fi

    # ── PE analysis commands (scan, analyze, discover, memory) ──
    if [[ "$q" =~ ^scan([[:space:]]+(.*))?$ ]]; then
        cmd_scan "${BASH_REMATCH[2]:-}"
        return 0
    fi
    if [[ "$q" =~ ^analyze([[:space:]]+(.*))?$ ]]; then
        cmd_analyze "${BASH_REMATCH[2]:-}"
        return 0
    fi
    if [[ "$q" =~ ^discover([[:space:]]+(.*))?$ ]]; then
        cmd_discover "${BASH_REMATCH[2]:-}"
        return 0
    fi
    if [[ "$q" =~ ^memory[[:space:]]+(.+)$ ]]; then
        local marg="${BASH_REMATCH[1]}"
        # "memory map" or "memory <pid>" -> PE memory viewer; bare "memory" -> RAM usage (below)
        if [[ "$marg" =~ ^[0-9]+$ ]] || [[ "$marg" == "map" ]] || [[ "$marg" == "processes" ]]; then
            [[ "$marg" == "map" || "$marg" == "processes" ]] && marg=""
            cmd_memory "$marg"
            return 0
        fi
    fi

    # ── Question → route through process_input ─────────────────
    if [[ "$q" =~ ^question[[:space:]]+[\"\']?(.+?)[\"\']?$ ]]; then
        local body="${BASH_REMATCH[1]}"
        # Strip quotes, then try the body directly (handles "question disk space")
        # If that doesn't match a skill, the how-to fallback in the later handler catches it
        process_input "$body"
        return $?
    fi

    # ── Package management (API-first, fallback to direct) ──
    if [[ "$q" =~ ^install[[:space:]]+(.+) ]]; then
        local pkg="${BASH_REMATCH[1]}"
        if resp=$(_api_call POST /auto/package "{\"action\":\"install\",\"package\":\"${pkg}\"}"); then
            ai_say "Installing via AI daemon (audited): $pkg"
            echo "  $resp"
            ai_ok "Done."
        else
            run_cmd "sudo pacman -S $pkg" "Installing package: $pkg"
        fi
        return 0
    fi
    if [[ "$q" =~ ^remove[[:space:]]+(.+) ]] || [[ "$q" =~ ^uninstall[[:space:]]+(.+) ]]; then
        local pkg="${BASH_REMATCH[1]}"
        if resp=$(_api_call POST /auto/package "{\"action\":\"remove\",\"package\":\"${pkg}\"}"); then
            ai_say "Removing via AI daemon (audited): $pkg"
            echo "  $resp"
            ai_ok "Done."
        else
            run_cmd "sudo pacman -Rns $pkg" "Removing package: $pkg"
        fi
        return 0
    fi
    if [[ "$q" =~ ^update[[:space:]]+check$ ]]; then
        ai_say "Checking for available updates..."
        if resp=$(_api_call GET /system/updates); then
            local cnt
            cnt=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null)
            if [ "$cnt" -gt 0 ]; then
                ai_warn "$cnt package update(s) available."
                echo "$resp" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for u in data.get('updates', [])[:15]:
    pkg = u.get('package', '?')
    cur = u.get('current', '?')
    new = u.get('new', '?')
    print('  {:<30} {} -> {}'.format(pkg, cur, new))
remaining = data.get('count', 0) - 15
if remaining > 0:
    print('  ... and {} more'.format(remaining))
" 2>/dev/null
            else
                ai_ok "System is up to date."
            fi
        else
            local updates
            updates=$(checkupdates 2>/dev/null)
            if [ -n "$updates" ]; then
                local cnt
                cnt=$(echo "$updates" | wc -l)
                ai_warn "$cnt package update(s) available:"
                echo "$updates" | head -15 | sed 's/^/  /'
                [ "$cnt" -gt 15 ] && ai_say "... and $((cnt - 15)) more"
            else
                ai_ok "System is up to date."
            fi
        fi
        return 0
    fi
    if [[ "$q" =~ ^update[[:space:]]+list$ ]]; then
        ai_say "Listing available updates..."
        local updates
        updates=$(checkupdates 2>/dev/null)
        if [ -n "$updates" ]; then
            local cnt
            cnt=$(echo "$updates" | wc -l)
            ai_say "$cnt package update(s) available:"
            echo "$updates" | sed 's/^/  /'
        else
            ai_ok "System is up to date."
        fi
        return 0
    fi
    if [[ "$q" =~ ^update[[:space:]]+install$ ]]; then
        ai_say "Installing all available updates..."
        if resp=$(_api_call POST /auto/package "{\"action\":\"update\"}"); then
            ai_say "Updating via AI daemon (audited)"
            echo "  $resp"
            ai_ok "Done."
        else
            run_cmd "sudo pacman -Syu" "Updating system packages"
        fi
        return 0
    fi
    if [[ "$q" =~ ^(update|upgrade)[[:space:]]*(system|everything|all|packages)?$ ]]; then
        if resp=$(_api_call POST /auto/package "{\"action\":\"update\"}"); then
            ai_say "Updating via AI daemon (audited)"
            echo "  $resp"
            ai_ok "Done."
        else
            run_cmd "sudo pacman -Syu" "Updating system packages"
        fi
        return 0
    fi
    if [[ "$q" =~ ^search[[:space:]]+(for[[:space:]]+)?(.+) ]]; then
        local term="${BASH_REMATCH[2]}"
        run_cmd "pacman -Ss $term" "Searching packages for: $term"
        return 0
    fi
    if [[ "$q" =~ ^(what is|info on|package info)[[:space:]]+(.+) ]]; then
        local pkg="${BASH_REMATCH[2]}"
        run_cmd "pacman -Qi $pkg 2>/dev/null || pacman -Si $pkg" "Package info: $pkg"
        return 0
    fi
    if [[ "$q" =~ ^(list installed|installed packages)$ ]]; then
        run_cmd "pacman -Qe | column" "Listing explicitly installed packages"
        return 0
    fi
    if [[ "$q" =~ ^(clean|cleanup)[[:space:]]*(cache|packages)?$ ]]; then
        run_cmd "sudo pacman -Sc && sudo paccache -rk1 2>/dev/null || true" "Cleaning package cache"
        return 0
    fi

    # ── System info ──────────────────────────────────────────
    if [[ "$q" =~ ^(disk[[:space:]]*space|disk[[:space:]]*usage|storage|df)$ ]]; then
        run_cmd "df -h --type=ext4 --type=btrfs --type=xfs --type=vfat --type=ntfs 2>/dev/null || df -h" "Disk usage"
        return 0
    fi
    if [[ "$q" =~ ^(memory|ram|memory[[:space:]]*usage|free)$ ]]; then
        run_cmd "free -h" "Memory usage"
        return 0
    fi
    if [[ "$q" =~ ^(processes|what.*processes|top|htop|running)$ ]]; then
        local resp
        if resp=$(_api_call GET /contusion/processes); then
            ai_say "Running processes (via Contusion):"
            echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    procs = data.get('processes', data) if isinstance(data, dict) else data
    if isinstance(procs, list):
        print(f'  {\"PID\":<8}{\"NAME\":<25}{\"CPU%\":<8}{\"MEM%\":<8}')
        print(f'  {\"---\":<8}{\"----\":<25}{\"----\":<8}{\"----\":<8}')
        for p in procs[:30]:
            print(f'  {str(p.get(\"pid\",\"\")):<8}{str(p.get(\"name\",\"\")):<25}{str(p.get(\"cpu\",\"\")):<8}{str(p.get(\"mem\",\"\")):<8}')
    else:
        print(f'  {data}')
except: print(sys.stdin.read() if hasattr(sys.stdin, 'read') else str(data))
" 2>/dev/null || echo "  $resp"
        else
            run_cmd "ps aux --sort=-%cpu | head -20" "Top 20 processes by CPU"
        fi
        return 0
    fi
    if [[ "$q" =~ ^(system[[:space:]]*info|sysinfo|neofetch|fastfetch|about)$ ]]; then
        if command -v fastfetch &>/dev/null; then
            run_cmd "fastfetch" "System information"
        else
            run_cmd "uname -a && echo && cat /etc/os-release" "System information"
        fi
        return 0
    fi
    if [[ "$q" =~ ^(uptime|how long)$ ]]; then
        run_cmd "uptime -p" "System uptime"
        return 0
    fi
    if [[ "$q" =~ ^(cpu|cpu[[:space:]]*info|processor)$ ]]; then
        run_cmd "lscpu | head -20" "CPU information"
        return 0
    fi
    if [[ "$q" =~ ^(gpu|graphics|video[[:space:]]*card)$ ]]; then
        run_cmd "lspci | grep -i 'vga\|3d\|display'" "GPU information"
        return 0
    fi
    if [[ "$q" =~ ^(temperature|temps|sensors)$ ]]; then
        run_cmd "sensors 2>/dev/null || echo 'Install lm_sensors: sudo pacman -S lm_sensors'" "System temperatures"
        return 0
    fi
    if [[ "$q" =~ ^(battery|power)$ ]]; then
        run_cmd "upower -i /org/freedesktop/UPower/devices/battery_BAT0 2>/dev/null || echo 'No battery detected'" "Battery status"
        return 0
    fi

    # ── File operations ──────────────────────────────────────
    if [[ "$q" =~ ^find[[:space:]]+(files?[[:space:]]+)?(named|called)[[:space:]]+(.+) ]]; then
        local name="${BASH_REMATCH[3]}"
        run_cmd "find . -maxdepth 5 -name '*${name}*' 2>/dev/null | head -30" "Finding files matching: $name"
        return 0
    fi
    if [[ "$q" =~ ^(largest|biggest)[[:space:]]*files?$ ]]; then
        run_cmd "du -ah . 2>/dev/null | sort -rh | head -20" "Largest files in current directory"
        return 0
    fi
    if [[ "$q" =~ ^compress[[:space:]]+(.+) ]]; then
        local target="${BASH_REMATCH[1]}"
        run_cmd "tar czf '${target}.tar.gz' '${target}'" "Compressing: $target"
        return 0
    fi
    if [[ "$q" =~ ^extract[[:space:]]+(.+) ]]; then
        local archive="${BASH_REMATCH[1]}"
        if [[ "$archive" == *.zip ]]; then
            run_cmd "unzip '${archive}'" "Extracting: $archive"
        elif [[ "$archive" == *.tar.gz || "$archive" == *.tgz ]]; then
            run_cmd "tar xzf '${archive}'" "Extracting: $archive"
        elif [[ "$archive" == *.tar.bz2 ]]; then
            run_cmd "tar xjf '${archive}'" "Extracting: $archive"
        elif [[ "$archive" == *.tar.xz ]]; then
            run_cmd "tar xJf '${archive}'" "Extracting: $archive"
        elif [[ "$archive" == *.tar.zst ]]; then
            run_cmd "tar --zstd -xf '${archive}'" "Extracting: $archive"
        elif [[ "$archive" == *.7z ]]; then
            run_cmd "7z x '${archive}'" "Extracting: $archive"
        else
            run_cmd "tar xf '${archive}'" "Extracting: $archive"
        fi
        return 0
    fi
    if [[ "$q" =~ ^(file[[:space:]]*size|size[[:space:]]*of)[[:space:]]+(.+) ]]; then
        local target="${BASH_REMATCH[2]}"
        run_cmd "du -sh '${target}'" "Size of: $target"
        return 0
    fi

    # ── Network ──────────────────────────────────────────────
    if [[ "$q" =~ ^(show[[:space:]]*)?wifi[[:space:]]*(networks|scan)?$ ]] || [[ "$q" =~ ^scan[[:space:]]*wifi$ ]]; then
        run_cmd "nmcli dev wifi list" "Available WiFi networks"
        return 0
    fi
    if [[ "$q" =~ ^connect[[:space:]]*(to[[:space:]]*)?wifi[[:space:]]+(.+) ]]; then
        local ssid="${BASH_REMATCH[2]}"
        run_cmd "nmcli dev wifi connect '${ssid}'" "Connecting to WiFi: $ssid"
        return 0
    fi
    if [[ "$q" =~ ^(my[[:space:]]*ip|ip[[:space:]]*address|what.*my.*ip)$ ]]; then
        ai_say "Local and public IP addresses:"
        ai_cmd "ip -4 addr show scope global | grep inet"
        ip -4 addr show scope global 2>/dev/null | grep inet || true
        ai_cmd "curl -s ifconfig.me"
        curl -s --max-time 5 ifconfig.me 2>/dev/null && echo || ai_warn "Could not reach ifconfig.me"
        return 0
    fi
    if [[ "$q" =~ ^ping[[:space:]]+(.+) ]]; then
        local host="${BASH_REMATCH[1]}"
        run_cmd "ping -c 4 '${host}'" "Pinging: $host"
        return 0
    fi
    if [[ "$q" =~ ^(ports|open[[:space:]]*ports|listening)$ ]]; then
        run_cmd "ss -tlnp" "Listening ports"
        return 0
    fi
    if [[ "$q" =~ ^(speedtest|speed[[:space:]]*test|bandwidth)$ ]]; then
        if command -v speedtest-cli &>/dev/null; then
            run_cmd "speedtest-cli --simple" "Running speed test"
        else
            ai_say "speedtest-cli not installed."
            run_cmd "sudo pacman -S speedtest-cli" "Installing speedtest-cli"
        fi
        return 0
    fi
    if [[ "$q" =~ ^(dns|resolve|nslookup)[[:space:]]+(.+) ]]; then
        local domain="${BASH_REMATCH[2]}"
        run_cmd "dig +short '${domain}'" "DNS lookup: $domain"
        return 0
    fi

    # ── Git ──────────────────────────────────────────────────
    if [[ "$q" =~ ^(create|init)[[:space:]]*(a[[:space:]]*)?repo$ ]]; then
        run_cmd "git init" "Initializing git repository"
        return 0
    fi
    if [[ "$q" =~ ^clone[[:space:]]+(.+) ]]; then
        local repo="${BASH_REMATCH[1]}"
        run_cmd "git clone '${repo}'" "Cloning repository"
        return 0
    fi
    if [[ "$q" =~ ^commit[[:space:]]*(changes|all)?$ ]]; then
        ai_say "Staging all changes and committing."
        echo -ne "${C_CYAN}  Commit message: ${C_RESET}"
        read -r msg
        [ -z "$msg" ] && msg="Update $(date +%Y-%m-%d)"
        run_cmd "git add -A && git commit -m '${msg}'" "Committing changes"
        return 0
    fi
    if [[ "$q" =~ ^push$ ]]; then
        run_cmd "git push" "Pushing to remote"
        return 0
    fi
    if [[ "$q" =~ ^pull$ ]]; then
        run_cmd "git pull" "Pulling from remote"
        return 0
    fi
    if [[ "$q" =~ ^(git[[:space:]]*)?status$ ]]; then
        run_cmd "git status" "Git status"
        return 0
    fi
    if [[ "$q" =~ ^(git[[:space:]]*)?log$ ]]; then
        run_cmd "git log --oneline -20" "Recent commits"
        return 0
    fi
    if [[ "$q" =~ ^(git[[:space:]]*)?diff$ ]]; then
        run_cmd "git diff" "Showing changes"
        return 0
    fi
    if [[ "$q" =~ ^(git[[:space:]]*)?stash$ ]]; then
        run_cmd "git stash" "Stashing changes"
        return 0
    fi

    # ── User management ──────────────────────────────────────
    if [[ "$q" =~ ^add[[:space:]]*user[[:space:]]+(.+) ]]; then
        local user="${BASH_REMATCH[1]}"
        run_cmd "sudo useradd -m -G wheel -s /bin/bash '${user}' && sudo passwd '${user}'" "Creating user: $user"
        return 0
    fi
    if [[ "$q" =~ ^change[[:space:]]*password$ ]]; then
        run_cmd "passwd" "Changing your password"
        return 0
    fi
    if [[ "$q" =~ ^(who|who is logged in|users)$ ]]; then
        run_cmd "who" "Logged-in users"
        return 0
    fi
    if [[ "$q" =~ ^(groups|my groups)$ ]]; then
        run_cmd "groups" "Your groups"
        return 0
    fi

    # ── Service management ───────────────────────────────────
    if [[ "$q" =~ ^(start|stop|restart|enable|disable)[[:space:]]+(.+?)[[:space:]]*(service)?$ ]]; then
        local action="${BASH_REMATCH[1]}"
        local svc="${BASH_REMATCH[2]}"
        svc="${svc% service}"
        svc="${svc% }"
        run_cmd "sudo systemctl ${action} '${svc}'" "${action^}ing service: $svc"
        return 0
    fi
    if [[ "$q" =~ ^status[[:space:]]+of[[:space:]]+(.+?)[[:space:]]*(service)?$ ]] || [[ "$q" =~ ^(.+?)[[:space:]]+status$ ]]; then
        local svc="${BASH_REMATCH[1]}"
        svc="${svc% service}"
        svc="${svc% }"
        run_cmd "systemctl status '${svc}'" "Status of service: $svc"
        return 0
    fi
    if [[ "$q" =~ ^(list[[:space:]]*)?services$ ]]; then
        run_cmd "systemctl list-units --type=service --state=running" "Running services"
        return 0
    fi
    if [[ "$q" =~ ^(failed|failed services)$ ]]; then
        run_cmd "systemctl --failed" "Failed services"
        return 0
    fi

    # ── Contusion Engine: automate ────────────────────────────
    if [[ "$q" =~ ^automate[[:space:]]+[\"\']?(.+?)[\"\']?$ ]]; then
        local desc="${BASH_REMATCH[1]}"
        ai_say "Sending to Contusion engine..."
        local resp
        if resp=$(_api_call POST /contusion/context "{\"description\":\"${desc}\"}"); then
            # Show pipeline steps
            local steps
            steps=$(echo "$resp" | sed -n 's/.*"steps"[[:space:]]*:[[:space:]]*\(\[.*\]\).*/\1/p')
            if [ -n "$steps" ]; then
                ai_say "Pipeline steps:"
                echo "$steps" | tr ',' '\n' | sed 's/[]"[]//g; s/^/    /'
            else
                echo "  $resp"
            fi
            # Check for dangerous flag
            local dangerous
            dangerous=$(echo "$resp" | sed -n 's/.*"dangerous"[[:space:]]*:[[:space:]]*\(true\).*/\1/p')
            if [ "$dangerous" = "true" ]; then
                ai_warn "This automation involves potentially dangerous actions."
                echo -ne "${C_YELLOW}  Proceed? [y/N]: ${C_RESET}"
                read -r ans
                if [[ ! "$ans" =~ ^[Yy]$ ]]; then
                    ai_say "Cancelled."
                    return 0
                fi
            fi
            # Execute
            local exec_resp
            if exec_resp=$(_api_call POST /contusion/execute "{\"description\":\"${desc}\"}"); then
                ai_ok "Automation complete."
                echo "  $exec_resp"
            else
                ai_err "Execution failed."
            fi
        else
            ai_err "Contusion engine unavailable. Is the AI daemon running?"
            ai_say "Try: ${C_CYAN}status${C_RESET} to check daemon health."
        fi
        return 0
    fi

    # ── Contusion Engine: macro ──────────────────────────────
    if [[ "$q" =~ ^macro[[:space:]]+record[[:space:]]+(.+) ]]; then
        local name="${BASH_REMATCH[1]}"
        ai_say "Starting macro recording: ${C_CYAN}${name}${C_RESET}"
        local resp
        if resp=$(_api_call POST /contusion/macro/record "{\"name\":\"${name}\"}"); then
            ai_ok "Recording started. Perform actions, then run: ${C_CYAN}macro stop${C_RESET}"
            echo "  $resp"
        else
            ai_err "Failed to start recording. Daemon may be down."
        fi
        return 0
    fi
    if [[ "$q" =~ ^macro[[:space:]]+stop$ ]]; then
        local resp
        if resp=$(_api_call POST /contusion/macro/stop "{}"); then
            ai_ok "Macro recording saved."
            echo "  $resp"
        else
            ai_err "Failed to stop recording."
        fi
        return 0
    fi
    if [[ "$q" =~ ^macro[[:space:]]+play[[:space:]]+(.+) ]]; then
        local name="${BASH_REMATCH[1]}"
        ai_say "Playing macro: ${C_CYAN}${name}${C_RESET}"
        local resp
        if resp=$(_api_call POST /contusion/macro/play "{\"name\":\"${name}\"}"); then
            ai_ok "Macro playback complete."
            echo "  $resp"
        else
            ai_err "Failed to play macro '${name}'. Check: ${C_CYAN}macro list${C_RESET}"
        fi
        return 0
    fi
    if [[ "$q" =~ ^macro[[:space:]]+list$ ]]; then
        ai_say "Saved macros:"
        local resp
        if resp=$(_api_call GET /contusion/macro/list); then
            echo "$resp" | sed -n 's/.*"macros"[[:space:]]*:[[:space:]]*\(\[.*\]\).*/\1/p' \
                | tr ',' '\n' | sed 's/[]"[]//g; s/^/    /' | grep -v '^[[:space:]]*$'
            [ -z "$(echo "$resp" | grep '"macros"')" ] && echo "  $resp"
        else
            ai_err "Could not retrieve macros. Daemon may be down."
        fi
        return 0
    fi

    # ── Contusion Engine: workflows ─────────────────────────
    if [[ "$q" =~ ^workflow[[:space:]]+list$ ]]; then
        local resp
        if resp=$(_api_call GET /contusion/workflows); then
            ai_say "Available workflows:"
            echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    wfs = data.get('workflows', {})
    for key, wf in wfs.items():
        name = wf.get('name', key)
        desc = wf.get('description', '')
        steps = wf.get('steps', '?')
        print(f'  \033[1;36m{key}\033[0m  {name} ({steps} steps)')
        if desc: print(f'    {desc}')
except: pass
" 2>/dev/null || echo "  $resp"
        else
            ai_err "Could not retrieve workflows. Daemon may be down."
        fi
        return 0
    fi
    if [[ "$q" =~ ^workflow[[:space:]]+show[[:space:]]+(.+) ]]; then
        local name="${BASH_REMATCH[1]}"
        local resp
        if resp=$(_api_call GET "/contusion/workflows/${name}"); then
            ai_say "Workflow: ${C_CYAN}${name}${C_RESET}"
            echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    wf = data.get('workflow', data)
    print(f'  Name: {wf.get(\"name\", \"\")}')
    print(f'  Description: {wf.get(\"description\", \"\")}')
    print(f'  Steps:')
    for i, step in enumerate(wf.get('steps', []), 1):
        kind = step.get('kind', '?')
        detail = step.get('cmd', step.get('app', step.get('key', '')))
        secs = step.get('seconds', '')
        extra = f' ({secs}s)' if secs else (f': {detail}' if detail else '')
        print(f'    {i}. [{kind}]{extra}')
except: pass
" 2>/dev/null || echo "  $resp"
        else
            ai_err "Unknown workflow '${name}'. Try: ${C_CYAN}workflow list${C_RESET}"
        fi
        return 0
    fi
    if [[ "$q" =~ ^workflow[[:space:]]+run[[:space:]]+(.+) ]]; then
        local name="${BASH_REMATCH[1]}"
        ai_say "Running workflow: ${C_CYAN}${name}${C_RESET}"
        local resp
        if resp=$(_api_call POST "/contusion/workflows/${name}/run" "{}"); then
            ai_ok "Workflow complete."
            echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    result = data.get('result', data)
    steps = result.get('steps', result.get('results', []))
    if isinstance(steps, int):
        print(f'  {steps} steps executed')
    elif isinstance(steps, list):
        for i, s in enumerate(steps, 1):
            ok = '\033[32mOK\033[0m' if s.get('success', s.get('returncode', -1) == 0) else '\033[31mFAIL\033[0m'
            kind = s.get('kind', '?')
            print(f'  Step {i} [{kind}]: {ok}')
except: pass
" 2>/dev/null || echo "  $resp"
        else
            ai_err "Failed to run workflow '${name}'. Try: ${C_CYAN}workflow list${C_RESET}"
        fi
        return 0
    fi

    # ── Contusion Engine: launch ─────────────────────────────
    if [[ "$q" =~ ^launch[[:space:]]+(.+) ]]; then
        local app="${BASH_REMATCH[1]}"
        ai_say "Launching: ${C_CYAN}${app}${C_RESET}"
        local resp
        if resp=$(_api_call POST /contusion/launch "{\"app\":\"${app}\"}"); then
            ai_ok "Launched."
            echo "  $resp"
        else
            # Fallback: try desktop file or direct command
            ai_warn "Daemon unavailable, trying direct launch..."
            local desktop_file
            desktop_file=$(find /usr/share/applications -iname "*${app}*" -print -quit 2>/dev/null)
            if [ -n "$desktop_file" ]; then
                run_cmd "gtk-launch '$(basename "$desktop_file")'" "Launching via .desktop file"
            elif command -v "$app" &>/dev/null; then
                run_cmd "$app &" "Launching directly"
            else
                ai_err "Could not find '${app}'. Try: ${C_CYAN}apps${C_RESET}"
            fi
        fi
        return 0
    fi


    # ── Contusion Engine: apps ───────────────────────────────
    if [[ "$q" =~ ^apps$ ]]; then
        local resp
        if resp=$(_api_call GET /contusion/apps); then
            ai_say "Available apps:"
            echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    apps = data.get('apps', data) if isinstance(data, dict) else data
    if isinstance(apps, list):
        for a in apps:
            name = a.get('name', a) if isinstance(a, dict) else a
            desc = a.get('description', '') if isinstance(a, dict) else ''
            print(f'  \033[1;36m{name}\033[0m  {desc}')
    else:
        print(f'  {data}')
except: print(sys.stdin.read() if hasattr(sys.stdin, 'read') else str(data))
" 2>/dev/null || echo "  $resp"
        else
            # Fallback: list .desktop files
            ai_warn "Daemon unavailable, scanning local .desktop files..."
            find /usr/share/applications -name '*.desktop' -exec grep -l '^Type=Application' {} \; 2>/dev/null \
                | while read -r f; do
                    name=$(sed -n 's/^Name=//p' "$f" | head -1)
                    [ -n "$name" ] && echo "  $name"
                done | sort | head -40
        fi
        return 0
    fi

    # ── Question / ask prefix ─────────────────────────────────
    if [[ "$q" =~ ^(question|ask)[[:space:]]+(.+) ]]; then
        local body="${BASH_REMATCH[2]}"
        # Try the body as-is first (handles "question what is my ip")
        # then fall back to how-to form (handles "question set up ssh")
        process_input "$body"
        return $?
    fi

    # ── How-to / help ────────────────────────────────────────
    if [[ "$q" =~ ^how[[:space:]]+(do[[:space:]]+i[[:space:]]+|to[[:space:]]+|can[[:space:]]+i[[:space:]]+)?(.+) ]]; then
        local topic="${BASH_REMATCH[2]}"
        case "$topic" in
            *install*package*|*install*software*)
                ai_say "To install a package: ${C_CYAN}sudo pacman -S <package-name>${C_RESET}"
                ai_say "To search first: ${C_CYAN}pacman -Ss <keyword>${C_RESET}"
                ai_say "For AUR packages: ${C_CYAN}yay -S <package-name>${C_RESET}" ;;
            *update*|*upgrade*)
                ai_say "Full system update: ${C_CYAN}sudo pacman -Syu${C_RESET}" ;;
            *change*hostname*)
                ai_say "Change hostname: ${C_CYAN}sudo hostnamectl set-hostname <new-name>${C_RESET}" ;;
            *check*disk*|*disk*health*)
                ai_say "Check disk health: ${C_CYAN}sudo smartctl -a /dev/sda${C_RESET}"
                ai_say "Check filesystem: ${C_CYAN}sudo fsck /dev/sda1${C_RESET} (unmount first)" ;;
            *set*timezone*|*change*time*)
                ai_say "Set timezone: ${C_CYAN}sudo timedatectl set-timezone <Region/City>${C_RESET}"
                ai_say "List zones: ${C_CYAN}timedatectl list-timezones${C_RESET}" ;;
            *connect*ssh*|*ssh*into*|*set*up*ssh*|*setup*ssh*|*configure*ssh*|*enable*ssh*)
                ai_say "Start SSH server: ${C_CYAN}sudo systemctl enable --now sshd${C_RESET}"
                ai_say "SSH into a server: ${C_CYAN}ssh user@hostname${C_RESET}"
                ai_say "With key: ${C_CYAN}ssh -i ~/.ssh/id_ed25519 user@host${C_RESET}"
                ai_say "Generate key: ${C_CYAN}ssh-keygen -t ed25519${C_RESET}" ;;
            *create*ssh*key*|*generate*key*)
                ai_say "Generate SSH key: ${C_CYAN}ssh-keygen -t ed25519${C_RESET}" ;;
            *mount*drive*|*mount*usb*)
                ai_say "List drives: ${C_CYAN}lsblk${C_RESET}"
                ai_say "Mount: ${C_CYAN}sudo mount /dev/sdX1 /mnt${C_RESET}" ;;
            *find*file*|*locate*file*)
                ai_say "Find by name: ${C_CYAN}find / -name 'filename' 2>/dev/null${C_RESET}"
                ai_say "Fast search: ${C_CYAN}locate filename${C_RESET} (run ${C_CYAN}sudo updatedb${C_RESET} first)" ;;
            *kill*process*|*stop*process*)
                ai_say "Find process: ${C_CYAN}ps aux | grep <name>${C_RESET}"
                ai_say "Kill by name: ${C_CYAN}pkill <name>${C_RESET}"
                ai_say "Kill by PID: ${C_CYAN}kill <pid>${C_RESET}" ;;
            *cron*|*schedule*task*|*automate*)
                ai_say "Edit crontab: ${C_CYAN}crontab -e${C_RESET}"
                ai_say "Format: ${C_CYAN}min hour day month weekday command${C_RESET}"
                ai_say "Example (daily 2am): ${C_CYAN}0 2 * * * /path/to/script.sh${C_RESET}" ;;
            *firewall*|*open*port*|*close*port*)
                ai_say "Check firewall: ${C_CYAN}sudo ufw status${C_RESET}"
                ai_say "Allow port: ${C_CYAN}sudo ufw allow <port>${C_RESET}"
                ai_say "Or with iptables: ${C_CYAN}sudo iptables -A INPUT -p tcp --dport <port> -j ACCEPT${C_RESET}" ;;
            *run*exe*|*windows*program*|*run*windows*)
                ai_say "Run a .exe: ${C_CYAN}peloader /path/to/program.exe${C_RESET}"
                ai_say "Or simply: ${C_CYAN}./program.exe${C_RESET} (binfmt_misc handles it)"
                ai_say "For games: ${C_CYAN}pe-run-game /path/to/game.exe${C_RESET}" ;;
            *make*bootable*|*create*usb*|*bootable*usb*)
                ai_say "Write ISO to USB: ${C_CYAN}sudo dd bs=4M if=file.iso of=/dev/sdX status=progress${C_RESET}"
                ai_say "Or use: ${C_CYAN}sudo ventoy -i /dev/sdX${C_RESET}" ;;
            *)
                ai_say "Try: ${C_CYAN}man ${topic}${C_RESET}"
                ai_say "Or:  ${C_CYAN}${topic} --help${C_RESET}"
                run_cmd "man -k '${topic}' 2>/dev/null | head -10" "Searching manual pages" ;;
        esac
        return 0
    fi

    # ── Direct command pass-through (starts with !) ──────────
    if [[ "$q" =~ ^\!(.+) ]]; then
        local cmd="${BASH_REMATCH[1]}"
        cmd="${cmd# }"
        run_cmd "$cmd" "Running command"
        return 0
    fi

    # ── Fallback: try to be helpful ──────────────────────────
    ai_say "I didn't understand that. Try one of these:"
    echo -e "  ${C_CYAN}diagnose${C_RESET}                - System health check"
    echo -e "  ${C_CYAN}automate \"open firefox\"${C_RESET} - AI-driven task automation"
    echo -e "  ${C_CYAN}launch discord${C_RESET}          - Launch an app"
    echo -e "  ${C_CYAN}scan <pid>${C_RESET}              - Scan PE process for patterns"
    echo -e "  ${C_CYAN}analyze <pid>${C_RESET}           - PE process analysis"
    echo -e "  ${C_CYAN}discover <pid>${C_RESET}          - Stub discovery for PE process"
    echo -e "  ${C_CYAN}config show${C_RESET}             - View daemon config"
    echo -e "  ${C_CYAN}logs daemon${C_RESET}             - View system logs"
    echo -e "  ${C_CYAN}security status${C_RESET}         - Security overview"
    echo -e "  ${C_CYAN}contusion search <q>${C_RESET}    - Search command dictionary"
    echo -e "  ${C_CYAN}install firefox${C_RESET}         - Install a package"
    echo -e "  ${C_CYAN}!command${C_RESET}                - Run any command directly"
    echo -e "  ${C_CYAN}help${C_RESET}                    - Show all commands"
    return 0
}

# ─── Main ────────────────────────────────────────────────────
main() {
    # Direct command mode
    if [ $# -gt 0 ]; then
        process_input "$*"
        exit $?
    fi

    # Interactive chat mode
    INTERACTIVE=1
    echo -e "${C_BOLD}${C_BLUE}"
    echo "  +==============================================+"
    echo "  |           AI Assist v${VERSION}                  |"
    echo "  |   AI Arch Linux command-line assistant       |"
    echo "  +==============================================+"
    echo -e "${C_RESET}"
    ai_say "Type a request in plain English, or ${C_CYAN}help${C_RESET} for commands. ${C_DIM}(exit to quit)${C_RESET}"
    echo

    while true; do
        echo -ne "${C_BLUE}ai>${C_RESET} "
        if ! read -r line; then
            echo
            ai_say "Goodbye!"
            break
        fi
        [ -z "$line" ] && continue
        process_input "$line"
        echo
    done
}

main "$@"
