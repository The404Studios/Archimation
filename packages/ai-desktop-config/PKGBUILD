    # --- Windows 11 Bloom-style wallpaper ---
    install -d "$pkgdir/usr/share/backgrounds/ai-arch"
    python3 -c "
from PIL import Image, ImageDraw, ImageFilter

w, h = 1920, 1080
img = Image.new(chr(82)+chr(71)+chr(66), (w, h), chr(35)+chr(48)+chr(97)+chr(48)+chr(48)+chr(49)+chr(48))
draw = ImageDraw.Draw(img)

for y in range(h):
    t = y / h
    r = int(10 + 30 * t)
    g = int(0 + 5 * t)
    b = int(16 + 40 * t)
    draw.line([(0, y), (w-1, y)], fill=(r, g, b))

glow = Image.new(chr(82)+chr(71)+chr(66), (w, h), (0, 0, 0))
gd = ImageDraw.Draw(glow)

cx, cy = int(w * 0.38), int(h * 0.55)
for radius in range(400, 0, -1):
    alpha = (400 - radius) / 400
    r = int(80 * alpha * alpha)
    g = int(20 * alpha)
    b = int(200 * alpha * alpha * 0.8)
    gd.ellipse([cx-radius, cy-int(radius*0.7), cx+radius, cy+int(radius*0.7)], fill=(r, g, b))

cx2, cy2 = int(w * 0.72), int(h * 0.28)
for radius in range(300, 0, -1):
    alpha = (300 - radius) / 300
    r = int(60 * alpha)
    g = int(10 * alpha)
    b = int(150 * alpha)
    gd.ellipse([cx2-radius, cy2-int(radius*0.6), cx2+radius, cy2+int(radius*0.6)], fill=(r, g, b))

cx3, cy3 = int(w * 0.5), int(h * 0.88)
for radius in range(200, 0, -1):
    alpha = (200 - radius) / 200 * 0.5
    gd.ellipse([cx3-radius, cy3-int(radius*0.4), cx3+radius, cy3+int(radius*0.4)], fill=(int(10*alpha), int(80*alpha), int(120*alpha)))

glow_blur = glow.filter(ImageFilter.GaussianBlur(radius=40))
img = Image.blend(img, glow_blur, alpha=0.85)
img.save(chr(47)+chr(116)+chr(109)+chr(112)+chr(47)+chr(119)+chr(49)+chr(49)+chr(95)+chr(119)+chr(97)+chr(108)+chr(108)+chr(112)+chr(97)+chr(112)+chr(101)+chr(114)+chr(46)+chr(112)+chr(110)+chr(103))
print(chr(87)+chr(97)+chr(108)+chr(108)+chr(112)+chr(97)+chr(112)+chr(101)+chr(114)+chr(32)+chr(103)+chr(101)+chr(110)+chr(101)+chr(114)+chr(97)+chr(116)+chr(101)+chr(100))
" 2>/dev/null && install -Dm644 /tmp/w11_wallpaper.png \
    "$pkgdir/usr/share/backgrounds/ai-arch/default.png" 2>/dev/null || true

    # --- Quick Settings Panel (Win11 Action Center) ---
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-quick-settings" <<'QUICKSET'
#!/bin/bash
# ai-quick-settings - Windows 11-style quick settings panel
if [ -z "${DISPLAY:-}" ]; then
    echo 'No display available'
    exit 1
fi
CHOICE=$(zenity --list \
    --title='Quick Settings' \
    --text='<b>Quick Settings</b>' \
    --column='' --column='Action' \
    --hide-column=1 \
    --width=300 --height=380 \
    --ok-label='Select' \
    --cancel-label='Close' \
    'wifi'      '  WiFi / Network' \
    'sound'     '  Sound' \
    'display'   '  Display' \
    'bluetooth' '  Bluetooth' \
    'nightmode' '  Night Light' \
    'darkmode'  '  Toggle Dark/Light Mode' \
    'screenshot''  Screenshot' \
    'lock'      '  Lock Screen' \
    'settings'  '  All Settings' \
    'pkgupdate' '  Update System' \
    2>/dev/null) || exit 0
case '$CHOICE' in
    wifi)      nm-connection-editor &;;
    sound)     pavucontrol &;;
    display)   xfce4-display-settings &;;
    bluetooth) command -v blueman-manager &>/dev/null && blueman-manager &;;
    nightmode)
        if pgrep -x redshift &>/dev/null; then
            pkill redshift; notify-send 'Night Light' 'Night light off' --icon=weather-clear
        else
            redshift -O 4500 &
            notify-send 'Night Light' 'Night light on (4500K)' --icon=weather-clear-night
        fi
        ;;
    darkmode)
        CURRENT=$(xfconf-query -c xsettings -p /Net/ThemeName 2>/dev/null)
        if [[ '$CURRENT' == *'dark'* ]] || [[ '$CURRENT' == *'Dark'* ]]; then
            xfconf-query -c xsettings -p /Net/ThemeName -s 'Adwaita' 2>/dev/null
            notify-send 'Theme' 'Switched to Light mode' --icon=preferences-desktop-theme
        else
            xfconf-query -c xsettings -p /Net/ThemeName -s 'Adwaita-dark' 2>/dev/null
            notify-send 'Theme' 'Switched to Dark mode' --icon=preferences-desktop-theme
        fi
        ;;
    screenshot)
        sleep 0.5
        mkdir -p ~/Pictures
        scrot -q 90 ~/Pictures/Screenshot_%Y-%m-%d_%H-%M-%S.png
        notify-send 'Screenshot' 'Saved to ~/Pictures' --icon=camera-photo
        ;;
    lock)      xflock4 ;;
    settings)  xfce4-settings-manager &;;
    pkgupdate)
        terminator -e 'sudo pacman -Syu; read -p "Press Enter to close..."' &
        ;;
esac
QUICKSET

    # --- Proton-GE download/install script ---
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/proton-ge-install" <<'PROTONGESCRIPT'
#!/usr/bin/env bash
# proton-ge-install - Download and install latest Proton-GE
set -euo pipefail

INSTALL_DIR="$HOME/.local/share/Steam/compatibilitytools.d"
mkdir -p "$INSTALL_DIR"

echo "Fetching latest Proton-GE release..."
RELEASE_JSON=$(curl -sL "https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest") || {
    echo "Error: Could not reach GitHub API. Check internet connection."
    exit 1
}
LATEST=$(echo "$RELEASE_JSON" | grep '"tag_name"' | head -1 | cut -d'"' -f4)

if [ -z "$LATEST" ]; then
    echo "Error: Could not parse release tag from GitHub API response."
    exit 1
fi

echo "Latest release: $LATEST"
# Proton-GE tarballs extract to a directory matching the tag (e.g. GE-Proton9-20)
DIRNAME="$LATEST"
TARNAME="${LATEST}.tar.gz"
URL="https://github.com/GloriousEggroll/proton-ge-custom/releases/download/${LATEST}/${TARNAME}"

if [ -d "$INSTALL_DIR/$DIRNAME" ]; then
    echo "$DIRNAME already installed at $INSTALL_DIR/$DIRNAME"
    exit 0
fi

echo "Downloading ${TARNAME}..."
TMPTAR=$(mktemp /tmp/proton-ge-XXXXXX.tar.gz)
if ! curl -L --progress-bar -o "$TMPTAR" "$URL"; then
    echo "Error: Download failed for $URL"
    rm -f "$TMPTAR"
    exit 1
fi

echo "Extracting..."
tar xzf "$TMPTAR" -C "$INSTALL_DIR/"
rm -f "$TMPTAR"

if [ ! -d "$INSTALL_DIR/$DIRNAME" ]; then
    echo "Warning: Expected directory $DIRNAME not found after extraction."
    echo "Contents of $INSTALL_DIR:"
    ls -1 "$INSTALL_DIR"
fi

echo ""
echo "Proton-GE $LATEST installed to $INSTALL_DIR/$DIRNAME"
echo ""
echo "Next steps:"
echo "  1. Restart Steam"
echo "  2. Right-click a game -> Properties -> Compatibility"
echo "  3. Select '$DIRNAME'"

command -v notify-send &>/dev/null && \
    notify-send "Proton-GE" "Installed $LATEST. Restart Steam to use it." --icon=steam 2>/dev/null || true
