# Build outputs
work/
output/
repo/
repo/x86_64/*.pkg.tar.zst
repo/x86_64/*.db*
repo/x86_64/*.files*
*.pkg.tar.zst

# Pacman repo symlinks (generated by repo-add; Windows git can't index symlinks)
/pe-compat.db
/pe-compat.db.tar.gz
/pe-compat.files
/pe-compat.files.tar.gz

# C header dependency files (generated by -MMD -MP).
# Only match FILES ending in .d, not DIRECTORIES — leading-slash
# exclusion via `!*/` is the standard way to tell git "match files,
# not dirs". Before S81.5 this rule accidentally excluded EVERY *.d
# directory (xorg.conf.d/, modprobe.d/, sudoers.d/, profile.d/,
# sysctl.d/, modules-load.d/, pam.d/, binfmt.d/, udev/rules.d/
# CANNOT match — rules.d/ is matched by *.d/), which silently
# prevented tracking of ~20 critical boot-config files for months.
# Each re-include rule below is load-bearing; do not remove without
# re-auditing `git ls-files profile/airootfs/etc/*.d` output.
*.d
!*.d/
# Systemd unit drop-in directories (foo.service.d/, foo.slice.d/)
!*.service.d/**
!*.slice.d/**
# Config drop-in directories that ship with the live ISO profile.
# Adding a new category? mirror the pattern: `!<name>.d/**`. Glob-match
# against paths like profile/airootfs/etc/X/<name>.d/foo.conf — the
# `!*.d/` above re-includes DIRECTORIES, these rules re-include FILES
# inside them.
!binfmt.d/**
!conf.d/**
!hooks.d/**
!logind.conf.d/**
!journald.conf.d/**
!modprobe.d/**
!modules-load.d/**
!pacman.d/**
!pam.d/**
!profile.d/**
!rules.d/**
!scripts.d/**
!sleep.conf.d/**
!sshd_config.d/**
!sudoers.d/**
!sysctl.d/**
!sysusers.d/**
!system.conf.d/**
!tmpfiles.d/**
!tmp.mount.d/**
!xorg.conf.d/**

