# Maintainer: AI Arch Linux Project
# PKGBUILD for windows-services - Windows Service Control Manager and driver tools

pkgname=windows-services
pkgver=0.1.0
pkgrel=6
pkgdesc="Windows Service Control Manager daemon, driver framework, and anti-cheat compatibility layer"
arch=('x86_64')
url="https://github.com/ai-arch-linux/windows-services"
license=('GPL-3.0-or-later')
options=('!debug')
depends=('glibc' 'pe-loader')
makedepends=('gcc' 'make')
optdepends=(
    'dkms: kernel driver host module'
    'linux-headers: building the kernel driver host'
)
provides=('windows-services' 'scm-daemon' 'devcon')
source=()

# Use the project source tree directly (local build)
_srcdir="${startdir}/../../services"

build() {
    cd "$_srcdir"
    # Parallel compile (MAKEFLAGS propagated from build-packages.sh).
    make clean
    make all ${MAKEFLAGS:-}
}

package() {
    cd "$_srcdir"

    # Install SCM daemon and sc command
    install -Dm755 scm/scm_daemon "$pkgdir/usr/bin/scm_daemon"
    install -Dm755 scm/sc "$pkgdir/usr/bin/sc"

    # Install devcon (device console) tool
    install -Dm755 drivers/userspace/devcon "$pkgdir/usr/bin/devcon"

    # Install anti-cheat compatibility library
    install -Dm755 anticheat/libpe_anticheat.so "$pkgdir/usr/lib/pe-compat/libpe_anticheat.so"

    # Install driver stub shared libraries
    install -d "$pkgdir/usr/lib/pe-compat/drivers"
    for so in drivers/stubs/*.so; do
        [ -f "$so" ] && install -Dm755 "$so" "$pkgdir/usr/lib/pe-compat/drivers/$(basename "$so")"
    done

    # Create SCM state directories
    install -d "$pkgdir/var/lib/pe-compat/services"
    install -d "$pkgdir/var/log/pe-compat"

    # Object broker daemon
    install -Dm755 objectd/pe-objectd "$pkgdir/usr/bin/pe-objectd"

    # pe-objectd systemd service
    #
    # Heredoc uses 'EOF' (quoted) so the shell does NOT expand $MAINPID;
    # systemd needs those specifiers verbatim at unit-activation time.
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system/pe-objectd.service" <<'EOF'
[Unit]
Description=PE Compatibility Object Broker
Documentation=https://github.com/ai-arch-linux/windows-services
# L1 layer: object broker must be up before L3 SCM and L4 cortex.
Before=ai-cortex.service scm-daemon.service
# local-fs for /var/lib/pe-compat/services state, network for unix socket
# bind (doesn't wait for connectivity, just for loopback to be up).
After=network.target local-fs.target systemd-modules-load.service
# S82+E: ConditionPathExists= removed.  pe-objectd is L1 critical-path
# (broker for L3 SCM + L4 cortex).  A silent Condition= skip would start
# downstream units against a missing broker and show as "skipped" in the
# journal rather than an error.  If the binary is absent, let ExecStart
# fail loudly so the real problem surfaces.  The binary is installed by
# this very package (line 55), so the only way it's missing is a partial
# pacstrap — which we want to see, not paper over.
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
# Session 36: objectd_main.c now sends READY=1 after broker init, pings
# WATCHDOG=1 every 15s from the epoll loop, and STOPPING=1 before cleanup.
# Stdlib AF_UNIX datagram -- no libsystemd link dep.
Type=notify
NotifyAccess=main
ExecStartPre=/usr/bin/mkdir -p /run/pe-compat
ExecStart=/usr/bin/pe-objectd
Restart=on-failure
RestartSec=5
# Broker cold-start: hive load + session namespace init.  Fast on real HW,
# up to ~20s on TCG QEMU.
TimeoutStartSec=30
# Broker answers SIGTERM immediately (unix-socket listen loop drops out).
TimeoutStopSec=10
KillMode=mixed
KillSignal=SIGTERM
# Runtime dir: systemd creates /run/pe-compat with 0755 automatically,
# which makes the ExecStartPre mkdir above redundant but harmless.
RuntimeDirectory=pe-compat
RuntimeDirectoryMode=0755
StandardOutput=journal
StandardError=journal
# Heartbeat posted every 15s from the epoll loop (half-interval).
WatchdogSec=30

[Install]
WantedBy=multi-user.target
EOF

    # Install systemd service for SCM daemon
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system/scm-daemon.service" <<'SERVICE'
[Unit]
Description=Windows Service Control Manager Daemon
Documentation=https://github.com/ai-arch-linux/windows-services
# L3 layer: SCM needs pe-objectd (L1) for handle resolution.  Using After=
# rather than Requires= because SCM can start in degraded mode without the
# broker (only reports error when a client actually needs a named object).
After=network.target pe-objectd.service local-fs.target
Wants=pe-objectd.service
# S82+E: ConditionPathExists= removed.  scm_daemon is L3 critical-path
# (Windows service lifecycle).  Silent-skip hides install breakage; let
# ExecStart fail loudly instead.  Binary is installed by this package
# (line 35).
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
# Session 36: scm_daemon.c now sends READY=1 after service auto-start,
# pings WATCHDOG=1 every 15s from the select() accept loop, and STOPPING=1
# before cleanup. Stdlib AF_UNIX datagram -- no libsystemd link dep.
Type=notify
NotifyAccess=main
ExecStartPre=/usr/bin/mkdir -p /run/pe-compat/services
ExecStart=/usr/bin/scm_daemon
Restart=on-failure
RestartSec=5
# SCM startup: service-graph load from /var/lib/pe-compat/services.
# Fast on real HW; 30s ceiling for TCG QEMU + large service graph.
TimeoutStartSec=30
# SCM graceful shutdown: signals each managed service in reverse dep order.
# Give 15s before SIGKILL — enough time to notify 10-20 shims.
TimeoutStopSec=15
KillMode=mixed
KillSignal=SIGTERM
RuntimeDirectory=pe-compat/services
RuntimeDirectoryMode=0755
StandardOutput=journal
StandardError=journal
# Heartbeat posted every 15s from the main accept loop (half-interval).
WatchdogSec=30

[Install]
WantedBy=multi-user.target
SERVICE
}
