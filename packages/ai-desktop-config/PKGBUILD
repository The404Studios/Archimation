      <property name="XF86AudioMute" type="string" value="pactl set-sink-mute @DEFAULT_SINK@ toggle"/>
      <property name="XF86AudioMicMute" type="string" value="pactl set-source-mute @DEFAULT_SOURCE@ toggle"/>
      <!-- Brightness keys -->
      <property name="XF86MonBrightnessUp" type="string" value="brightnessctl set +10%"/>
      <property name="XF86MonBrightnessDown" type="string" value="brightnessctl set 10%-"/>
    </property>
  </property>
  <property name="xfwm4" type="empty">
    <property name="custom" type="empty">
      <!-- Alt+F4 = Close window -->
      <property name="&lt;Alt&gt;F4" type="string" value="close_window_key"/>
      <property name="&lt;Alt&gt;F10" type="string" value="maximize_window_key"/>
      <property name="&lt;Alt&gt;F9" type="string" value="hide_window_key"/>
      <!-- Super+Arrow = window tiling -->
      <property name="&lt;Super&gt;Left" type="string" value="tile_left_key"/>
      <property name="&lt;Super&gt;Right" type="string" value="tile_right_key"/>
      <property name="&lt;Super&gt;Up" type="string" value="maximize_window_key"/>
      <property name="&lt;Super&gt;Down" type="string" value="hide_window_key"/>
      <!-- Alt+Tab = Switch windows -->
      <property name="&lt;Alt&gt;Tab" type="string" value="cycle_windows_key"/>
      <property name="&lt;Alt&gt;&lt;Shift&gt;Tab" type="string" value="cycle_reverse_windows_key"/>
      <!-- Super+Tab = Switch workspaces -->
      <property name="&lt;Super&gt;Tab" type="string" value="switch_window_key"/>
      <!-- Super+1..4 = Switch to workspace 1-4 -->
      <property name="&lt;Super&gt;1" type="string" value="workspace_1_key"/>
      <property name="&lt;Super&gt;2" type="string" value="workspace_2_key"/>
      <property name="&lt;Super&gt;3" type="string" value="workspace_3_key"/>
      <property name="&lt;Super&gt;4" type="string" value="workspace_4_key"/>
      <!-- Alt+F1..F3 = Switch to workspace 1-3 -->
      <property name="&lt;Alt&gt;F1" type="string" value="workspace_1_key"/>
      <property name="&lt;Alt&gt;F2" type="string" value="workspace_2_key"/>
      <property name="&lt;Alt&gt;F3" type="string" value="workspace_3_key"/>
      <!-- Ctrl+Alt+Left/Right = Switch workspaces -->
      <property name="&lt;Primary&gt;&lt;Alt&gt;Left" type="string" value="left_workspace_key"/>
      <property name="&lt;Primary&gt;&lt;Alt&gt;Right" type="string" value="right_workspace_key"/>
    </property>
  </property>
</channel>
