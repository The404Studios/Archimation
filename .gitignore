# Build outputs
work/
output/
repo/
repo/x86_64/*.pkg.tar.zst
repo/x86_64/*.db*
repo/x86_64/*.files*
*.pkg.tar.zst

# Pacman repo symlinks (generated by repo-add; Windows git can't index symlinks)
/pe-compat.db
/pe-compat.db.tar.gz
/pe-compat.files
/pe-compat.files.tar.gz

# C header dependency files (generated by -MMD -MP)
*.d
# But re-include systemd drop-in directories (foo.service.d/) -- those
# are version-controlled unit-file overrides, NOT C dep files.
!*.service.d/
!*.service.d/**
!*.slice.d/
!*.slice.d/**

# Arch package metadata (generated by makepkg)
/.BUILDINFO
/.INSTALL
/.MTREE
/.PKGINFO

# Object files
*.o
*.so
*.ko
*.mod
*.mod.c
*.order
*.symvers
*.cmd
.tmp_versions/

# Binaries
pe-loader/loader/peloader
pe-loader/tools/pe_dump
pe-loader/tools/syscall_trace
pe-loader/dlls/*/*.so
pe-loader/dlls/*.so
services/scm/scm_daemon
services/scm/sc
services/drivers/userspace/devcon
peloader
pe-loader/nul
trust/lib/libtrust.a
trust/lib/libtrust.so*
# S76 Agent E: pt_regs_compat unit-test build artifact
tests/bisim/pt_regs_compat
# tests/adversarial/helpers — built by tests/adversarial/Makefile
tests/adversarial/helpers

# Kernel module build
Module.symvers
modules.order
.Module.symvers.cmd
.modules.order.cmd

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
.eggs/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Obsidian
.obsidian/

# Claude Code runtime state
.claude/scheduled_tasks.lock

# Local session artifacts (transcripts, CI log dumps, scratch probes)
/info/
/logs/
/tmp_*.py
/tmp_*.sh
