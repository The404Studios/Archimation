# /etc/X11/Xwrapper.config
#
# Controls who may start Xorg and whether the X server needs the
# setuid root wrapper (/usr/lib/Xorg.wrap).
#
# Modern display managers (LightDM, GDM, SDDM) start Xorg via
# systemd-logind, which hands the server a pre-opened seat/DRM/VT
# fd.  In that flow the server runs as the logged-in user (Xorg
# rootless) and needs NO setuid bit.
#
# But /usr/lib/Xorg.wrap still enforces this file:
#   * allowed_users=rootonly  -> blocks user-started X, but ALSO
#                                blocks the logind path on some
#                                Arch builds.  SILENT FAILURE.
#   * allowed_users=console   -> any user on a physical VT can
#                                start X.  Default on most distros.
#   * allowed_users=anybody   -> permissive; safe under logind
#                                because the kernel still owns the
#                                DRM master.
#
# needs_root_rights=no tells the wrapper to drop setuid entirely and
# trust logind to pass the DRM/input fds.  This is the correct value
# when the machine always boots into a logind-managed DM, which is
# our case (LightDM -> xfce session).  Without this line, the wrapper
# falls back to "auto" which on some hosts decides it DOES need root
# and then bails out if the binary isn't setuid -> LightDM silently
# fails with no useful log.
allowed_users=anybody
needs_root_rights=no
