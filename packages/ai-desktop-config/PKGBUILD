    def _rebuild_history_menu(self):
        self.history_menu.remove_all()
        for i, cmd in enumerate(self.cmd_history[:15]):
            self.history_menu.append_item(
                Gio.MenuItem.new(cmd, f"app.hist-{i}"))
        for i, cmd in enumerate(self.cmd_history[:15]):
            aname = f"hist-{i}"
            old = self.lookup_action(aname)
            if old:
                self.remove_action(aname)
            act = Gio.SimpleAction.new(aname, None)
            act.connect("activate",
                        self._on_history_select, cmd)
            self.add_action(act)

    def _on_history_select(self, action, param, cmd):
        self.auto_entry.set_text(cmd)
        self.auto_entry.grab_focus()

    def _on_execute(self, _w):
        text = self.auto_entry.get_text().strip()
        if not text:
            return
        self._set_result("")
        self.auto_entry.set_sensitive(False)
        self.exec_btn.set_sensitive(False)
        self.auto_spinner.set_visible(True)
        self.auto_spinner.start()
        self.auto_spinner_label.set_visible(True)
        self.auto_running = True

        if text in self.cmd_history:
            self.cmd_history.remove(text)
        self.cmd_history.insert(0, text)
        save_cmd_history(self.cmd_history)
        self._rebuild_history_menu()

        def do():
            res = api_call("POST", "/contusion/context",
                           {"prompt": text})
            GLib.idle_add(self._show_result, text, res)
        threading.Thread(target=do, daemon=True).start()

    def _show_result(self, prompt, res):
        self.auto_entry.set_sensitive(True)
        self.exec_btn.set_sensitive(True)
        self.auto_entry.set_text("")
        self.auto_spinner.stop()
        self.auto_spinner.set_visible(False)
        self.auto_spinner_label.set_visible(False)
        self.auto_running = False
        self.last_action_ts = time.strftime("%H:%M:%S")
        self._update_status_bar()

        if "error" in res:
            self._set_result(
                f"Error: {res['error']}")
            self._show_toast(
                f"Automation failed: {res['error']}", 5)
        else:
            actions = res.get("actions", [])
            summary = res.get("summary",
                              json.dumps(res, indent=2))
            out = (summary if isinstance(summary, str)
                   else json.dumps(summary))
            # Append stdout/stderr if present
            stdout = res.get("stdout", "")
            stderr = res.get("stderr", "")
            if stdout:
                out += f"\n{stdout}"
            if stderr:
                out += f"\n[stderr] {stderr}"
            if actions:
                out += (f"\n[{len(actions)} action(s) "
                        "executed]")
            self._set_result(out)
            self._show_toast(
                "Automation completed successfully")

        ts = time.strftime("%H:%M:%S")
        self.history.insert(
            0, {"time": ts, "prompt": prompt})
        row = Adw.ActionRow(title=prompt, subtitle=ts)
        rerun = Gtk.Button(
            icon_name="media-playback-start-symbolic")
        rerun.set_valign(Gtk.Align.CENTER)
        rerun.set_tooltip_text("Re-run")
        rerun.connect("clicked",
                      self._on_rerun_history, prompt)
        row.add_suffix(rerun)
        self.history_list.prepend(row)

    def _on_rerun_history(self, _b, prompt):
        self.auto_entry.set_text(prompt)
        self._on_execute(None)

    # --- Quick Actions ---------------------------------------------------
    def _qa_screenshot(self, _b):
        self._run_quick_action(
            "Taking screenshot...",
            lambda: api_call(
                "POST", "/screen/screenshot", {}),
            "Screenshot saved")

    def _qa_update_system(self, _b):
        self._run_quick_action(
            "Updating system...",
            lambda: api_call("POST", "/system/exec",
                {"command": "pacman -Syu --noconfirm"}),
            "System update complete")

    def _qa_clean_cache(self, _b):
        self._run_quick_action(
            "Cleaning package cache...",
            lambda: api_call("POST", "/system/exec",
                {"command": "pacman -Sc --noconfirm"}),
            "Cache cleaned")

    def _qa_show_processes(self, _b):
        self.sidebar.select_row(
            self.sidebar.get_row_at_index(2))
        self._load_processes()

    def _qa_network_diag(self, _b):
        self._run_quick_action(
            "Running network diagnostics...",
            lambda: api_call("POST", "/system/exec",
                {"command": "echo '=== IP ===' && "
                 "ip -br addr && echo '=== Route ===' && "
                 "ip route && echo '=== DNS ===' && "
                 "cat /etc/resolv.conf && "
                 "echo '=== Ping ===' && "
                 "ping -c 2 -W 2 8.8.8.8 2>&1 || "
                 "echo 'ping failed'"}),
            "Network diagnostics complete")

    def _qa_show_monitor(self, _b):
        self.sidebar.select_row(
            self.sidebar.get_row_at_index(3))
        self._refresh_monitor()

    def _run_quick_action(self, busy_msg, api_fn, ok_msg):
        self._set_result(busy_msg)
        self.auto_spinner.set_visible(True)
        self.auto_spinner.start()
        self.auto_spinner_label.set_visible(True)
        self.auto_spinner_label.set_text(busy_msg)
        def do():
            res = api_fn()
            GLib.idle_add(_finish, res)
        def _finish(res):
            self.auto_spinner.stop()
            self.auto_spinner.set_visible(False)
            self.auto_spinner_label.set_visible(False)
            self.last_action_ts = time.strftime("%H:%M:%S")
            self._update_status_bar()
            if "error" in res:
                self._set_result(
                    f"Error: {res['error']}")
                self._show_toast(
                    f"Action failed: {res['error']}", 5)
            else:
                out = ok_msg
                stdout = res.get("stdout", "")
                if stdout:
                    out += f"\n\n{stdout}"
                self._set_result(out)
                self._show_toast(ok_msg)
        threading.Thread(target=do, daemon=True).start()

    # == Macros ============================================================
    def _check_connection(self):
        def do():
            health = api_call("GET", "/health")
            online = isinstance(health, dict) and health.get("status") == "ok"
            trust = "Unknown"
            if online:
                tdata = api_call("GET", "/trust/level")
                if isinstance(tdata, dict):
                    trust = tdata.get("level",
                        tdata.get("trust_level", "Unknown"))
            GLib.idle_add(self._apply_connection, online, trust)
        threading.Thread(target=do, daemon=True).start()

    def _apply_connection(self, online, trust):
        self.daemon_online = online
        self.trust_level = trust
        self.offline_banner.set_revealed(not online)
        self._update_status_bar()
        self._show_toast("Refreshed")

    def _on_play_macro(self, _b, idx):
        macros = load_macros()
        if idx < len(macros):
            m = macros[idx]
            mname = m.get("name", "Unnamed")
            self._show_toast(
                f"Running macro '{mname}'...")
            def do():
                for a in m.get("actions", []):
                    api_call("POST",
                             "/contusion/context",
                             {"prompt": a})
                m["last_run"] = time.strftime(
                    "%Y-%m-%d %H:%M")
                save_macros(macros)
                GLib.idle_add(self._reload_macros)
                GLib.idle_add(self._show_toast,
                    f"Macro '{mname}' finished")
            threading.Thread(
                target=do, daemon=True).start()

    def _on_delete_macro(self, _b, idx):
        macros = load_macros()
        if idx < len(macros):
            name = macros[idx].get("name", "Unnamed")
            macros.pop(idx)
            save_macros(macros)
            self._reload_macros()
            self._show_toast(
                f"Macro '{name}' deleted")

    # == Processes =========================================================
    def _page_processes(self):
        _m = self._page_margin
        _sp = 6 if self._compact else 12
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL,
                       spacing=_sp)
        page.set_margin_start(_m); page.set_margin_end(_m)
        page.set_margin_top(self._page_top)

        t = Gtk.Label(label="Processes")
        t.add_css_class("title-2" if self._compact else "title-1")
        t.set_halign(Gtk.Align.START); page.append(t)

        # Toolbar: search + sort + refresh
        toolbar = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL,
            spacing=8)
        self.proc_search = Gtk.SearchEntry()
        self.proc_search.set_placeholder_text(
            "Filter processes...")
        self.proc_search.set_hexpand(True)
        self.proc_search.connect("search-changed",
                                  self._on_proc_filter)
        toolbar.append(self.proc_search)

        sbox = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL,
            spacing=4)
        slbl = Gtk.Label(label="Sort:")
        slbl.add_css_class("dim-label")
        sbox.append(slbl)
        self.proc_sort_dd = Gtk.DropDown.new_from_strings(
            ["CPU %", "Memory %", "PID", "Name"])
        self.proc_sort_dd.set_selected(0)
        self.proc_sort_dd.connect("notify::selected",
                                   self._on_proc_sort)
        sbox.append(self.proc_sort_dd)
        toolbar.append(sbox)

        rbtn = Gtk.Button(icon_name="view-refresh-symbolic")
        rbtn.set_tooltip_text("Refresh")
        rbtn.connect("clicked",
                      lambda _: self._load_processes())
        toolbar.append(rbtn)
        page.append(toolbar)

        sw = Gtk.ScrolledWindow(); sw.set_vexpand(True)
        self.proc_list = Gtk.ListBox()
        self.proc_list.set_selection_mode(
            Gtk.SelectionMode.NONE)
        self.proc_list.add_css_class("boxed-list")
        sw.set_child(self.proc_list); page.append(sw)

        self.proc_count_lbl = Gtk.Label(label="")
        self.proc_count_lbl.add_css_class("caption")
        self.proc_count_lbl.add_css_class("dim-label")
        self.proc_count_lbl.set_halign(Gtk.Align.START)
        page.append(self.proc_count_lbl)

        self._load_processes()
        return page

    def _on_proc_filter(self, entry):
        self._proc_filter = (
            entry.get_text().strip().lower())
        self._render_processes()

    def _on_proc_sort(self, dd, _p):
        idx = dd.get_selected()
        keys = ["cpu", "mem", "pid", "name"]
        self._proc_sort_key = (
            keys[idx] if idx < len(keys) else "cpu")
        self._proc_sort_reverse = (
            self._proc_sort_key != "name")
        self._render_processes()

    def _load_processes(self):
        def do():
            try:
                out = subprocess.check_output(
                    ["ps", "aux", "--sort=-pcpu"],
                    text=True, timeout=5
                ).strip().split("\n")[1:51]
            except Exception:
                out = []
            procs = []
            for line in out:
                parts = line.split(None, 10)
                if len(parts) < 11:
                    continue
                pid = parts[1]
                cpu = parts[2]
                mem = parts[3]
                cmd = parts[10]
                name = (os.path.basename(
                    cmd.split()[0]) if cmd else "?")
                procs.append({
                    "pid": pid,
                    "cpu": float(cpu),
                    "mem": float(mem),
                    "name": name, "cmd": cmd})
            GLib.idle_add(self._set_proc_data, procs)
        threading.Thread(target=do, daemon=True).start()

    def _set_proc_data(self, procs):
        self._proc_data = procs
        self._render_processes()

    def _render_processes(self):
        _clear_listbox(self.proc_list)
        data = self._proc_data
        if self._proc_filter:
            flt = self._proc_filter
            data = [p for p in data
                    if flt in p["name"].lower()
                    or flt in p["pid"]
                    or flt in p.get("cmd", "").lower()]
        sk = self._proc_sort_key
        if sk == "name":
            data = sorted(data,
                key=lambda p: p["name"].lower(),
                reverse=self._proc_sort_reverse)
        else:
            data = sorted(data,
                key=lambda p: p.get(sk, 0),
                reverse=self._proc_sort_reverse)

        for p in data:
            row = Adw.ActionRow(
                title=p["name"],
                subtitle=f"PID {p['pid']}")
            # CPU/MEM metric badges
            cpu_v = min(p["cpu"], 100)
            mem_v = min(p["mem"], 100)
            metrics = Gtk.Box(
                orientation=Gtk.Orientation.VERTICAL,
                spacing=2)
            metrics.set_valign(Gtk.Align.CENTER)
            cpu_lbl = Gtk.Label(
                label=f"CPU {p['cpu']}%")
            cpu_lbl.add_css_class("caption")
            if p["cpu"] >= 50:
                cpu_lbl.add_css_class("proc-cpu-high")
            elif p["cpu"] >= 15:
                cpu_lbl.add_css_class("proc-cpu-med")
            else:
                cpu_lbl.add_css_class("proc-cpu-low")
            cpu_bar = Gtk.LevelBar()
            cpu_bar.set_min_value(0)
            cpu_bar.set_max_value(100)
            cpu_bar.set_value(cpu_v)
            cpu_bar.add_css_class("proc-bar")
            mem_lbl = Gtk.Label(
                label=f"MEM {p['mem']}%")
            mem_lbl.add_css_class("caption")
            mem_bar = Gtk.LevelBar()
            mem_bar.set_min_value(0)
            mem_bar.set_max_value(100)
            mem_bar.set_value(mem_v)
            mem_bar.add_css_class("proc-bar")
            metrics.append(cpu_lbl)
            metrics.append(cpu_bar)
            metrics.append(mem_lbl)
            metrics.append(mem_bar)
            row.add_suffix(metrics)
            kill_btn = Gtk.Button(
                icon_name="process-stop-symbolic")
            kill_btn.set_valign(Gtk.Align.CENTER)
            kill_btn.set_tooltip_text(
                f"Kill {p['name']} (PID {p['pid']})")
            kill_btn.add_css_class("destructive-action")
            kill_btn.connect("clicked", self._on_kill,
                             p["pid"], p["name"])
            row.add_suffix(kill_btn)
            self.proc_list.append(row)

        total = len(self._proc_data)
        shown = len(data)
        if self._proc_filter:
            self.proc_count_lbl.set_text(
                f"Showing {shown} of {total} processes")
        else:
            self.proc_count_lbl.set_text(
                f"{shown} processes")

    def _on_kill(self, _b, pid, name):
        if (hasattr(self, 'sw_kill')
                and self.sw_kill.get_active()):
            dlg = Adw.MessageDialog(
                heading=f"Kill {name}?",
                body=f"Send SIGKILL to PID {pid}. "
                     "This cannot be undone.")
            dlg.add_response("cancel", "Cancel")
            dlg.add_response("kill", "Kill")
            dlg.set_response_appearance("kill",
                Adw.ResponseAppearance.DESTRUCTIVE)
            dlg.connect("response",
                self._on_kill_confirm, pid, name)
            dlg.set_transient_for(
                self.get_active_window())
            dlg.present()
        else:
            self._do_kill(pid, name)

    def _on_kill_confirm(self, dlg, resp, pid, name):
        if resp == "kill":
            self._do_kill(pid, name)

    def _do_kill(self, pid, name):
        def do():
            try:
                subprocess.run(
                    ["kill", "-9", pid], timeout=3)
                GLib.idle_add(self._show_toast,
                    f"Killed {name} (PID {pid})")
            except Exception as e:
                GLib.idle_add(self._show_toast,
                    f"Failed to kill {name}: {e}", 5)
            GLib.idle_add(self._load_processes)
        threading.Thread(target=do, daemon=True).start()

    def _on_send_input(self, _b, pid, name):
        dlg = Adw.MessageDialog(
            heading=f"Send Input to {name} "
                    f"(PID {pid})",
            body="Enter text to write to "
                 "process stdin:")
        dlg.add_response("cancel", "Cancel")
        dlg.add_response("send", "Send")
        dlg.set_response_appearance("send",
            Adw.ResponseAppearance.SUGGESTED)
        entry = Gtk.Entry()
        entry.set_placeholder_text("input text...")
        dlg.set_extra_child(entry)
        dlg.connect("response",
            self._on_input_resp, entry, pid)
        dlg.set_transient_for(
            self.get_active_window())
        dlg.present()

    def _on_input_resp(self, dlg, resp, entry, pid):
        if resp == "send":
            text = entry.get_text()
            try:
                with open(f"/proc/{pid}/fd/0", "w") as f:
                    f.write(text + "\n")
                self._show_toast("Input sent")
            except Exception as e:
                self._show_toast(
                    f"Failed to send input: {e}", 5)

    # == System Monitor ====================================================
    def _page_monitor(self):
        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        _m = self._page_margin
        _sp = 6 if self._compact else 12
