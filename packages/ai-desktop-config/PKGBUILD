    # ==========================================================================
    # AI RUN EXE — file-picker dialog to run a Windows .exe via PE loader
    # ==========================================================================
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-run-exe" <<'AIRUNEXE'
#!/bin/bash
# ai-run-exe - Launch a Windows .exe through the PE loader with a GUI file picker
# Part of AI Arch Linux desktop integration.
set -euo pipefail

FILE=""

if [ $# -ge 1 ] && [ -f "$1" ]; then
    FILE="$1"
else
    # Show file picker dialog (zenity preferred, kdialog fallback)
    if command -v zenity >/dev/null 2>&1; then
        FILE=$(zenity --file-selection             --title="Select Windows Executable"             --file-filter="Windows Executables (exe)|*.exe *.EXE"             --file-filter="All files|*" 2>/dev/null) || true
    elif command -v kdialog >/dev/null 2>&1; then
        FILE=$(kdialog --getopenfilename "$HOME" "*.exe *.EXE|Windows Executables" 2>/dev/null) || true
    else
        notify-send "PE Loader" "No file picker available (install zenity)" -i dialog-error
        exit 1
    fi
fi

if [ -z "$FILE" ]; then
    exit 0  # user cancelled
fi

BASENAME=$(basename "$FILE")
DIRNAME=$(dirname "$FILE")

# Validate it looks like a PE file (check MZ header)
if ! head -c2 "$FILE" 2>/dev/null | grep -q "MZ"; then
    notify-send "PE Loader" "'$BASENAME' does not appear to be a valid Windows executable" -i dialog-error
    exit 1
fi

notify-send "PE Loader" "Launching $BASENAME..." -i application-x-executable -t 3000

# Run in a terminal so the user can see output
if command -v terminator >/dev/null 2>&1; then
    exec terminator --working-directory="$DIRNAME" -e "peloader '$FILE'; echo; read -p 'Press Enter to close...'" --title="PE: $BASENAME"
elif command -v xfce4-terminal >/dev/null 2>&1; then
    exec xfce4-terminal --working-directory="$DIRNAME" -e "bash -c \"peloader '$FILE'; echo; read -p 'Press Enter to close...'\"" --title="PE: $BASENAME"
else
    exec xterm -title "PE: $BASENAME" -e "cd '$DIRNAME' && peloader '$FILE'; echo; read -p 'Press Enter to close...'"
fi
AIRUNEXE

    # .desktop file for ai-run-exe (shows in application menu)
