    # --- NetworkManager applet — system-wide XDG autostart ---
    # NOTE: /etc/xdg/autostart/nm-applet.desktop is already provided by
    # network-manager-applet package. We only install the per-user skel copy above.

    # --- First-login experience script (runs once per user) ---
    install -d "$pkgdir/usr/lib/ai-arch"
    install -Dm755 /dev/stdin "$pkgdir/usr/lib/ai-arch/first-login.sh" <<'FIRSTLOGIN'
#!/bin/bash
# AI Arch Linux — polished first-login experience (runs once)
MARKER="$HOME/.cache/ai-arch-welcomed"
[ -f "$MARKER" ] && exit 0
mkdir -p "$HOME/.cache"

# 1. XDG user directories
command -v xdg-user-dirs-update &>/dev/null && xdg-user-dirs-update
for d in Documents Downloads Music Pictures Videos Desktop; do
    mkdir -p "$HOME/$d"
done

# 2. Verify desktop shortcuts are present and executable
if [ -d "$HOME/Desktop" ]; then
    for f in "$HOME/Desktop"/*.desktop; do
        [ -f "$f" ] || continue
        chmod +x "$f"
        command -v gio &>/dev/null && gio set "$f" metadata::trusted true 2>/dev/null
    done
fi

# 3. Ensure wallpaper is applied
if command -v xfconf-query &>/dev/null; then
    for mon in Virtual-1 Virtual1 HDMI-1 DP-1 eDP-1; do
        xfconf-query -c xfce4-desktop \
            -p "/backdrop/screen0/monitor${mon}/workspace0/last-image" \
            -s /usr/share/backgrounds/ai-arch/default.svg 2>/dev/null
    done
fi

# 4. Wait for notification daemon to be ready
sleep 5

# 5. Welcome notification (10 seconds, shown once)
ICON=/usr/share/icons/hicolor/scalable/apps/archwindows-logo.svg
[ -f "$ICON" ] || ICON=computer
notify-send -i "$ICON" -t 10000 \
    "Welcome to AI Arch Linux" \
    "Your AI-powered desktop is ready.\nPress Super to open the Start menu.\nRight-click desktop for quick actions."

# 6. Open a terminal on first login (shows fastfetch via .bashrc)
if command -v terminator &>/dev/null; then
    terminator &
fi

# Mark complete — never run again
touch "$MARKER"
FIRSTLOGIN

