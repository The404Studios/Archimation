    def _refresh_monitor(self):
        self.mon_spinner.set_visible(True)
        self.mon_spinner.start()
        def do():
            cpu = read_cpu_usage()
            mu, mt, mp = read_mem_usage()
            du, dt_d, dp = read_disk_usage("/")
            audit = api_call("GET", "/audit/recent")
            GLib.idle_add(self._update_monitor,
                          cpu, mu, mt, mp,
                          du, dt_d, dp, audit)
        threading.Thread(target=do, daemon=True).start()

    def _update_monitor(self, cpu, mu, mt, mp,
                        du, dt_d, dp, audit):
        self.mon_spinner.stop()
        self.mon_spinner.set_visible(False)

        if cpu >= 0:
            self.cpu_row.set_subtitle(f"{cpu}%")
            self.cpu_bar.set_value(min(cpu, 100))
        else:
            self.cpu_row.set_subtitle("Unavailable")

        if mt > 0:
            self.mem_row.set_subtitle(
                f"{mu} MB / {mt} MB ({mp}%)")
            self.mem_bar.set_value(min(mp, 100))
        else:
            self.mem_row.set_subtitle("Unavailable")

        if dt_d > 0:
            self.disk_row.set_subtitle(
                f"{du} GB / {dt_d} GB ({dp}%)")
            self.disk_bar.set_value(min(dp, 100))
        else:
            self.disk_row.set_subtitle("Unavailable")

        if self.auto_running:
            self.tasks_row.set_subtitle(
                "1 automation task running")
        else:
            self.tasks_row.set_subtitle(
                "No tasks running")

        _clear_listbox(self.audit_list)
        if "error" in audit:
            row = Adw.ActionRow(
                title="Could not fetch audit log",
                subtitle=audit.get("error", ""))
            row.add_prefix(Gtk.Image.new_from_icon_name(
                "dialog-warning-symbolic"))
            self.audit_list.append(row)
        else:
            entries = (
                audit if isinstance(audit, list)
                else audit.get("entries",
                     audit.get("events", [])))
            if not entries:
                row = Adw.ActionRow(
                    title="No recent audit entries",
                    subtitle="Audit log is empty")
                self.audit_list.append(row)
            else:
                for e in entries[:25]:
                    if isinstance(e, dict):
                        et = e.get("type",
                             e.get("event", "unknown"))
                        tm = e.get("timestamp",
                             e.get("time", ""))
                        dt = e.get("detail",
                             e.get("message",
                             e.get("description", "")))
                        row = Adw.ActionRow(
                            title=str(et),
                            subtitle=f"{tm}  {dt}"
                                     .strip())
                    else:
                        row = Adw.ActionRow(
                            title=str(e), subtitle="")
                    row.add_prefix(
                        Gtk.Image.new_from_icon_name(
                            "document-open-recent"
                            "-symbolic"))
                    self.audit_list.append(row)

    # == Apps ==============================================================
    def _page_apps(self):
        _m = self._page_margin
        _sp = 6 if self._compact else 12
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL,
                       spacing=_sp)
        page.set_margin_start(_m); page.set_margin_end(_m)
        page.set_margin_top(self._page_top)

        t = Gtk.Label(label="Apps")
        t.add_css_class("title-2" if self._compact else "title-1")
        t.set_halign(Gtk.Align.START); page.append(t)

        self.app_search = Gtk.SearchEntry()
        self.app_search.set_placeholder_text(
            "Search installed apps...")
        self.app_search.connect("search-changed",
            self._on_app_filter)
        page.append(self.app_search)
        self._app_filter = ""

        sw = Gtk.ScrolledWindow(); sw.set_vexpand(True)
        self.app_list = Gtk.ListBox()
        self.app_list.set_selection_mode(
            Gtk.SelectionMode.NONE)
        self.app_list.add_css_class("boxed-list")
        sw.set_child(self.app_list); page.append(sw)

        self.app_count_lbl = Gtk.Label(label="")
        self.app_count_lbl.add_css_class("caption")
        self.app_count_lbl.add_css_class("dim-label")
        self.app_count_lbl.set_halign(Gtk.Align.START)
        page.append(self.app_count_lbl)
        self._app_data = []
        self._load_apps()
        return page

    def _on_app_filter(self, entry):
        self._app_filter = (
            entry.get_text().strip().lower())
        self._render_apps()

    def _load_apps(self):
        _clear_listbox(self.app_list)
        apps = []
        dirs = [
            "/usr/share/applications",
            os.path.expanduser(
                "~/.local/share/applications")]
        for d in dirs:
            if not os.path.isdir(d):
                continue
            for f in sorted(os.listdir(d)):
                if not f.endswith(".desktop"):
                    continue
                path = os.path.join(d, f)
                name = exe = icon = atype = None
                nodisplay = False
                try:
                    with open(path) as fh:
                        for ln in fh:
                            ln = ln.strip()
                            if (ln.startswith("Name=")
                                    and name is None):
                                name = ln[5:]
                            elif ln.startswith("Exec="):
                                exe = (ln[5:]
                                    .split("%")[0]
                                    .strip())
                            elif ln.startswith("Icon="):
                                icon = ln[5:]
                            elif ln.startswith(
                                    "Terminal=true"):
                                atype = "CLI"
                            elif ln.startswith(
                                    "NoDisplay=true"):
                                nodisplay = True
                except Exception:
                    continue
                if nodisplay or not name or not exe:
                    continue
                if atype is None:
                    atype = "GUI"
                apps.append((name, exe,
                    icon or "application-x-executable",
                    atype))
        seen = set()
        deduped = []
        for name, exe, icon, atype in apps:
            if name in seen:
                continue
            seen.add(name)
            deduped.append((name, exe, icon, atype))
        self._app_data = deduped
        self._render_apps()

    def _render_apps(self):
        _clear_listbox(self.app_list)
        data = self._app_data
        if self._app_filter:
            flt = self._app_filter
            data = [(n, e, i, t) for n, e, i, t
                    in data if flt in n.lower()
                    or flt in e.lower()]
        for name, exe, icon, atype in data:
            row = Adw.ActionRow(
                title=name,
                subtitle=f"{atype} \u2014 {exe}")
            row.add_prefix(
                Gtk.Image.new_from_icon_name(icon))
            launch = Gtk.Button(label="Launch")
            launch.set_valign(Gtk.Align.CENTER)
            launch.add_css_class("suggested-action")
            launch.connect("clicked",
                self._on_launch_app, exe, name)
            row.add_suffix(launch)
            self.app_list.append(row)
        total = len(self._app_data)
        shown = len(data)
        if self._app_filter:
            self.app_count_lbl.set_text(
                f"Showing {shown} of {total} apps")
        else:
            self.app_count_lbl.set_text(
                f"{shown} apps")

    def _on_launch_app(self, _b, exe, name="App"):
        try:
            subprocess.Popen(
                exe, shell=True,
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL)
            self._show_toast(f"Launched {name}")
        except Exception as e:
            self._show_toast(
                f"Failed to launch {name}: {e}", 5)

