    install -Dm755 /dev/stdin "$pkgdir/etc/profile.d/pe-compat-setup.sh" <<'FIRSTRUN'
#!/bin/bash
# Create PE compat directory structure on first login
PE_PREFIX="$HOME/.pe-compat"
if [ ! -d "$PE_PREFIX" ]; then
    mkdir -p "$PE_PREFIX/drives/c/Windows/System32"
    mkdir -p "$PE_PREFIX/drives/c/Program Files"
    mkdir -p "$PE_PREFIX/drives/c/Program Files (x86)"
    mkdir -p "$PE_PREFIX/drives/c/Users/$USER/AppData/Local"
    mkdir -p "$PE_PREFIX/drives/c/Users/$USER/AppData/Roaming"
    mkdir -p "$PE_PREFIX/drives/c/Users/$USER/Documents"
    mkdir -p "$PE_PREFIX/drives/c/Users/$USER/Desktop"
    mkdir -p "$PE_PREFIX/drives/c/Users/$USER/Downloads"
    mkdir -p "$PE_PREFIX/drives/c/Games"
    mkdir -p "$PE_PREFIX/dxvk"
    mkdir -p "$PE_PREFIX/logs"
    mkdir -p "$PE_PREFIX/registry"
fi

# Create Games directory in home too (for easy access)
mkdir -p "$HOME/Games" 2>/dev/null

# Ensure Desktop directory exists and shortcuts are trusted
if [ -d "$HOME/Desktop" ]; then
    for f in "$HOME/Desktop"/*.desktop; do
        [ -f "$f" ] && chmod +x "$f" 2>/dev/null
        # XFCE trusts .desktop files via gio metadata
        command -v gio &>/dev/null && gio set "$f" metadata::trusted true 2>/dev/null
    done
fi
FIRSTRUN

    # ==========================================================================
    # UNIVERSAL PACKAGE INSTALLER — install .deb, .rpm, .pkg.tar.zst, tarballs
    # ==========================================================================
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-pkg-install" <<'PKGINSTALL'
#!/bin/bash
# ai-pkg-install - Universal package installer for ArchWindows
set -euo pipefail

FILE="${1:?Usage: ai-pkg-install <package-file>}"
FILE="$(realpath "$FILE")"
BASENAME="$(basename "$FILE")"
HAS_DISPLAY="${DISPLAY:+yes}"

gui_confirm() {
    if [ -n "$HAS_DISPLAY" ] && command -v zenity &>/dev/null; then
        zenity --question --title="$1" --text="$2" --width=400 2>/dev/null
    else
        echo "$2"; read -rp "Continue? [y/N] " ans; [[ "$ans" =~ ^[Yy] ]]
    fi
}

gui_info() {
    if [ -n "$HAS_DISPLAY" ] && command -v zenity &>/dev/null; then
        zenity --info --title="$1" --text="$2" --width=400 2>/dev/null
    else
        echo "$2"
    fi
}

gui_error() {
    if [ -n "$HAS_DISPLAY" ] && command -v zenity &>/dev/null; then
        zenity --error --title="$1" --text="$2" --width=400 2>/dev/null
    else
        echo "ERROR: $2" >&2
    fi
}

case "$BASENAME" in
    *.pkg.tar.zst|*.pkg.tar.xz|*.pkg.tar.gz)
        gui_confirm "Install Package" "Install Arch package:\n$BASENAME?" || exit 0
        if [ -n "$HAS_DISPLAY" ] && command -v xterm &>/dev/null; then
            xterm -e sudo pacman -U --noconfirm "$FILE"
        else
            sudo pacman -U "$FILE"
        fi
        gui_info "Done" "$BASENAME installed successfully"
        ;;
    *.deb)
        gui_confirm "Install .deb" "Install Debian package:\n$BASENAME?\n\nFiles will be extracted and installed." || exit 0
        TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$TMPDIR"' EXIT
        if command -v dpkg-deb &>/dev/null; then
            dpkg-deb -x "$FILE" "$TMPDIR/root"
        else
            cd "$TMPDIR" && ar x "$FILE"
            mkdir -p "$TMPDIR/root"
            for d in data.tar.*; do [ -f "$d" ] && tar xf "$d" -C "$TMPDIR/root"; done
        fi
        sudo cp -a "$TMPDIR/root/." /
        sudo ldconfig 2>/dev/null || true
        sudo update-desktop-database /usr/share/applications 2>/dev/null || true
        gui_info "Done" "$BASENAME installed successfully"
        ;;
    *.rpm)
        gui_confirm "Install .rpm" "Install RPM package:\n$BASENAME?" || exit 0
        TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$TMPDIR"' EXIT
        mkdir -p "$TMPDIR/root"
        if command -v rpm2cpio &>/dev/null; then
            rpm2cpio "$FILE" | (cd "$TMPDIR/root" && cpio -idm 2>/dev/null)
        else
            gui_error "Error" "rpm2cpio not found. Install rpm-tools first."; exit 1
        fi
        sudo cp -a "$TMPDIR/root/." /
        sudo ldconfig 2>/dev/null || true
        gui_info "Done" "$BASENAME installed successfully"
        ;;
    *.tar.gz|*.tar.xz|*.tar.bz2|*.tar.zst|*.tgz|*.txz)
        if [ -n "$HAS_DISPLAY" ] && command -v zenity &>/dev/null; then
            ACTION=$(zenity --list --title="Extract Archive" \
                --text="What to do with:\n$BASENAME" \
                --column="Action" --column="Description" \
                "here" "Extract to current directory" \
                "opt" "Extract to /opt/" \
                "home" "Extract to ~/Downloads/" \
                --width=450 --height=250 2>/dev/null) || exit 0
        else
            ACTION="here"
        fi
        case "$ACTION" in
            here) tar xf "$FILE" -C "$(dirname "$FILE")"; gui_info "Done" "Extracted to $(dirname "$FILE")" ;;
            opt)  NAME="${BASENAME%%.*}"; sudo mkdir -p "/opt/$NAME"; sudo tar xf "$FILE" -C "/opt/$NAME" --strip-components=1; gui_info "Done" "Extracted to /opt/$NAME" ;;
            home) tar xf "$FILE" -C "$HOME/Downloads/"; gui_info "Done" "Extracted to ~/Downloads/" ;;
        esac
        ;;
    *)
        gui_error "Unknown" "Cannot install: $BASENAME\nSupported: .deb, .rpm, .pkg.tar.zst, .tar.gz"
        exit 1
        ;;
esac
PKGINSTALL

