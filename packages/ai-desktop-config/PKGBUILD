    # --- AI session logout script (clean shutdown of AI services) ---
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-session-logout" <<'LOGOUT'
#!/bin/bash
# Clean shutdown of AI services before logout
# Stop the AI tray indicator
pkill -f ai-tray-indicator 2>/dev/null
# Notify the daemon we're logging out
curl -s -X POST http://127.0.0.1:8420/system/notify \
    -H "Content-Type: application/json" \
    -d '{"message":"User session ending"}' 2>/dev/null || true
# Let XFCE handle the actual logout
xfce4-session-logout "$@"
LOGOUT

    # --- Polkit rule: allow users group to shutdown/reboot without password ---
    install -Dm644 /dev/stdin "$pkgdir/etc/polkit-1/rules.d/49-ai-shutdown.rules" <<'POLKIT'
polkit.addRule(function(action, subject) {
    if ((action.id == "org.freedesktop.login1.power-off" ||
         action.id == "org.freedesktop.login1.power-off-multiple-sessions" ||
         action.id == "org.freedesktop.login1.reboot" ||
         action.id == "org.freedesktop.login1.reboot-multiple-sessions" ||
         action.id == "org.freedesktop.login1.suspend" ||
         action.id == "org.freedesktop.login1.suspend-multiple-sessions" ||
         action.id == "org.freedesktop.login1.hibernate" ||
         action.id == "org.freedesktop.login1.hibernate-multiple-sessions") &&
        subject.isInGroup("users")) {
        return polkit.Result.YES;
    }
});
POLKIT

