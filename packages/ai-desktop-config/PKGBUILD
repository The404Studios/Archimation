            row.set_child(bx); row._page = name
            self.sidebar.append(row)

        sb_box.append(self.sidebar)
        sb_page.set_child(sb_box)

        # --- pages ---
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(
            Gtk.StackTransitionType.CROSSFADE)
        self.stack.add_named(
            self._page_automations(), "Automations")
        self.stack.add_named(self._page_macros(), "Macros")
        self.stack.add_named(
            self._page_processes(), "Processes")
        self.stack.add_named(self._page_monitor(), "Monitor")
        self.stack.add_named(self._page_apps(), "Apps")
        self.stack.add_named(
            self._page_settings(), "Settings")

        ct_page = Adw.NavigationPage(title="Automations")
        ct_page.set_child(self.stack)
        split.set_sidebar(sb_page)
        split.set_content(ct_page)
        outer.append(split)

        # --- Status Bar at bottom ---
        _sb_sp = 8 if self._compact else 16
        _sb_side = 6 if self._compact else 12
        self.status_bar = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL, spacing=_sb_sp)
        self.status_bar.set_margin_start(_sb_side)
        self.status_bar.set_margin_end(_sb_side)
        self.status_bar.set_margin_top(2 if self._compact else 4)
        self.status_bar.set_margin_bottom(2 if self._compact else 4)
        self.status_bar.add_css_class("toolbar")
        self.status_bar.add_css_class("contusion-statusbar")

        self.sb_conn_icon = Gtk.Image.new_from_icon_name(
            "network-offline-symbolic")
        self.sb_conn_label = Gtk.Label(label="Daemon: Checking...")
        self.sb_conn_label.add_css_class("compact-label" if self._compact else "caption")
        conn_box = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        conn_box.append(self.sb_conn_icon)
        conn_box.append(self.sb_conn_label)
        self.status_bar.append(conn_box)
        self.status_bar.append(
            Gtk.Separator(orientation=Gtk.Orientation.VERTICAL))

        self.sb_trust_label = Gtk.Label(label="Trust: Unknown")
        self.sb_trust_label.add_css_class("compact-label" if self._compact else "caption")
        trust_box = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        trust_box.append(Gtk.Image.new_from_icon_name(
            "security-high-symbolic"))
        trust_box.append(self.sb_trust_label)
        self.status_bar.append(trust_box)
        self.status_bar.append(
            Gtk.Separator(orientation=Gtk.Orientation.VERTICAL))

        self.sb_macros_label = Gtk.Label(label="Macros: 0")
        self.sb_macros_label.add_css_class("compact-label" if self._compact else "caption")
        macro_box = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        macro_box.append(Gtk.Image.new_from_icon_name(
            "media-record-symbolic"))
        macro_box.append(self.sb_macros_label)
        self.status_bar.append(macro_box)
        self.status_bar.append(
            Gtk.Separator(orientation=Gtk.Orientation.VERTICAL))

        self.sb_last_action = Gtk.Label(
            label="Last action: Never")
        self.sb_last_action.add_css_class("compact-label" if self._compact else "caption")
        self.sb_last_action.set_hexpand(True)
        self.sb_last_action.set_halign(Gtk.Align.END)
        self.status_bar.append(self.sb_last_action)

        outer.append(self.status_bar)
        self.toast_overlay.set_child(outer)
        self.win.set_content(self.toast_overlay)

        self.sidebar.connect("row-selected", self._on_nav)
        self.sidebar.select_row(self.sidebar.get_row_at_index(0))
        self.win.present()

        self._check_connection()
        GLib.timeout_add_seconds(5, self._auto_refresh)
        GLib.timeout_add_seconds(3,
            self._monitor_tick)
        self._update_status_bar()

    # == Toast Helper =====================================================
    def _show_toast(self, message, timeout=3):
        toast = Adw.Toast(title=message)
        toast.set_timeout(timeout)
        self.toast_overlay.add_toast(toast)

    def _set_result(self, text):
        """Set the automation result TextView content."""
        buf = self.auto_result_tv.get_buffer()
        buf.set_text(text if text else "")

    # == Status Bar =======================================================
    def _update_status_bar(self):
        if self.daemon_online:
            self.sb_conn_icon.set_from_icon_name(
                "network-idle-symbolic")
            self.sb_conn_label.set_text("Daemon: Online")
            self.sb_conn_label.remove_css_class(
                "status-offline")
            self.sb_conn_label.add_css_class(
                "status-online")
        else:
            self.sb_conn_icon.set_from_icon_name(
                "network-offline-symbolic")
            self.sb_conn_label.set_text("Daemon: Offline")
            self.sb_conn_label.remove_css_class(
                "status-online")
            self.sb_conn_label.add_css_class(
                "status-offline")
        self.sb_trust_label.set_text(
            f"Trust: {self.trust_level}")
        self.sb_macros_label.set_text(
            f"Macros: {len(load_macros())}")
        self.sb_last_action.set_text(
            f"Last action: {self.last_action_ts}")

    def _on_nav(self, lb, row):
        if row and hasattr(row, '_page'):
            self.stack.set_visible_child_name(row._page)

    # == Automations ======================================================
