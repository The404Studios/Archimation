#!/usr/bin/env python3
"""AI Chat Assistant - command router for the AI control daemon."""
import os, json, threading, re
os.environ.setdefault("GDK_BACKEND", "x11")
os.environ.setdefault("GSK_RENDERER", "cairo")
import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib, Pango, Gdk
import urllib.request, urllib.error


def _scaled_window_size(base_w, base_h, max_frac=0.5):
    """Compute window size that respects screen geometry."""
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                geom = monitors.get_item(0).get_geometry()
                if geom.height <= 768:
                    frac = 0.80
                elif geom.height <= 900:
                    frac = 0.70
                else:
                    frac = max_frac
                w = max(350, min(base_w, int(geom.width * frac)))
                h = max(300, min(base_h, int(geom.height * frac)))
                return w, h
    except Exception:
        pass
    return base_w, base_h


def _is_compact_screen():
    """Return True if the screen is small (<=900p) and UI should be compact."""
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                return monitors.get_item(0).get_geometry().height <= 900
    except Exception:
        pass
    return True  # Default to compact for safety

API = "http://localhost:8420"
HELP = """Available commands:
  install <pkg>       Install a package
  remove <pkg>        Remove a package
  start <svc>         Start a service
  stop <svc>          Stop a service
  restart <svc>       Restart a service
  status <svc>        Show service status
  disk                Show disk usage
  cpu / memory        Show system info
  health              Check AI daemon health
  help                Show this message"""

ROUTES = [
    (r"^install\s+(.+)",   lambda m: req("POST", "/auto/package", {"action":"install","name":m.group(1)})),
    (r"^remove\s+(.+)",    lambda m: req("POST", "/auto/package", {"action":"remove","name":m.group(1)})),
    (r"^start\s+(.+)",     lambda m: req("POST", "/auto/service", {"action":"start","name":m.group(1)})),
    (r"^stop\s+(.+)",      lambda m: req("POST", "/auto/service", {"action":"stop","name":m.group(1)})),
    (r"^restart\s+(.+)",   lambda m: req("POST", "/auto/service", {"action":"restart","name":m.group(1)})),
    (r"^status\s+(.+)",    lambda m: req("POST", "/auto/service", {"action":"status","name":m.group(1)})),
    (r"^(disk|df)",        lambda m: req("GET",  "/system/info")),
    (r"^(cpu|mem|sys)",    lambda m: req("GET",  "/system/info")),
    (r"^health",           lambda m: req("GET",  "/health")),
    (r"^help",             lambda m: HELP),
]

def req(method, path, body=None):
    try:
        data = json.dumps(body).encode() if body else None
        r = urllib.request.Request(API + path, data=data, method=method,
            headers={"Content-Type":"application/json"} if data else {})
        with urllib.request.urlopen(r, timeout=10) as resp:
            return json.dumps(json.loads(resp.read()), indent=2)
    except urllib.error.HTTPError as e:
        return f"Error {e.code}: {e.read().decode()[:200]}"
    except Exception as e:
        return f"Error: {e}"

def route(text):
    text = text.strip()
    if not text:
        return None
    for pattern, handler in ROUTES:
        m = re.match(pattern, text, re.IGNORECASE)
        if m:
            return handler(m)
    return f"Unknown command: {text}\nType 'help' for available commands."

class ChatWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        _compact = _is_compact_screen()
        _m = 4 if _compact else 8
        _tvp = 4 if _compact else 8
        _tvs = 6 if _compact else 12
        w, h = _scaled_window_size(500, 600)
        super().__init__(application=app, title="AI Assistant", default_width=w, default_height=h)
        if _compact:
            try:
                _css = Gtk.CssProvider()
                _css.load_from_data(b"headerbar.compact{min-height:32px;padding:2px 0}headerbar.compact button{min-height:24px;padding:2px 6px}")
                Gtk.StyleContext.add_provider_for_display(Gdk.Display.get_default(), _css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            except Exception:
                pass
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.set_content(box)
        # Header
        hdr = Adw.HeaderBar()
        if _compact:
            hdr.add_css_class("compact")
        box.append(hdr)
        # Chat log
        sw = Gtk.ScrolledWindow(vexpand=True, hscrollbar_policy=Gtk.PolicyType.NEVER)
        self.log = Gtk.TextView(editable=False, wrap_mode=Gtk.WrapMode.WORD_CHAR,
                                cursor_visible=False, top_margin=_tvp, bottom_margin=_tvp,
                                left_margin=_tvs, right_margin=_tvs)
        self.log.get_buffer().create_tag("bold", weight=Pango.Weight.BOLD)
        self.log.get_buffer().create_tag("mono", family="monospace", scale=0.85 if _compact else 0.9)
        sw.set_child(self.log)
        box.append(sw)
        # Input row
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4, margin_start=_m,
                      margin_end=_m, margin_top=2 if _compact else 4, margin_bottom=_m)
        self.entry = Gtk.Entry(hexpand=True, placeholder_text="Type a command...")
        self.entry.connect("activate", self._on_send)
        row.append(self.entry)
        btn = Gtk.Button(label="Execute")
        btn.add_css_class("suggested-action")
        btn.connect("clicked", self._on_send)
        row.append(btn)
        box.append(row)
        self._append("AI Assistant ready. Type 'help' for commands.\n", "bold")

    def _append(self, text, tag=None):
        buf = self.log.get_buffer()
        end = buf.get_end_iter()
        if tag:
            buf.insert_with_tags_by_name(end, text, tag)
        else:
            buf.insert(end, text)
        GLib.idle_add(lambda: self.log.scroll_to_mark(buf.get_insert(), 0, False, 0, 0))

    def _on_send(self, _w):
        text = self.entry.get_text().strip()
        if not text:
            return
        self._append(f"\n> {text}\n", "bold")
        self.entry.set_text("")
        self.entry.set_sensitive(False)
        threading.Thread(target=self._run, args=(text,), daemon=True).start()

    def _run(self, text):
        result = route(text)
        GLib.idle_add(self._show_result, result or "")

    def _show_result(self, text):
        self._append(text + "\n", "mono")
        self.entry.set_sensitive(True)
        self.entry.grab_focus()

class App(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.aiarch.chat")
    def do_activate(self):
        win = ChatWindow(self)
        win.present()

def main():
    App().run(None)

if __name__ == "__main__":
    main()
