    # ------------------------------------------------------------------
    # Finish: apply settings and mark wizard complete
    # ------------------------------------------------------------------
    def _finish_wizard(self):
        """Apply chosen settings and mark the wizard as done."""
        # Apply theme preference via xfconf
        dark = self._dark_switch.get_active()
        try:
            theme = "Adwaita-dark" if dark else "Adwaita"
            subprocess.Popen(
                ["xfconf-query", "-c", "xsettings", "-p", "/Net/ThemeName", "-s", theme],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            icon_theme = "Papirus-Dark" if dark else "Papirus-Light"
            subprocess.Popen(
                ["xfconf-query", "-c", "xsettings", "-p", "/Net/IconThemeName", "-s", icon_theme],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
        except Exception:
            pass

        # Enable or disable AI daemon
        ai_enabled = self._ai_switch.get_active()
        try:
            action = "enable" if ai_enabled else "disable"
            subprocess.Popen(
                ["systemctl", "--user", action, "--now", "ai-control.service"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
        except Exception:
            pass

        # Mark wizard as completed
        marker_dir = os.path.expanduser("~/.config/ai-arch")
        os.makedirs(marker_dir, exist_ok=True)
        marker = os.path.join(marker_dir, "first-boot-done")
        try:
            with open(marker, "w") as f:
                f.write("done\n")
        except Exception:
            pass

        self.win.close()


