[Unit]
Description=PE-Compat Windows-Style Firewall
Documentation=man:pe-compat-firewall(8)
After=network.target nftables.service local-fs.target
Wants=nftables.service
# Install nft rules before any PE application binds a socket.  The broker
# itself doesn't expose network services but PE apps launched under SCM
# do, and we want the policy in place first to avoid leaky-first-packet.
Before=pe-objectd.service
Conflicts=ufw.service firewalld.service
# Skip entirely if nft binary is missing (package not installed)
ConditionPathExists=/usr/sbin/nft
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
# Ensure nf_tables kernel module is loaded before applying rules.
# Prefix with - so failure is non-fatal (module may be built-in).
ExecStartPre=-/usr/sbin/modprobe -q nf_tables
ExecStart=/usr/bin/python3 /usr/lib/pe-compat/firewall/backend/nft_manager.py --daemon
ExecReload=/bin/kill -HUP $MAINPID
# Firewall startup: parse rules json, apply nft ruleset, open netlink.
# Bounded 30s — rule compilation is O(rules) and large policies exist.
TimeoutStartSec=30
# Shutdown: close netlink + flush rules.  10s is generous.
TimeoutStopSec=10
KillSignal=SIGTERM
KillMode=mixed

# Run as root for nftables access
User=root
Group=root

# Security hardening
ProtectSystem=strict
ReadWritePaths=/var/lib/pe-compat/firewall /var/log/pe-compat /run/pe-compat
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_SYS_PTRACE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_SYS_PTRACE

# Restart policy
Restart=on-failure
RestartSec=5

# TODO: enable WatchdogSec=60 after nft_manager.py's netlink loop sends
# WATCHDOG=1 periodically (and unit is flipped to Type=notify).
# WatchdogSec=60

# Runtime directory for socket/pid
RuntimeDirectory=pe-compat
RuntimeDirectoryMode=0755

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pe-compat-firewall

[Install]
WantedBy=multi-user.target
