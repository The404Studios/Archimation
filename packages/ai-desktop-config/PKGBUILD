    # --- Panel resolution-adapt: scale panel/tray/clock for larger screens ---
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-panel-adapt" <<'PANELADAPT'
#!/bin/bash
# ai-panel-adapt - Adjust XFCE panel settings based on screen resolution.
# Defaults in xfce4-panel.xml target 1366x768 (small). This script scales
# up for 1440x900, 1920x1080, and 2560+.
# Runs once at login via XDG autostart.

sleep 2  # wait for panel to load

command -v xfconf-query &>/dev/null || exit 0

# Detect primary screen height
SCREEN_H=768
if command -v xrandr &>/dev/null; then
    RES=$(xrandr 2>/dev/null | awk '/ connected.*[0-9]+x[0-9]+/{for(i=1;i<=NF;i++) if($i~/^[0-9]+x[0-9]+/) {split($i,a,"[x+]"); print a[2]; exit}}')
    [ -n "$RES" ] && SCREEN_H="$RES"
fi

XP="xfconf-query -c xfce4-panel"

if [ "$SCREEN_H" -ge 1440 ]; then
    # 2560x1440 and above (HiDPI tier)
    $XP -p /panels/panel-1/size -s 40
    $XP -p /panels/panel-1/icon-size -s 24
    $XP -p /plugins/plugin-5/icon-size -s 24
    $XP -p /plugins/plugin-3/max-button-length -s 260
    # Clock: show date + time on large screens
    $XP -p /plugins/plugin-10/digital-layout -s 3
    $XP -p /plugins/plugin-10/digital-date-format -s "%b %d" -n
    $XP -p /plugins/plugin-10/digital-date-font -s "Noto Sans 9" -n
elif [ "$SCREEN_H" -ge 1080 ]; then
    # 1920x1080 (Full HD)
    $XP -p /panels/panel-1/size -s 36
    $XP -p /panels/panel-1/icon-size -s 22
    $XP -p /plugins/plugin-5/icon-size -s 22
    $XP -p /plugins/plugin-3/max-button-length -s 220
    # Clock: show date + time
    $XP -p /plugins/plugin-10/digital-layout -s 3
    $XP -p /plugins/plugin-10/digital-date-format -s "%b %d" -n
    $XP -p /plugins/plugin-10/digital-date-font -s "Noto Sans 8" -n
elif [ "$SCREEN_H" -ge 900 ]; then
    # 1440x900 (medium)
    $XP -p /panels/panel-1/size -s 30
    $XP -p /panels/panel-1/icon-size -s 18
    $XP -p /plugins/plugin-5/icon-size -s 20
    $XP -p /plugins/plugin-3/max-button-length -s 200
    # Clock: time only (compact)
    $XP -p /plugins/plugin-10/digital-layout -s 2
fi
# <= 768: defaults from xfce4-panel.xml are already correct (28px panel,
# 16px icons, 18px tray, time-only clock, 180px task buttons)

exit 0
PANELADAPT

    install -Dm644 /dev/stdin "$pkgdir/etc/skel/.config/autostart/ai-panel-adapt.desktop" <<'PANELADAPT_AUTO'
[Desktop Entry]
Name=Panel Resolution Adapt
Exec=/usr/bin/ai-panel-adapt
Terminal=false
Type=Application
X-GNOME-Autostart-enabled=true
NoDisplay=true
Comment=Scale XFCE panel for current screen resolution
PANELADAPT_AUTO

