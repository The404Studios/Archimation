#!/usr/bin/env python3
"""AI Arch Linux - First Boot Welcome Wizard

A GTK4/Adwaita carousel-based wizard that guides new users through
initial system configuration on their very first login.
"""

import gi
import os
import subprocess
import json
import threading

gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib, Gdk, Gio

os.environ.setdefault("GDK_BACKEND", "x11")
os.environ.setdefault("GSK_RENDERER", "cairo")

API = "http://127.0.0.1:8420"


def _api_call(method, endpoint, data=None, timeout=8):
    """Thread-safe HTTP call to the AI control daemon."""
    import urllib.request, urllib.error
    try:
        url = f"{API}{endpoint}"
        body = json.dumps(data).encode() if data else None
        req = urllib.request.Request(url, data=body, method=method)
        req.add_header("Content-Type", "application/json")
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode())
    except Exception as e:
        return {"error": str(e)}


class FirstBootWizard(Adw.Application):
    """Multi-page welcome wizard for first-time users."""

    def __init__(self):
        super().__init__(application_id="org.ai_arch.first_boot")
        self.connect("activate", self._on_activate)
        self._wifi_networks = []
        self._selected_ssid = None

    # ------------------------------------------------------------------
    # Application activation
    # ------------------------------------------------------------------
    def _on_activate(self, app):
        self._compact = False
        try:
            display = Gdk.Display.get_default()
            if display:
                mon0 = display.get_monitors().get_item(0)
                if mon0 and mon0.get_geometry().height <= 900:
                    self._compact = True
        except Exception:
            self._compact = True

        if self._compact:
            try:
                _css = Gtk.CssProvider()
                _css.load_from_data(b"headerbar.compact{min-height:32px;padding:2px 0}headerbar.compact button{min-height:24px;padding:2px 6px}")
                Gtk.StyleContext.add_provider_for_display(Gdk.Display.get_default(), _css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            except Exception:
                pass

        self.win = Adw.ApplicationWindow(application=app)
        self.win.set_title("Welcome to AI Arch Linux")

        # Scale window to screen geometry
        try:
            display = Gdk.Display.get_default()
            if display:
                mon = display.get_monitors().get_item(0)
                geom = mon.get_geometry()
                w = min(600, int(geom.width * 0.5))
                h = min(500, int(geom.height * 0.6))
                self.win.set_default_size(w, h)
        except Exception:
            self.win.set_default_size(500, 450)

        self.toast_overlay = Adw.ToastOverlay()

        # Carousel for page navigation
        self.carousel = Adw.Carousel()
        self.carousel.set_allow_long_swipes(True)
        self.carousel.set_allow_mouse_drag(True)
        self.carousel.connect("page-changed", self._on_page_changed)

        # Build pages
        page1 = self._make_welcome_page()
        page2 = self._make_setup_page()
        page3 = self._make_shortcuts_page()
        page4 = self._make_finish_page()

        self.carousel.append(page1)
        self.carousel.append(page2)
        self.carousel.append(page3)
        self.carousel.append(page4)

        # Carousel indicator dots
        dots = Adw.CarouselIndicatorDots(carousel=self.carousel)

        # Navigation buttons
        nav_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8 if self._compact else 12)
        nav_box.set_halign(Gtk.Align.CENTER)
        nav_box.set_margin_bottom(8 if self._compact else 16)
        nav_box.set_margin_top(4 if self._compact else 8)

        self.back_btn = Gtk.Button(label="Back")
        self.back_btn.set_sensitive(False)
        self.back_btn.connect("clicked", self._go_back)

        self.next_btn = Gtk.Button(label="Next")
        self.next_btn.add_css_class("suggested-action")
        self.next_btn.connect("clicked", self._go_next)

        nav_box.append(self.back_btn)
        nav_box.append(dots)
        nav_box.append(self.next_btn)

        # Main layout
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main_box.append(self.carousel)
        main_box.append(nav_box)

        self.toast_overlay.set_child(main_box)
        self.win.set_content(self.toast_overlay)
        self.win.present()

        # Kick off initial WiFi scan in background
        self._refresh_wifi()

    # ------------------------------------------------------------------
    # Navigation
    # ------------------------------------------------------------------
    def _on_page_changed(self, carousel, idx):
        pos = int(carousel.get_position())
        n_pages = carousel.get_n_pages()
        self.back_btn.set_sensitive(pos > 0)
        if pos == n_pages - 1:
            self.next_btn.set_label("Get Started")
            self.next_btn.remove_css_class("suggested-action")
            self.next_btn.add_css_class("suggested-action")
        else:
            self.next_btn.set_label("Next")

    def _go_back(self, _btn):
        pos = int(self.carousel.get_position())
        if pos > 0:
            prev = self.carousel.get_nth_page(pos - 1)
            self.carousel.scroll_to(prev, True)

    def _go_next(self, _btn):
        pos = int(self.carousel.get_position())
        n_pages = self.carousel.get_n_pages()
        if pos < n_pages - 1:
            nxt = self.carousel.get_nth_page(pos + 1)
            self.carousel.scroll_to(nxt, True)
        else:
            self._finish_wizard()

    # ------------------------------------------------------------------
    # Page 1: Welcome
    # ------------------------------------------------------------------
    def _make_welcome_page(self):
        _m = 16 if self._compact else 32
        _p = 12 if self._compact else 24
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6 if self._compact else 12)
        page.set_valign(Gtk.Align.CENTER)
        page.set_margin_start(_m)
        page.set_margin_end(_m)
        page.set_margin_top(_p)
        page.set_margin_bottom(_p)

        icon = Gtk.Image.new_from_icon_name("dialog-information-symbolic")
        icon.set_pixel_size(40 if self._compact else 64)
        icon.add_css_class("accent")
        page.append(icon)

        title = Gtk.Label(label="Welcome to AI Arch Linux")
        title.add_css_class("title-1")
        title.set_wrap(True)
        title.set_justify(Gtk.Justification.CENTER)
        page.append(title)

        subtitle = Gtk.Label(
            label="Your AI-powered operating system with native\nWindows application support."
        )
        subtitle.add_css_class("dim-label")
        subtitle.set_wrap(True)
        subtitle.set_justify(Gtk.Justification.CENTER)
        page.append(subtitle)

        # Feature list
        features = [
            ("brain-augmented-symbolic", "AI-powered desktop automation (Contusion)"),
            ("application-x-executable-symbolic", "Native Windows .exe execution"),
            ("security-high-symbolic", "Trust-based security system"),
            ("network-wireless-symbolic", "Full WiFi and network management"),
        ]
        feature_box = Gtk.ListBox()
        feature_box.set_selection_mode(Gtk.SelectionMode.NONE)
        feature_box.add_css_class("boxed-list")
        feature_box.set_margin_top(16)

        for icon_name, text in features:
            row = Adw.ActionRow(title=text)
            img = Gtk.Image.new_from_icon_name(icon_name)
            img.set_pixel_size(24)
            row.add_prefix(img)
            feature_box.append(row)

        page.append(feature_box)
        return page

    # ------------------------------------------------------------------
    # Page 2: Quick Setup (WiFi, theme, AI daemon)
    # ------------------------------------------------------------------
    def _make_setup_page(self):
        _m = 12 if self._compact else 24
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4 if self._compact else 8)
        page.set_margin_start(_m)
        page.set_margin_end(_m)
        page.set_margin_top(10 if self._compact else 20)
        page.set_margin_bottom(6 if self._compact else 12)

        title = Gtk.Label(label="Quick Setup")
        title.add_css_class("title-2")
        page.append(title)

        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        content.set_margin_top(8)

        # -- WiFi section --
        wifi_group = Adw.PreferencesGroup(title="WiFi Network")
        wifi_group.set_description("Select a network to connect")

        self._wifi_list = Gtk.ListBox()
        self._wifi_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self._wifi_list.add_css_class("boxed-list")
        self._wifi_list.set_placeholder(
            Gtk.Label(label="Scanning for networks...")
        )
        self._wifi_list.connect("row-selected", self._on_wifi_selected)

        wifi_group.add(self._wifi_list)

        wifi_btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        wifi_btn_box.set_halign(Gtk.Align.END)
        wifi_btn_box.set_margin_top(4)

        scan_btn = Gtk.Button(label="Rescan")
        scan_btn.connect("clicked", lambda _b: self._refresh_wifi())
        wifi_btn_box.append(scan_btn)

        self._wifi_connect_btn = Gtk.Button(label="Connect")
        self._wifi_connect_btn.add_css_class("suggested-action")
        self._wifi_connect_btn.set_sensitive(False)
        self._wifi_connect_btn.connect("clicked", self._on_wifi_connect)
        wifi_btn_box.append(self._wifi_connect_btn)

        wifi_group.add(wifi_btn_box)
        content.append(wifi_group)

