    # --- NVIDIA modprobe options ---
    install -Dm644 /dev/stdin "$pkgdir/etc/modprobe.d/nvidia.conf" <<'NVMODPROBE'
# NVIDIA module options for RTX 5070 (Blackwell)
# Framebuffer device for console rendering (simpledrm replacement)
options nvidia_drm modeset=1 fbdev=1
# Preserve VRAM across suspend/resume cycles
options nvidia NVreg_PreserveVideoMemoryAllocations=1
# Enable Dynamic Boost for improved thermal/power management
options nvidia NVreg_DynamicPowerManagement=0x02
NVMODPROBE

    # --- NVIDIA/nouveau GPU-generation auto-select ---
    # nvidia-utils ships blacklist nouveau. Override: allow nouveau on pre-Turing GPUs.
    install -Dm644 /dev/stdin "$pkgdir/etc/modprobe.d/nvidia-nouveau-compat.conf" <<'NVCOMPAT'
# Override nvidia-utils blacklist: allow nouveau on older GPUs.
# nvidia-open-dkms only supports Turing (NV160/TU*) and newer.
# Fermi, Kepler, Maxwell, Pascal need nouveau.
softdep nvidia pre: nouveau
# Do NOT blacklist nouveau -- let udev pick the right driver.
NVCOMPAT

    # Udev rule: load nvidia-drm on Turing+ (device ID >= 0x1e00), nouveau on older
    install -Dm644 /dev/stdin "$pkgdir/etc/udev/rules.d/80-nvidia-nouveau-select.rules" <<'NVUDEV'
# NVIDIA Turing+ (TU10x 1e00+, GA10x 2200+, AD10x 2600+, GB20x 2700+):
# Bind nvidia-drm. Older GPUs fall through to nouveau.
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de",   ATTR{class}=="0x030000",   ATTR{device}=="0x1e[0-9a-f][0-9a-f]|0x1f[0-9a-f][0-9a-f]|0x2[0-9a-f][0-9a-f][0-9a-f]",   RUN+="/sbin/modprobe nvidia-drm"

# For pre-Turing NVIDIA GPUs: ensure nouveau is not blocked
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de",   ATTR{class}=="0x030000",   ATTR{device}!="0x1e[0-9a-f][0-9a-f]|0x1f[0-9a-f][0-9a-f]|0x2[0-9a-f][0-9a-f][0-9a-f]",   RUN+="/sbin/modprobe nouveau"
NVUDEV

    # NVIDIA persistenced/suspend/resume services + nvidia-sleep.sh come from
    # the `nvidia-utils` package. Session 21: removed duplicate installs that
    # caused pacstrap file-conflict errors. Enable them via preset only.
    # Drop-in overrides add ConditionPathExists so they skip silently without GPU.
    install -d "$pkgdir/usr/lib/systemd/system-preset"
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system-preset/60-ai-nvidia.preset" <<'NVPRESET'
enable nvidia-persistenced.service
enable nvidia-suspend.service
enable nvidia-resume.service
NVPRESET

    # Drop-in overrides: skip NVIDIA services when no GPU is present
    for _nvsvc in nvidia-persistenced nvidia-suspend nvidia-resume; do
        install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system/${_nvsvc}.service.d/10-condition-gpu.conf" <<'NVCOND'
[Unit]
ConditionPathExists=/proc/driver/nvidia/version
NVCOND
    done

