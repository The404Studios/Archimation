        warn_box.set_halign(Gtk.Align.CENTER)
        warn_icon = Gtk.Label(label="\u26A0")
        warn_icon.add_css_class("warning-text")
        warn_box.append(warn_icon)
        warn_label = Gtk.Label(
            label="This will FORMAT the selected drive. All existing data will be lost."
        )
        warn_label.add_css_class("warning-text")
        warn_box.append(warn_label)
        page.append(warn_box)

        return page

    # ------------------------------------------------------------------
    # Page 2: Disk Selection
    # ------------------------------------------------------------------
    def _make_disk_page(self):
        _m = self._page_margin
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6 if self._compact else 12)
        page.set_margin_top(self._page_top)
        page.set_margin_bottom(self._page_top)
        page.set_margin_start(_m)
        page.set_margin_end(_m)

        title = Gtk.Label(label="Select Installation Disk")
        title.add_css_class("title-2")
        title.set_halign(Gtk.Align.START)
        page.append(title)

        subtitle = Gtk.Label(
            label="Choose the drive where AI Arch Linux will be installed.\n"
                  "The live boot media is automatically excluded."
        )
        subtitle.set_halign(Gtk.Align.START)
        subtitle.add_css_class("dim-label")
        page.append(subtitle)

        # Refresh button
        refresh_btn = Gtk.Button(label="Refresh Disk List")
        refresh_btn.set_halign(Gtk.Align.START)
        refresh_btn.connect("clicked", lambda b: self._refresh_disks())
        page.append(refresh_btn)

        # Scrollable disk list
        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        self._disk_list_box = Gtk.ListBox()
        self._disk_list_box.set_selection_mode(Gtk.SelectionMode.NONE)
        self._disk_list_box.add_css_class("boxed-list")

        scroll.set_child(self._disk_list_box)
        page.append(scroll)

        # Selected disk info
        self._disk_info_label = Gtk.Label(label="No disk selected")
        self._disk_info_label.set_halign(Gtk.Align.START)
        self._disk_info_label.add_css_class("dim-label")
        page.append(self._disk_info_label)

        # Populate on first show
        GLib.idle_add(self._refresh_disks)

        return page

    def _refresh_disks(self):
        """Refresh the list of available block devices."""
        # Clear existing items
        while True:
            row = self._disk_list_box.get_row_at_index(0)
            if row is None:
                break
            self._disk_list_box.remove(row)

        self._devices = get_block_devices()

        if not self._devices:
            empty_label = Gtk.Label(
                label="No suitable installation targets found.\n"
                      "Connect a drive and click Refresh."
            )
            empty_label.set_margin_top(40)
            empty_label.set_margin_bottom(40)
            empty_label.add_css_class("dim-label")
            row = Gtk.ListBoxRow()
            row.set_child(empty_label)
            row.set_activatable(False)
            self._disk_list_box.append(row)
            return

        self._disk_radio_group = None
        for dev in self._devices:
            row_widget = self._make_disk_row(dev)
            self._disk_list_box.append(row_widget)

    def _make_disk_row(self, dev):
        """Create a ListBoxRow for a disk device."""
        row = Gtk.ListBoxRow()
        row.set_activatable(False)

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        hbox.set_margin_top(8)
        hbox.set_margin_bottom(8)
        hbox.set_margin_start(12)
        hbox.set_margin_end(12)

        # Radio button
        radio = Gtk.CheckButton()
        if self._disk_radio_group is not None:
            radio.set_group(self._disk_radio_group)
        else:
            self._disk_radio_group = radio
        radio.connect("toggled", self._on_disk_selected, dev)
        hbox.append(radio)

        # Drive icon
        if "nvme" in dev["name"]:
            icon_name = "drive-harddisk-solidstate-symbolic"
        elif dev["interface"] == "USB":
            icon_name = "drive-removable-media-symbolic"
        else:
            icon_name = "drive-harddisk-symbolic"

        icon = Gtk.Image.new_from_icon_name(icon_name)
        icon.set_pixel_size(32)
        hbox.append(icon)

        # Info column
        info_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        info_box.set_hexpand(True)

        name_label = Gtk.Label(label=f"/dev/{dev['name']}")
        name_label.set_halign(Gtk.Align.START)
        name_label.add_css_class("heading")
        info_box.append(name_label)

        detail = f"{dev['model']}  \u2022  {dev['size']}  \u2022  {dev['interface']}"
        detail_label = Gtk.Label(label=detail)
        detail_label.set_halign(Gtk.Align.START)
        detail_label.add_css_class("dim-label")
        info_box.append(detail_label)

        hbox.append(info_box)

        # Badges
        badge_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        if dev["recommended"]:
            badge = Gtk.Label(label="Recommended")
            badge.add_css_class("recommended-badge")
            badge_box.append(badge)
        if dev["removable"]:
            rm_badge = Gtk.Label(label="Removable")
            rm_badge.add_css_class("dim-label")
            badge_box.append(rm_badge)

        hbox.append(badge_box)

        row.set_child(hbox)
        return row

    def _on_disk_selected(self, radio, dev):
        if radio.get_active():
            self._selected_device = dev
            self._disk_info_label.set_text(
                f"Selected: /dev/{dev['name']} ({dev['size']}, {dev['model']})"
            )
            self._disk_info_label.remove_css_class("dim-label")
            self._disk_info_label.add_css_class("accent-text")

    # ------------------------------------------------------------------
    # Page 3: Partition Scheme
    # ------------------------------------------------------------------
    def _make_partition_page(self):
        _m = self._page_margin
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6 if self._compact else 12)
        page.set_margin_top(self._page_top)
        page.set_margin_bottom(self._page_top)
        page.set_margin_start(_m)
        page.set_margin_end(_m)

        title = Gtk.Label(label="Partition Scheme")
        title.add_css_class("title-2")
        title.set_halign(Gtk.Align.START)
        page.append(title)

        subtitle = Gtk.Label(
            label="Choose how to partition the selected drive."
        )
        subtitle.set_halign(Gtk.Align.START)
        subtitle.add_css_class("dim-label")
        page.append(subtitle)

        # Auto partition option
        auto_group = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        auto_group.set_margin_top(16)

        self._auto_radio = Gtk.CheckButton(label="Automatic partitioning (recommended)")
        self._auto_radio.set_active(True)
        self._auto_radio.connect("toggled", self._on_partition_mode_changed)
        auto_group.append(self._auto_radio)

        # Auto partition details
        self._auto_details = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        self._auto_details.set_margin_start(28)

        auto_info = Gtk.Label(
            label="Creates a GPT partition table with:"
        )
        auto_info.set_halign(Gtk.Align.START)
        self._auto_details.append(auto_info)

        parts = [
            "\u2022  EFI System Partition: 512 MB (FAT32)",
            "\u2022  Root partition: remaining space (ext4)",
        ]
        for p in parts:
            lbl = Gtk.Label(label=p)
            lbl.set_halign(Gtk.Align.START)
            lbl.add_css_class("dim-label")
            self._auto_details.append(lbl)

        # Swap toggle
        swap_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        swap_row.set_margin_top(8)
        self._swap_check = Gtk.CheckButton(label="Create swap partition")
        self._swap_check.set_active(self._use_swap)
        self._swap_check.connect("toggled", self._on_swap_toggled)
        swap_row.append(self._swap_check)

        self._swap_spin = Gtk.SpinButton()
        self._swap_spin.set_range(1, 32)
        self._swap_spin.set_value(self._swap_size_gb)
        self._swap_spin.set_increments(1, 4)
        self._swap_spin.set_digits(0)
        self._swap_spin.connect("value-changed",
                                lambda s: setattr(self, '_swap_size_gb', int(s.get_value())))
        swap_row.append(self._swap_spin)
        swap_row.append(Gtk.Label(label="GB"))

        self._auto_details.append(swap_row)

        auto_group.append(self._auto_details)
        page.append(auto_group)

        # Separator
        page.append(Gtk.Separator())

        # Manual partition option
        self._manual_radio = Gtk.CheckButton(label="Manual partitioning (advanced)")
        self._manual_radio.set_group(self._auto_radio)
        self._manual_radio.connect("toggled", self._on_partition_mode_changed)
        page.append(self._manual_radio)

        self._manual_details = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        self._manual_details.set_margin_start(28)
        self._manual_details.set_sensitive(False)

        manual_info = Gtk.Label(
            label="Opens GParted for manual partition management.\n"
                  "You must create at least:\n"
                  "  \u2022  An EFI partition (FAT32, 512MB+, esp flag)\n"
                  "  \u2022  A root partition (ext4)"
        )
        manual_info.set_halign(Gtk.Align.START)
        manual_info.add_css_class("dim-label")
        self._manual_details.append(manual_info)

        gparted_btn = Gtk.Button(label="Launch GParted")
        gparted_btn.set_halign(Gtk.Align.START)
        gparted_btn.set_margin_top(8)
        gparted_btn.connect("clicked", self._launch_gparted)
        self._manual_details.append(gparted_btn)

        page.append(self._manual_details)

        return page

    def _on_partition_mode_changed(self, radio):
        is_auto = self._auto_radio.get_active()
        self._auto_details.set_sensitive(is_auto)
        self._manual_details.set_sensitive(not is_auto)

    def _on_swap_toggled(self, check):
        self._use_swap = check.get_active()
        self._swap_spin.set_sensitive(self._use_swap)

    def _launch_gparted(self, btn):
        try:
            dev = self._selected_device
            if dev:
                subprocess.Popen(["gparted", dev["path"]])
            else:
                subprocess.Popen(["gparted"])
        except FileNotFoundError:
            self._show_toast("GParted is not installed.")

    # ------------------------------------------------------------------
    # Page 4: User Setup
    # ------------------------------------------------------------------
    def _make_user_page(self):
        _m = self._page_margin
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6 if self._compact else 12)
        page.set_margin_top(self._page_top)
        page.set_margin_bottom(self._page_top)
        page.set_margin_start(_m)
        page.set_margin_end(_m)

        title = Gtk.Label(label="User Setup")
        title.add_css_class("title-2")
        title.set_halign(Gtk.Align.START)
        page.append(title)

        subtitle = Gtk.Label(
            label="Configure the user account and system settings."
        )
        subtitle.set_halign(Gtk.Align.START)
        subtitle.add_css_class("dim-label")
        page.append(subtitle)

        # Form in a scrollable area
        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        form = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        form.set_margin_top(16)

        # Username
        user_group = Adw.PreferencesGroup(title="User Account")
        self._username_entry = Adw.EntryRow(title="Username")
        self._username_entry.set_text("arch")
        user_group.add(self._username_entry)

        self._password_entry = Adw.PasswordEntryRow(title="Password")
        user_group.add(self._password_entry)

        self._password_confirm = Adw.PasswordEntryRow(title="Confirm Password")
        user_group.add(self._password_confirm)

        form.append(user_group)

        # System settings
        sys_group = Adw.PreferencesGroup(title="System")
        self._hostname_entry = Adw.EntryRow(title="Hostname")
        self._hostname_entry.set_text("archwindows")
        sys_group.add(self._hostname_entry)

        # Timezone dropdown
        self._tz_combo = Adw.ComboRow(title="Timezone")
        tz_list = Gtk.StringList()
        all_tz = COMMON_TIMEZONES + [tz for tz in get_all_timezones()
                                      if tz not in COMMON_TIMEZONES]
        for tz in all_tz:
            tz_list.append(tz)
        self._tz_combo.set_model(tz_list)
        self._tz_list = all_tz
        sys_group.add(self._tz_combo)

        form.append(sys_group)

        # AI settings
        ai_group = Adw.PreferencesGroup(title="AI Control")
        self._ai_row = Adw.SwitchRow(
            title="Enable AI Daemon on Boot",
            subtitle="Start the AI control daemon (port 8420) automatically"
        )
        self._ai_row.set_active(True)
        ai_group.add(self._ai_row)
        form.append(ai_group)

        # Validation error label
        self._validation_label = Gtk.Label()
        self._validation_label.add_css_class("error-text")
        self._validation_label.set_halign(Gtk.Align.START)
        self._validation_label.set_visible(False)
        form.append(self._validation_label)

        # Summary
        self._summary_label = Gtk.Label()
        self._summary_label.set_halign(Gtk.Align.START)
        self._summary_label.add_css_class("dim-label")
        self._summary_label.set_margin_top(8)
        self._summary_label.set_wrap(True)
        form.append(self._summary_label)

        scroll.set_child(form)
        page.append(scroll)

        return page

    def _validate_user_inputs(self):
        """Validate user page inputs. Returns True if valid."""
        self._username = self._username_entry.get_text().strip()
        pw1 = self._password_entry.get_text()
        pw2 = self._password_confirm.get_text()
        self._hostname = self._hostname_entry.get_text().strip()
        tz_idx = self._tz_combo.get_selected()
        if tz_idx < len(self._tz_list):
            self._timezone = self._tz_list[tz_idx]
        self._enable_ai = self._ai_row.get_active()

        errors = []

        if not self._username:
            errors.append("Username cannot be empty.")
        elif not re.match(r'^[a-z_][a-z0-9_-]*$', self._username):
            errors.append("Username must be lowercase, start with a letter or underscore.")
        elif len(self._username) > 32:
            errors.append("Username too long (max 32 characters).")

        if not pw1:
            errors.append("Password cannot be empty.")
        elif len(pw1) < 4:
            errors.append("Password must be at least 4 characters.")
        elif pw1 != pw2:
            errors.append("Passwords do not match.")

        if not self._hostname:
            errors.append("Hostname cannot be empty.")
        elif not re.match(r'^[a-zA-Z0-9][a-zA-Z0-9-]*$', self._hostname):
            errors.append("Hostname contains invalid characters.")

        if errors:
            self._validation_label.set_text("\n".join(errors))
            self._validation_label.set_visible(True)
            return False

        self._password = pw1
        self._validation_label.set_visible(False)

        # Update summary
        dev = self._selected_device
        swap_info = f", {self._swap_size_gb}GB swap" if self._use_swap else ""
        self._summary_label.set_text(
            f"Ready to install to /dev/{dev['name']} ({dev['size']})\n"
            f"Partitions: 512MB EFI + root ext4{swap_info}\n"
            f"User: {self._username} @ {self._hostname}\n"
            f"Timezone: {self._timezone}\n"
            f"AI daemon: {'enabled' if self._enable_ai else 'disabled'}"
        )

        # Show confirmation dialog
        dialog = Adw.MessageDialog(
            transient_for=self.win,
            heading="Confirm Installation",
            body=f"All data on /dev/{dev['name']} ({dev['size']}, {dev['model']}) "
                 f"will be permanently erased.\n\nThis action cannot be undone.",
        )
        dialog.add_response("cancel", "Cancel")
        dialog.add_response("install", "Erase Disk and Install")
        dialog.set_response_appearance("install", Adw.ResponseAppearance.DESTRUCTIVE)
        dialog.set_default_response("cancel")
        dialog.set_close_response("cancel")

        # Use a flag to communicate result since dialogs are async in GTK4
        self._confirm_result = None
        dialog.connect("response", self._on_confirm_response)
        dialog.present()
        return False  # Always return False; installation starts from callback

    def _on_confirm_response(self, dialog, response):
        dialog.destroy()
        if response == "install":
            self._stack.set_visible_child_name("install")
            self._update_nav_buttons()
            self._start_installation()

    # ------------------------------------------------------------------
    # Page 5: Installation Progress
    # ------------------------------------------------------------------
    def _make_install_page(self):
        _m = self._page_margin
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6 if self._compact else 12)
        page.set_margin_top(self._page_top)
        page.set_margin_bottom(self._page_top)
        page.set_margin_start(_m)
        page.set_margin_end(_m)

        title = Gtk.Label(label="Installing AI Arch Linux")
        title.add_css_class("title-2")
        title.set_halign(Gtk.Align.START)
        page.append(title)

        # Current step label
        self._step_label = Gtk.Label(label="Preparing...")
        self._step_label.set_halign(Gtk.Align.START)
        self._step_label.add_css_class("accent-text")
        page.append(self._step_label)

        # Progress bar
        self._progress_bar = Gtk.ProgressBar()
        self._progress_bar.set_show_text(True)
        self._progress_bar.set_margin_top(8)
        page.append(self._progress_bar)

        # Step checklist
        self._steps_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        self._steps_box.set_margin_top(16)

        self._step_labels = {}
        steps = [
            ("partition", "Partitioning disk"),
            ("format", "Formatting partitions"),
            ("mount", "Mounting filesystems"),
            ("pacstrap", "Installing base system"),
            ("fstab", "Generating fstab"),
            ("timezone", "Setting timezone and locale"),
            ("users", "Creating user accounts"),
            ("bootloader", "Installing bootloader"),
            ("services", "Enabling services"),
            ("initramfs", "Building initramfs"),
            ("cleanup", "Finishing up"),
        ]
        for key, label in steps:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            status = Gtk.Label(label="\u25CB")  # empty circle
            status.add_css_class("step-pending")
            status.set_size_request(20, -1)
            row.append(status)
            text = Gtk.Label(label=label)
            text.set_halign(Gtk.Align.START)
            text.add_css_class("step-pending")
            row.append(text)
            self._steps_box.append(row)
            self._step_labels[key] = (status, text)

        page.append(self._steps_box)

        # Log output (scrollable text view)
        log_frame = Gtk.Frame()
        log_frame.set_vexpand(True)
        log_frame.set_margin_top(12)

        log_scroll = Gtk.ScrolledWindow()
        log_scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        log_scroll.set_min_content_height(150)

        self._log_view = Gtk.TextView()
        self._log_view.set_editable(False)
        self._log_view.set_cursor_visible(False)
        self._log_view.set_monospace(True)
        self._log_view.add_css_class("log-view")
        self._log_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        self._log_buffer_widget = self._log_view.get_buffer()

        log_scroll.set_child(self._log_view)
        log_frame.set_child(log_scroll)
        page.append(log_frame)

        return page

    def _update_step(self, key, status):
        """Update a step's visual status. status: 'active', 'done', 'error', 'pending'."""
        if key not in self._step_labels:
            return
        icon_label, text_label = self._step_labels[key]

        icons = {"active": "\u25CF", "done": "\u2713", "error": "\u2717", "pending": "\u25CB"}
        classes = {"active": "step-active", "done": "step-done",
                   "error": "error-text", "pending": "step-pending"}

        icon_label.set_text(icons.get(status, "\u25CB"))
        text_label.set_text(text_label.get_text())  # refresh

        for cls in ("step-active", "step-done", "error-text", "step-pending"):
            icon_label.remove_css_class(cls)
            text_label.remove_css_class(cls)

        css_cls = classes.get(status, "step-pending")
        icon_label.add_css_class(css_cls)
        text_label.add_css_class(css_cls)

    def _log(self, message):
        """Append a message to the install log (thread-safe via GLib.idle_add)."""
        def _append():
            end_iter = self._log_buffer_widget.get_end_iter()
            self._log_buffer_widget.insert(end_iter, message + "\n")
            # Auto-scroll to bottom
            mark = self._log_buffer_widget.get_insert()
            self._log_view.scroll_mark_onscreen(mark)
            # Also move the insert mark to end so scroll works
            end_iter = self._log_buffer_widget.get_end_iter()
            self._log_buffer_widget.place_cursor(end_iter)
            return False
        GLib.idle_add(_append)

    def _set_progress(self, fraction, text=None):
        """Update progress bar (thread-safe)."""
        def _update():
            self._progress_bar.set_fraction(fraction)
            if text:
                self._progress_bar.set_text(text)
                self._step_label.set_text(text)
            return False
        GLib.idle_add(_update)

    def _set_step(self, key, status):
        """Thread-safe step status update."""
        GLib.idle_add(self._update_step, key, status)

    # ------------------------------------------------------------------
    # Page 6: Complete
    # ------------------------------------------------------------------
    def _make_complete_page(self):
        _cm = 20 if self._compact else 40
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8 if self._compact else 16)
        page.set_valign(Gtk.Align.CENTER)
        page.set_halign(Gtk.Align.CENTER)
        page.set_margin_top(_cm)
        page.set_margin_bottom(_cm)
        page.set_margin_start(_cm)
        page.set_margin_end(_cm)

        self._complete_icon = Gtk.Image.new_from_icon_name("emblem-ok-symbolic")
        self._complete_icon.set_pixel_size(48 if self._compact else 72)
        self._complete_icon.add_css_class("success-text")
        page.append(self._complete_icon)

        self._complete_title = Gtk.Label(label="Installation Complete!")
        self._complete_title.add_css_class("title-1")
        page.append(self._complete_title)

        self._complete_subtitle = Gtk.Label(
            label="AI Arch Linux has been installed successfully.\n"
                  "Remove the installation media and reboot to start using your new system."
        )
        self._complete_subtitle.set_justify(Gtk.Justification.CENTER)
        self._complete_subtitle.add_css_class("dim-label")
        page.append(self._complete_subtitle)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        btn_box.set_halign(Gtk.Align.CENTER)
        btn_box.set_margin_top(24)

        reboot_btn = Gtk.Button(label="Reboot Now")
        reboot_btn.add_css_class("suggested-action")
        reboot_btn.connect("clicked", self._on_reboot)
        btn_box.append(reboot_btn)

        close_btn = Gtk.Button(label="Close")
        close_btn.connect("clicked", lambda b: self.quit())
        btn_box.append(close_btn)

        page.append(btn_box)

        return page

    def _on_reboot(self, btn):
        try:
            subprocess.run(["systemctl", "reboot"], check=False)
        except Exception:
            pass

    def _on_cancel(self, btn):
        if self._current_page() == "install":
            return  # Can't cancel during installation
        dialog = Adw.MessageDialog(
            transient_for=self.win,
            heading="Cancel Installation?",
            body="No changes have been made to your disks yet.",
        )
        dialog.add_response("continue", "Continue Setup")
        dialog.add_response("quit", "Quit Installer")
        dialog.set_response_appearance("quit", Adw.ResponseAppearance.DESTRUCTIVE)
        dialog.connect("response", self._on_cancel_response)
        dialog.present()

    def _on_cancel_response(self, dialog, response):
        dialog.destroy()
        if response == "quit":
            self.quit()

    # ------------------------------------------------------------------
    # Installation Logic (runs in background thread)
    # ------------------------------------------------------------------
    def _start_installation(self):
        """Start the installation in a background thread."""
        self._install_cancelled = False
        self._install_thread = threading.Thread(
            target=self._install_worker, daemon=False
        )
        self._install_thread.start()

    def _run_cmd(self, cmd, desc=None, check=True, env=None):
        """Run a shell command, logging output. Returns (returncode, stdout)."""
        if isinstance(cmd, str):
            cmd_str = cmd
        else:
            cmd_str = " ".join(cmd)

        if desc:
            self._log(f">>> {desc}")
        self._log(f"$ {cmd_str}")

        merged_env = os.environ.copy()
        if env:
            merged_env.update(env)

        try:
            proc = subprocess.Popen(
                cmd, shell=isinstance(cmd, str),
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, env=merged_env,
            )
            output_lines = []
            for line in proc.stdout:
                line = line.rstrip()
                output_lines.append(line)
                self._log(f"  {line}")
            proc.wait()
            output = "\n".join(output_lines)

            if check and proc.returncode != 0:
                self._log(f"ERROR: Command failed with exit code {proc.returncode}")
                raise subprocess.CalledProcessError(proc.returncode, cmd_str, output)

            return proc.returncode, output
        except FileNotFoundError as e:
            self._log(f"ERROR: Command not found: {e}")
            if check:
                raise
            return 127, str(e)

    def _install_worker(self):
        """The actual installation procedure. Runs in a background thread."""
        dev = self._selected_device
        disk = dev["path"]

        # Determine partition naming (nvme uses p1, sata uses 1)
        if "nvme" in dev["name"] or "mmcblk" in dev["name"]:
            p_prefix = f"{disk}p"
        else:
            p_prefix = disk

        total_steps = 11
        current_step = 0

        def progress(step_num, text):
            nonlocal current_step
            current_step = step_num
            frac = step_num / total_steps
            self._set_progress(frac, text)

        try:
            # === Step 1: Partition the disk ===
            progress(1, "Partitioning disk...")
            self._set_step("partition", "active")

            # Unmount any existing partitions on this device
            # (handles re-runs after a previous failed installation)
            self._log("Unmounting any existing partitions on the target device...")
            self._run_cmd(f"umount -R {MOUNT_ROOT} 2>/dev/null || true", check=False)
            self._run_cmd(f"swapoff -a 2>/dev/null || true", check=False)
            # Also unmount any partitions from this specific disk
            self._run_cmd(f"umount {p_prefix}* 2>/dev/null || true", check=False)

            # Wipe existing partition table signatures
            self._run_cmd(f"wipefs -af {disk}",
                          desc="Wiping existing filesystem signatures")

            # Create GPT partition table
            self._run_cmd(f"parted -s {disk} mklabel gpt",
                          desc="Creating GPT partition table")

            if self._use_swap:
                swap_gb = self._swap_size_gb
                swap_end = 513 + (swap_gb * 1024)
                # EFI partition
                self._run_cmd(
                    f"parted -s {disk} mkpart ESP fat32 1MiB 513MiB",
                    desc="Creating EFI partition (512MB)")
                self._run_cmd(f"parted -s {disk} set 1 esp on")
                # Swap partition
                self._run_cmd(
                    f"parted -s {disk} mkpart primary linux-swap 513MiB {swap_end}MiB",
                    desc=f"Creating swap partition ({swap_gb}GB)")
                # Root partition
                self._run_cmd(
                    f"parted -s {disk} mkpart primary ext4 {swap_end}MiB 100%",
                    desc="Creating root partition (remaining space)")
                efi_part = f"{p_prefix}1"
                swap_part = f"{p_prefix}2"
                root_part = f"{p_prefix}3"
            else:
                # EFI partition
                self._run_cmd(
                    f"parted -s {disk} mkpart ESP fat32 1MiB 513MiB",
                    desc="Creating EFI partition (512MB)")
                self._run_cmd(f"parted -s {disk} set 1 esp on")
                # Root partition
                self._run_cmd(
                    f"parted -s {disk} mkpart primary ext4 513MiB 100%",
                    desc="Creating root partition (remaining space)")
                efi_part = f"{p_prefix}1"
                swap_part = None
                root_part = f"{p_prefix}2"

            # Wait for kernel to update partition table
            self._run_cmd(f"partprobe {disk}", check=False)
            self._run_cmd("udevadm settle --timeout=10", check=False)
            self._run_cmd("sleep 3", check=False)

            # Verify partitions exist before proceeding
            self._log(f"Verifying partitions: EFI={efi_part} Root={root_part}")
            for attempt in range(5):
                if os.path.exists(root_part) and os.path.exists(efi_part):
                    break
                self._log(f"  Waiting for partitions to appear (attempt {attempt+1}/5)...")
                time.sleep(2)

            if not os.path.exists(root_part):
                raise RuntimeError(f"Partition {root_part} did not appear after partitioning. "
                                   f"Check if {disk} was partitioned correctly.")

            self._set_step("partition", "done")

            # === Step 2: Format partitions ===
            progress(2, "Formatting partitions...")
            self._set_step("format", "active")

            self._run_cmd(f"mkfs.fat -F32 {efi_part}",
                          desc="Formatting EFI partition (FAT32)")
            self._run_cmd(f"mkfs.ext4 -F -L AIArch {root_part}",
                          desc="Formatting root partition (ext4)")
            if swap_part:
                self._run_cmd(f"mkswap {swap_part}",
                              desc="Creating swap")

            self._set_step("format", "done")

            # === Step 3: Mount partitions ===
            progress(3, "Mounting filesystems...")
            self._set_step("mount", "active")

            os.makedirs(MOUNT_ROOT, exist_ok=True)
            self._run_cmd(f"mount {root_part} {MOUNT_ROOT}",
                          desc="Mounting root partition")
            os.makedirs(EFI_MOUNT, exist_ok=True)
            self._run_cmd(f"mount {efi_part} {EFI_MOUNT}",
                          desc="Mounting EFI partition")
            if swap_part:
                self._run_cmd(f"swapon {swap_part}",
                              desc="Enabling swap")

            self._set_step("mount", "done")

            # === Step 4: Install base system ===
            progress(4, "Installing base system (this may take a while)...")
            self._set_step("pacstrap", "active")

            # Base packages
            base_pkgs = (
                "base linux linux-firmware amd-ucode intel-ucode "
                "mkinitcpio networkmanager grub efibootmgr "
                "xfce4 xfce4-goodies lightdm lightdm-gtk-greeter "
                "xorg-server xorg-xinit xorg-xrandr "
                "pipewire pipewire-pulse pipewire-alsa wireplumber "
                "mesa vulkan-icd-loader "
                "base-devel gcc make dkms linux-headers "
                "git vim nano htop wget curl openssh "
                "networkmanager network-manager-applet iwd "
                "python python-pip python-fastapi uvicorn python-gobject "
                "gtk4 libadwaita "
                "firefox thunar terminator zenity "
                "nftables dosfstools e2fsprogs parted "
                "pipewire-jack iptables-nft "
                "papirus-icon-theme noto-fonts ttf-dejavu ttf-jetbrains-mono "
                "bluez bluez-utils blueman acpid tlp "
                "plymouth polkit "
                "steam gamemode wine wine-mono wine-gecko winetricks lutris "
                "lib32-mesa lib32-glibc lib32-gcc-libs "
                "xdotool wmctrl xclip "
                "picom dunst scrot conky i3lock xss-lock "
                "gparted arch-install-scripts "
                "shared-mime-info desktop-file-utils xdg-utils xdg-user-dirs "
                "python-psutil python-requests python-aiohttp python-evdev "
                "python-pillow python-pydantic python-websockets python-tomli "
                "bash-completion fastfetch "
                "sof-firmware alsa-utils pavucontrol "
                "ntfs-3g 7zip udisks2 gvfs gvfs-mtp "
                "man-db man-pages "
            )

            # Determine the pacman.conf to use — prefer the live ISO's config
            # which includes our custom [pe-compat] repo
            pacman_conf = "/etc/pacman.conf"
            if os.path.exists("/etc/pacman.conf"):
                # Check if it has our custom repo
                with open("/etc/pacman.conf") as f:
                    conf = f.read()
                if "[pe-compat]" not in conf:
                    # Try the ISO profile config
                    for alt in ["/run/archiso/airootfs/etc/pacman.conf"]:
                        if os.path.exists(alt):
                            pacman_conf = alt
                            break

            self._run_cmd(
                f"pacstrap -K --noconfirm {MOUNT_ROOT} {base_pkgs}",
                desc="Installing base system packages via pacstrap")

            # Install custom packages from our local repo
            # First, copy the repo config to the new system temporarily
            custom_pkgs = " ".join(CUSTOM_PACKAGES)
            self._log("Installing custom AI Arch packages...")
            rc, _ = self._run_cmd(
                f"pacstrap -K --noconfirm {MOUNT_ROOT} --config {pacman_conf} {custom_pkgs}",
                desc="Installing AI Arch custom packages",
                check=False)
            if rc != 0:
                self._log("WARNING: Some custom packages may not have installed. "
                          "They can be installed later from the pe-compat repo.")

            self._set_step("pacstrap", "done")

            # === Step 5: Generate fstab ===
            progress(5, "Generating fstab...")
            self._set_step("fstab", "active")

            self._run_cmd(
                f"bash -c 'genfstab -U {MOUNT_ROOT} >> {MOUNT_ROOT}/etc/fstab'",
                desc="Generating /etc/fstab with UUIDs")

            self._set_step("fstab", "done")

            # === Step 6: Timezone and locale ===
            progress(6, "Configuring timezone and locale...")
            self._set_step("timezone", "active")

            tz = self._timezone
            self._chroot(f"ln -sf /usr/share/zoneinfo/{tz} /etc/localtime")
            self._chroot("hwclock --systohc")
            with open(f"{MOUNT_ROOT}/etc/locale.gen", "w") as f:
                f.write("en_US.UTF-8 UTF-8\n")
            self._chroot("locale-gen", desc="Generating locale")
            with open(f"{MOUNT_ROOT}/etc/locale.conf", "w") as f:
                f.write("LANG=en_US.UTF-8\n")

            self._set_step("timezone", "done")

            # === Step 7: User accounts ===
            progress(7, "Creating user accounts...")
            self._set_step("users", "active")

            hostname = self._hostname
            username = self._username
            password = self._password

            # Hostname — use Python file writes (no shell quoting issues)
            with open(f"{MOUNT_ROOT}/etc/hostname", "w") as f:
                f.write(f"{hostname}\n")
            with open(f"{MOUNT_ROOT}/etc/hosts", "w") as f:
                f.write(f"127.0.0.1   localhost\n")
                f.write(f"::1         localhost\n")
                f.write(f"127.0.1.1   {hostname}.localdomain  {hostname}\n")

            # Root password — pipe to chpasswd stdin to avoid shell quoting issues
            # (passwords with single quotes, $, backticks would break echo-pipe)
            self._log(">>> Setting root password")
            subprocess.run(
                ["arch-chroot", MOUNT_ROOT, "chpasswd"],
                input=f"root:{password}\n", text=True, check=True,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

            # Create user
            self._chroot(
                f"useradd -m -G wheel,video,audio,input,network,storage,games,users "
                f"-s /bin/bash {username}",
                desc=f"Creating user {username}")
            self._log(f">>> Setting password for {username}")
            subprocess.run(
                ["arch-chroot", MOUNT_ROOT, "chpasswd"],
                input=f"{username}:{password}\n", text=True, check=True,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

            # Sudo access
            os.makedirs(f"{MOUNT_ROOT}/etc/sudoers.d", exist_ok=True)
            with open(f"{MOUNT_ROOT}/etc/sudoers.d/wheel", "w") as f:
                f.write("%wheel ALL=(ALL:ALL) ALL\n")
            os.chmod(f"{MOUNT_ROOT}/etc/sudoers.d/wheel", 0o440)

            # Copy skel files to user home (desktop shortcuts, configs)
            skel_src = f"{MOUNT_ROOT}/etc/skel"
            user_home = f"{MOUNT_ROOT}/home/{username}"
            if os.path.isdir(skel_src):
                for item in os.listdir(skel_src):
                    src = os.path.join(skel_src, item)
                    dst = os.path.join(user_home, item)
                    try:
                        if os.path.isdir(src):
                            if os.path.exists(dst):
                                shutil.rmtree(dst)
                            shutil.copytree(src, dst, symlinks=True)
                        else:
                            shutil.copy2(src, dst)
                    except (OSError, shutil.Error) as e:
                        self._log(f"  WARNING: Could not copy {item}: {e}")
                self._chroot(f"chown -R {username}:{username} /home/{username}")

            self._set_step("users", "done")

            # === Step 8: Bootloader ===
            progress(8, "Installing bootloader...")
            self._set_step("bootloader", "active")

            # UEFI GRUB
            self._chroot(
                "grub-install --target=x86_64-efi --efi-directory=/boot/efi "
                "--bootloader-id=AIArch --removable",
                desc="Installing GRUB for UEFI")

            # BIOS fallback (only if disk has MBR space, skip on NVMe)
            if not dev["name"].startswith("nvme"):
                self._chroot(
                    f"grub-install --target=i386-pc {disk}",
                    desc="Installing GRUB for BIOS (legacy fallback)",
                    check=False)

            # Configure GRUB
            grub_default = f"{MOUNT_ROOT}/etc/default/grub"
            if os.path.exists(grub_default):
                with open(grub_default, "r") as f:
                    grub_cfg = f.read()
                # Add kernel parameters for NVIDIA and Plymouth
                grub_cfg = re.sub(
                    r'GRUB_CMDLINE_LINUX_DEFAULT="[^"]*"',
                    'GRUB_CMDLINE_LINUX_DEFAULT="quiet splash '
                    'nvidia_drm.modeset=1 amd_pstate=active"',
                    grub_cfg)
                # Set timeout
                grub_cfg = re.sub(
                    r'GRUB_TIMEOUT=\d+',
                    'GRUB_TIMEOUT=3',
                    grub_cfg)
                with open(grub_default, "w") as f:
                    f.write(grub_cfg)

            self._chroot("grub-mkconfig -o /boot/grub/grub.cfg",
                          desc="Generating GRUB configuration")

            self._set_step("bootloader", "done")

            # === Step 9: Enable services ===
            progress(9, "Enabling services...")
            self._set_step("services", "active")

            for svc in ENABLE_SERVICES:
                if not self._enable_ai and svc == "ai-control":
                    self._log(f"  Skipping {svc} (AI daemon disabled by user)")
                    continue
                self._chroot(f"systemctl enable {svc}.service",
                              check=False)

            # Enable display manager
            self._chroot("systemctl enable lightdm.service", check=False)
            self._chroot(
                "ln -sf /usr/lib/systemd/system/lightdm.service "
                "/etc/systemd/system/display-manager.service",
                check=False)

            # Mask problematic services
            for svc in MASK_SERVICES:
                self._chroot(
                    f"ln -sf /dev/null /etc/systemd/system/{svc}.service",
                    check=False)

            # Enable PipeWire user services globally
            pw_user_wants = f"{MOUNT_ROOT}/etc/systemd/user/default.target.wants"
            pw_socket_wants = f"{MOUNT_ROOT}/etc/systemd/user/sockets.target.wants"
            os.makedirs(pw_user_wants, exist_ok=True)
            os.makedirs(pw_socket_wants, exist_ok=True)
            for unit in ["pipewire.socket", "pipewire-pulse.socket"]:
                src = f"/usr/lib/systemd/user/{unit}"
                for wants_dir in [pw_user_wants, pw_socket_wants]:
                    dst = os.path.join(wants_dir, unit)
                    if not os.path.exists(dst):
                        try:
                            os.symlink(src, dst)
                        except Exception:
                            pass
            wp_src = "/usr/lib/systemd/user/wireplumber.service"
            wp_dst = os.path.join(pw_user_wants, "wireplumber.service")
            if not os.path.exists(wp_dst):
                try:
                    os.symlink(wp_src, wp_dst)
                except Exception:
                    pass

            self._set_step("services", "done")

            # === Step 10: Build initramfs ===
            progress(10, "Building initramfs...")
            self._set_step("initramfs", "active")

            # Write mkinitcpio.conf for installed system
            mkinitcpio_conf = (
                "MODULES=(i915 amdgpu)\n"
                "BINARIES=()\n"
                "FILES=()\n"
                "HOOKS=(base udev plymouth autodetect modconf "
                "kms keyboard keymap consolefont block filesystems fsck)\n"
            )
            with open(f"{MOUNT_ROOT}/etc/mkinitcpio.conf", "w") as f:
                f.write(mkinitcpio_conf)

            self._chroot("mkinitcpio -P",
                          desc="Generating initramfs images")

            self._set_step("initramfs", "done")

            # === Step 11: Cleanup ===
            progress(11, "Finishing up...")
            self._set_step("cleanup", "active")

            # Copy the pe-compat repo config so user can update packages later
            live_pacman = "/etc/pacman.conf"
            target_pacman = f"{MOUNT_ROOT}/etc/pacman.conf"
            if os.path.exists(live_pacman):
                with open(live_pacman) as f:
                    live_conf = f.read()
                # If the live config has our repo, merge it into target
                if "[pe-compat]" in live_conf:
                    with open(target_pacman) as f:
                        target_conf = f.read()
                    if "[pe-compat]" not in target_conf:
                        # Extract the pe-compat section
                        idx = live_conf.index("[pe-compat]")
                        repo_block = live_conf[idx:]
                        # Rewrite Server to use a local path on installed system
                        repo_section = (
                            "\n[pe-compat]\n"
                            "SigLevel = Optional TrustAll\n"
                            "Server = file:///var/lib/pe-compat/repo\n"
                        )
                        with open(target_pacman, "a") as f:
                            f.write(repo_section)

            # Copy live repo packages if available
            repo_src = "/var/cache/pacman/pkg"
            repo_dst = f"{MOUNT_ROOT}/var/lib/pe-compat/repo"
            os.makedirs(repo_dst, exist_ok=True)

            # Set Plymouth theme
            self._chroot("plymouth-set-default-theme archwindows || true", check=False)

            # Configure LightDM for the installed system
            lightdm_conf = f"{MOUNT_ROOT}/etc/lightdm/lightdm.conf"
            os.makedirs(os.path.dirname(lightdm_conf), exist_ok=True)
            with open(lightdm_conf, "w") as f:
                f.write(f"""[LightDM]
run-directory=/run/lightdm

[Seat:*]
autologin-user={username}
autologin-session=xfce
user-session=xfce
greeter-session=lightdm-gtk-greeter
autologin-user-timeout=0
session-wrapper=/etc/lightdm/Xsession
""")

            # Ensure Xsession wrapper exists (critical for LightDM to launch sessions)
            xsession = f"{MOUNT_ROOT}/etc/lightdm/Xsession"
            if not os.path.exists(xsession):
                with open(xsession, "w") as f:
                    f.write("#!/bin/sh\n"
                            "[ -f /etc/profile ] && . /etc/profile\n"
                            "[ -f \"$HOME/.xprofile\" ] && . \"$HOME/.xprofile\"\n"
                            "[ -f \"$HOME/.profile\" ] && . \"$HOME/.profile\"\n"
                            "if [ -z \"$XDG_RUNTIME_DIR\" ]; then\n"
                            "    XDG_RUNTIME_DIR=\"/run/user/$(id -u)\"\n"
                            "    export XDG_RUNTIME_DIR\n"
                            "fi\n"
                            "exec $@\n")
                os.chmod(xsession, 0o755)
                self._log("  Created /etc/lightdm/Xsession wrapper")

            # Configure LightDM GTK greeter
            greeter_conf = f"{MOUNT_ROOT}/etc/lightdm/lightdm-gtk-greeter.conf"
            with open(greeter_conf, "w") as f:
                f.write("""[greeter]
theme-name=Adwaita-dark
icon-theme-name=Papirus-Dark
font-name=Noto Sans 11
background=/usr/share/backgrounds/ai-arch/default.svg
""")

            # Ensure binfmt.d config for PE loader
            binfmt_dir = f"{MOUNT_ROOT}/etc/binfmt.d"
            os.makedirs(binfmt_dir, exist_ok=True)
            binfmt_conf = os.path.join(binfmt_dir, "pe-loader.conf")
            if not os.path.exists(binfmt_conf):
                with open(binfmt_conf, "w") as f:
                    f.write(":PE:M::MZ::/usr/bin/peloader:OCF\n")

            # SSH config
            ssh_dir = f"{MOUNT_ROOT}/etc/ssh/sshd_config.d"
            os.makedirs(ssh_dir, exist_ok=True)
            with open(os.path.join(ssh_dir, "50-ai-arch.conf"), "w") as f:
                f.write("PermitRootLogin prohibit-password\n"
                        "PasswordAuthentication yes\n"
                        "PermitEmptyPasswords no\n")

            # Remove the installer desktop shortcut from installed system
            installer_desktop = f"{MOUNT_ROOT}/home/{username}/Desktop/Install-AI-Arch.desktop"
            try:
                if os.path.exists(installer_desktop):
                    os.remove(installer_desktop)
            except OSError:
                pass  # Non-critical: shortcut left on desktop

            # Sync and unmount
            self._run_cmd("sync", desc="Syncing filesystems")

            if swap_part:
                self._run_cmd(f"swapoff {swap_part}", check=False)
            self._run_cmd(f"umount -R {MOUNT_ROOT}",
                          desc="Unmounting filesystems")

            self._set_step("cleanup", "done")

            # === Done ===
            self._set_progress(1.0, "Installation complete!")
            self._log("\n=== Installation completed successfully! ===")
            self._log(f"Installed to: {disk}")
            self._log(f"User: {username}")
            self._log(f"Hostname: {hostname}")
            self._log("Remove the installation media and reboot.")

            # Switch to completion page
            GLib.idle_add(self._show_complete_success)

        except Exception as e:
            import traceback
            self._log(f"\nERROR: Installation failed: {e}")
            self._log(traceback.format_exc())
            self._set_progress(current_step / total_steps,
                              f"Installation failed!")
            # Mark current step as error
            for key, (icon_l, text_l) in self._step_labels.items():
                if "step-active" in (icon_l.get_css_classes() or []):
                    self._set_step(key, "error")

            # Try to clean up mounts
            try:
                self._run_cmd(f"umount -R {MOUNT_ROOT}", check=False)
            except Exception:
                pass

            GLib.idle_add(self._show_complete_failure, str(e))

    def _chroot(self, cmd, desc=None, check=True):
        """Run a command inside arch-chroot."""
        if desc:
            self._log(f">>> {desc}")
        # Use bash -c to handle complex commands with pipes/redirects
        full_cmd = f"arch-chroot {MOUNT_ROOT} /bin/bash -c {shlex.quote(cmd)}"
        return self._run_cmd(full_cmd, check=check)

    def _cleanup_mounts(self):
        """Clean up mounts on failure — prevents leaving disk in bad state."""
        self._log("Cleaning up mounts...")
        for cmd in [
            f"swapoff -a 2>/dev/null",
            f"umount -R {MOUNT_ROOT} 2>/dev/null",
        ]:
            self._run_cmd(cmd, check=False)

    def _show_complete_success(self):
        """Switch to the completion page with success status."""
        self._stack.set_visible_child_name("complete")
        self._update_nav_buttons()
        return False

    def _show_complete_failure(self, error_msg):
        """Switch to the completion page with failure status."""
        self._complete_icon.set_from_icon_name("dialog-error-symbolic")
        self._complete_icon.remove_css_class("success-text")
        self._complete_icon.add_css_class("error-text")
        self._complete_title.set_text("Installation Failed")
        self._complete_subtitle.set_text(
            f"An error occurred during installation:\n\n{error_msg}\n\n"
            "Check the log output for details. Your live system is unaffected."
        )
        self._stack.set_visible_child_name("complete")
        self._update_nav_buttons()
        return False


if __name__ == "__main__":
    app = InstallerApp()
    app.run(sys.argv)
DISK_INSTALLER

}
