#!/usr/bin/env python3
"""
AI WiFi Manager - GTK4/Adwaita wireless network manager.

Provides scanning, connecting, saved network management, and status
display. All operations go through the AI control daemon API.
"""

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib, Gio, Pango, Gdk
import json, threading, time, os
import urllib.request, urllib.error, urllib.parse

os.environ.setdefault("GDK_BACKEND", "x11")
os.environ.setdefault("GSK_RENDERER", "cairo")

API = "http://127.0.0.1:8420"
REFRESH_INTERVAL = 10  # seconds


def _scaled_window_size(base_w, base_h, max_frac=0.85):
    try:
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                geom = monitors.get_item(0).get_geometry()
                frac = 0.85 if geom.height <= 768 else 0.75 if geom.height <= 900 else 0.65 if geom.height <= 1080 else max_frac
                return max(380, min(base_w, int(geom.width * frac))), max(300, min(base_h, int(geom.height * frac)))
    except Exception:
        pass
    return min(base_w, 450), min(base_h, 500)


def api_call(method, endpoint, data=None, timeout=10):
    """Thread-safe API call. Returns dict with 'error' key on failure."""
    try:
        url = f"{API}{endpoint}"
        body = json.dumps(data).encode() if data else None
        req = urllib.request.Request(url, data=body, method=method)
        req.add_header("Content-Type", "application/json")
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode())
    except Exception as e:
        return {"error": str(e)}


def signal_icon_name(signal):
    """Return an appropriate icon name for signal strength."""
    if signal >= 75:
        return "network-wireless-signal-excellent-symbolic"
    elif signal >= 50:
        return "network-wireless-signal-good-symbolic"
    elif signal >= 25:
        return "network-wireless-signal-ok-symbolic"
    else:
        return "network-wireless-signal-weak-symbolic"


def signal_bar_text(signal):
    """Return a text-based signal bar for display."""
    filled = round(signal / 20)  # 0-5 bars
    return "\u2588" * filled + "\u2591" * (5 - filled)


def _clear_listbox(lb):
    """Remove all rows from a Gtk.ListBox."""
    while True:
        row = lb.get_row_at_index(0)
        if row is None:
            break
        lb.remove(row)


def _is_compact_screen():
    """Return True if the screen is small (<=900p) and UI should be compact."""
    try:
        from gi.repository import Gdk
        display = Gdk.Display.get_default()
        if display:
            monitors = display.get_monitors()
            if monitors.get_n_items() > 0:
                return monitors.get_item(0).get_geometry().height <= 900
    except Exception:
        pass
    return True


class WifiManagerApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.ai_arch.wifi_manager")
        self.connect("activate", self._on_activate)
        self._networks = []
        self._saved = []
        self._status = {}
        self._scanning = False
        self._auto_refresh_id = None

    def _on_activate(self, app):
        self._compact = _is_compact_screen()
        _m = 4 if self._compact else 12
        self._margin = _m
        self._spacing = 4 if self._compact else 8

        if self._compact:
            try:
                _css = Gtk.CssProvider()
                _css.load_from_data(b"headerbar.compact{min-height:32px;padding:2px 0}headerbar.compact button{min-height:24px;padding:2px 6px}")
                Gtk.StyleContext.add_provider_for_display(Gdk.Display.get_default(), _css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            except Exception:
                pass

        self.win = Adw.ApplicationWindow(application=app)
        self.win.set_title("WiFi Manager")
        _w, _h = _scaled_window_size(450, 550)
        self.win.set_default_size(_w, _h)

        self.toast_overlay = Adw.ToastOverlay()

        # Header bar
        hdr = Adw.HeaderBar()
        if self._compact:
            hdr.add_css_class("compact")
        refresh_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        refresh_btn.set_tooltip_text("Scan for networks")
        refresh_btn.connect("clicked", lambda _: self._trigger_scan())
        hdr.pack_end(refresh_btn)
        self._refresh_btn = refresh_btn

        # WiFi enable/disable switch
        wifi_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        wifi_label = Gtk.Label(label="WiFi")
        wifi_label.add_css_class("heading")
        self._wifi_switch = Gtk.Switch()
        self._wifi_switch.set_active(True)
        self._wifi_switch.connect("state-set", self._on_wifi_toggle)
        wifi_box.append(wifi_label)
        wifi_box.append(self._wifi_switch)
        hdr.pack_start(wifi_box)

        # Main vertical layout
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        outer.append(hdr)

        # Scrollable content
        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        content.set_margin_start(self._margin)
        content.set_margin_end(self._margin)
        content.set_margin_top(4 if self._compact else 8)
        content.set_margin_bottom(4 if self._compact else 8)

        # --- Status card ---
        status_group = Adw.PreferencesGroup(title="Connection Status")
        self._status_row = Adw.ActionRow(title="Not connected", subtitle="No WiFi connection")
        self._status_row.set_icon_name("network-wireless-offline-symbolic")
        status_group.add(self._status_row)
        content.append(status_group)

        # --- Available networks ---
        net_group_label = Gtk.Label(label="Available Networks")
        net_group_label.add_css_class("heading")
        net_group_label.set_halign(Gtk.Align.START)
        net_group_label.set_margin_top(8 if self._compact else 16)
        net_group_label.set_margin_bottom(2 if self._compact else 4)
        content.append(net_group_label)

        self._scanning_spinner = Gtk.Spinner()
        self._scanning_spinner.set_margin_top(4)
        self._scanning_spinner.set_visible(False)
        content.append(self._scanning_spinner)

        net_frame = Gtk.Frame()
        self._net_list = Gtk.ListBox()
        self._net_list.set_selection_mode(Gtk.SelectionMode.NONE)
        self._net_list.add_css_class("boxed-list")
        self._net_list.set_placeholder(Gtk.Label(label="No networks found. Click refresh to scan."))
        net_frame.set_child(self._net_list)
        content.append(net_frame)

        # --- Saved networks ---
        saved_label = Gtk.Label(label="Saved Networks")
        saved_label.add_css_class("heading")
        saved_label.set_halign(Gtk.Align.START)
        saved_label.set_margin_top(8 if self._compact else 16)
        saved_label.set_margin_bottom(2 if self._compact else 4)
        content.append(saved_label)

        saved_frame = Gtk.Frame()
        self._saved_list = Gtk.ListBox()
        self._saved_list.set_selection_mode(Gtk.SelectionMode.NONE)
        self._saved_list.add_css_class("boxed-list")
        self._saved_list.set_placeholder(Gtk.Label(label="No saved networks."))
        saved_frame.set_child(self._saved_list)
        content.append(saved_frame)

        scroll.set_child(content)
        self.toast_overlay.set_child(scroll)
        outer.append(self.toast_overlay)

        # Apply custom CSS
        css = Gtk.CssProvider()
        css.load_from_data(b"""
            .signal-bar { font-family: monospace; font-size: 14px; }
            .connected-label { color: #73daca; font-weight: bold; }
            .signal-excellent { color: #9ece6a; }
            .signal-good { color: #e0af68; }
            .signal-weak { color: #f7768e; }
        """)
        Gtk.StyleContext.add_provider_for_display(
            self.win.get_display(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.win.set_content(outer)
        self.win.present()

        # Initial load
        self._trigger_scan()
        self._refresh_status()
        self._refresh_saved()

        # Auto-refresh timer
        self._auto_refresh_id = GLib.timeout_add_seconds(
            REFRESH_INTERVAL, self._auto_refresh)

    def _auto_refresh(self):
        """Periodic refresh of status and networks."""
        if not self._scanning:
            self._trigger_scan()
        self._refresh_status()
        self._refresh_saved()
        return True  # keep timer alive

    def _toast(self, msg):
        """Show a toast notification."""
        toast = Adw.Toast(title=msg)
        toast.set_timeout(3)
        self.toast_overlay.add_toast(toast)

    # --- WiFi toggle ---
    def _on_wifi_toggle(self, switch, state):
        action = "on" if state else "off"
        def _do():
            import subprocess
            subprocess.run(["nmcli", "radio", "wifi", action],
                           capture_output=True, timeout=10)
            if state:
                time.sleep(1)
                GLib.idle_add(self._trigger_scan)
            else:
                GLib.idle_add(lambda: self._update_networks([]))
            GLib.idle_add(self._refresh_status)
        threading.Thread(target=_do, daemon=True).start()

    # --- Scan ---
    def _trigger_scan(self):
        if self._scanning:
            return
        self._scanning = True
        self._scanning_spinner.set_visible(True)
        self._scanning_spinner.start()
        self._refresh_btn.set_sensitive(False)

        def _do():
            result = api_call("GET", "/network/wifi/scan", timeout=20)
            networks = result.get("networks", []) if "error" not in result else []
            GLib.idle_add(self._update_networks, networks)

        threading.Thread(target=_do, daemon=True).start()

    def _update_networks(self, networks):
        self._networks = networks
        self._scanning = False
        self._scanning_spinner.stop()
        self._scanning_spinner.set_visible(False)
        self._refresh_btn.set_sensitive(True)

        _clear_listbox(self._net_list)
        for net in networks:
            row = self._make_network_row(net)
            self._net_list.append(row)
        return False

    def _make_network_row(self, net):
        """Build a ListBoxRow for a WiFi network."""
        row = Gtk.ListBoxRow()
        row.set_activatable(True)
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        _rm = 6 if self._compact else 12
        _rp = 4 if self._compact else 8
        hbox.set_margin_top(_rp)
        hbox.set_margin_bottom(_rp)
        hbox.set_margin_start(_rm)
        hbox.set_margin_end(_rm)

        # Signal icon
        sig_icon = Gtk.Image.new_from_icon_name(signal_icon_name(net["signal"]))
        sig_icon.set_pixel_size(24)
        hbox.append(sig_icon)

        # Network info (SSID + security)
        info_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        info_box.set_hexpand(True)

        ssid_label = Gtk.Label(label=net["ssid"])
        ssid_label.set_halign(Gtk.Align.START)
        ssid_label.set_ellipsize(Pango.EllipsizeMode.END)
        if net.get("connected"):
            ssid_label.add_css_class("connected-label")
        info_box.append(ssid_label)

        detail_parts = []
        if net.get("security"):
            detail_parts.append(net["security"])
        if net.get("frequency"):
            detail_parts.append(net["frequency"])
        if detail_parts:
            detail = Gtk.Label(label=" \u00b7 ".join(detail_parts))
            detail.set_halign(Gtk.Align.START)
            detail.add_css_class("dim-label")
            detail.add_css_class("caption")
            info_box.append(detail)

        hbox.append(info_box)

        # Signal bar
        bar = Gtk.Label(label=signal_bar_text(net["signal"]))
        bar.add_css_class("signal-bar")
        if net["signal"] >= 60:
            bar.add_css_class("signal-excellent")
        elif net["signal"] >= 30:
            bar.add_css_class("signal-good")
        else:
            bar.add_css_class("signal-weak")
        hbox.append(bar)

        # Signal percentage
        pct = Gtk.Label(label=f"{net['signal']}%")
        pct.set_width_chars(4)
        pct.add_css_class("dim-label")
        hbox.append(pct)

        # Lock icon for secured networks
        if net.get("security") and net["security"] not in ("", "--", "Open"):
            lock = Gtk.Image.new_from_icon_name("system-lock-screen-symbolic")
            lock.set_pixel_size(16)
            lock.set_tooltip_text("Secured network")
            hbox.append(lock)

        # Connected indicator
        if net.get("connected"):
            check = Gtk.Image.new_from_icon_name("emblem-ok-symbolic")
            check.set_pixel_size(16)
            check.set_tooltip_text("Connected")
            hbox.append(check)
        else:
            # Connect button
            btn = Gtk.Button(label="Connect")
            btn.add_css_class("suggested-action")
            btn.add_css_class("pill")
            btn.connect("clicked", lambda b, n=net: self._on_connect_clicked(n))
            hbox.append(btn)

        row.set_child(hbox)
        return row

    def _on_connect_clicked(self, net):
        """Handle clicking Connect on a network."""
        has_security = (net.get("security")
                        and net["security"] not in ("", "--", "Open"))
        if has_security:
            self._show_password_dialog(net)
        else:
            self._do_connect(net["ssid"], "")

    def _show_password_dialog(self, net):
        """Show a dialog to enter WiFi password."""
        dialog = Adw.MessageDialog(
            transient_for=self.win,
            heading=f"Connect to {net['ssid']}",
            body=f"Security: {net.get('security', 'Unknown')}\nSignal: {net['signal']}%",
        )

        # Password entry in the extra child area
        entry_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        entry_box.set_margin_start(12)
        entry_box.set_margin_end(12)
        pw_entry = Gtk.PasswordEntry()
        pw_entry.set_show_peek_icon(True)
        pw_entry.set_placeholder_text("WiFi password")
        entry_box.append(pw_entry)
        dialog.set_extra_child(entry_box)

        dialog.add_response("cancel", "Cancel")
        dialog.add_response("connect", "Connect")
        dialog.set_response_appearance("connect", Adw.ResponseAppearance.SUGGESTED)
        dialog.set_default_response("connect")
        dialog.set_close_response("cancel")

        # Allow Enter key in password entry to trigger connect
        pw_entry.connect("activate", lambda _: dialog.response("connect"))

        def _on_response(d, response):
            if response == "connect":
                password = pw_entry.get_text()
                self._do_connect(net["ssid"], password)
        dialog.connect("response", _on_response)
        dialog.present()

    def _do_connect(self, ssid, password):
        """Perform the WiFi connection in a background thread."""
        self._toast(f"Connecting to {ssid}...")

        def _do():
            data = {"ssid": ssid}
            if password:
                data["password"] = password
            result = api_call("POST", "/network/wifi/connect", data, timeout=30)
            success = result.get("connected", False)
            msg = result.get("message", "")
            if "error" in result and not msg:
                msg = result["error"]
            def _update():
                if success:
                    self._toast(f"Connected to {ssid}")
                else:
                    self._toast(f"Failed: {msg}")
                self._trigger_scan()
                self._refresh_status()
                self._refresh_saved()
            GLib.idle_add(_update)

        threading.Thread(target=_do, daemon=True).start()

    # --- Disconnect ---
    def _do_disconnect(self):
        self._toast("Disconnecting...")
        def _do():
            result = api_call("POST", "/network/wifi/disconnect")
            msg = result.get("message", "Disconnected")
            def _update():
                self._toast(msg)
                self._trigger_scan()
                self._refresh_status()
            GLib.idle_add(_update)
        threading.Thread(target=_do, daemon=True).start()

    # --- Status ---
    def _refresh_status(self):
        def _do():
            result = api_call("GET", "/network/wifi/status")
            if "error" not in result:
                GLib.idle_add(self._update_status, result)
        threading.Thread(target=_do, daemon=True).start()

    def _update_status(self, status):
        self._status = status
        wifi_on = status.get("wifi_enabled", False)

        # Block signal to avoid triggering _on_wifi_toggle
        self._wifi_switch.handler_block_by_func(self._on_wifi_toggle)
        self._wifi_switch.set_active(wifi_on)
        self._wifi_switch.handler_unblock_by_func(self._on_wifi_toggle)

        # Update status row
        if status.get("connected"):
            ssid = status.get("ssid", "Unknown")
            signal = status.get("signal", 0)
            ip = status.get("ip_address", "")
            speed = status.get("speed", "")
            security = status.get("security", "")

            self._status_row.set_title(f"Connected to {ssid}")
            parts = []
            if signal:
                parts.append(f"Signal: {signal}%")
            if ip:
                parts.append(f"IP: {ip}")
            if speed:
                parts.append(f"Speed: {speed}")
            if security:
                parts.append(f"Security: {security}")
            self._status_row.set_subtitle(" \u00b7 ".join(parts) if parts else "Connected")
            self._status_row.set_icon_name(signal_icon_name(signal))
        else:
            self._status_row.set_title("Not connected")
            self._status_row.set_subtitle(
                "WiFi is off" if not wifi_on else "Select a network to connect")
            self._status_row.set_icon_name("network-wireless-offline-symbolic")
        return False

    # --- Saved networks ---
    def _refresh_saved(self):
        def _do():
            result = api_call("GET", "/network/wifi/saved")
            saved = result.get("saved", []) if "error" not in result else []
            GLib.idle_add(self._update_saved, saved)
        threading.Thread(target=_do, daemon=True).start()

    def _update_saved(self, saved):
        self._saved = saved
        _clear_listbox(self._saved_list)
        for s in saved:
            row = Gtk.ListBoxRow()
            hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            _sm = 6 if self._compact else 12
            _sp = 4 if self._compact else 8
            hbox.set_margin_top(_sp)
            hbox.set_margin_bottom(_sp)
            hbox.set_margin_start(_sm)
            hbox.set_margin_end(_sm)

            icon = Gtk.Image.new_from_icon_name("network-wireless-symbolic")
            icon.set_pixel_size(20)
            hbox.append(icon)

            info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            info.set_hexpand(True)
            name_label = Gtk.Label(label=s["name"])
            name_label.set_halign(Gtk.Align.START)
            name_label.set_ellipsize(Pango.EllipsizeMode.END)
            info.append(name_label)

            detail_parts = []
            if s.get("autoconnect"):
                detail_parts.append("Auto-connect")
            if s.get("last_used"):
                detail_parts.append(f"Last: {s['last_used']}")
            if detail_parts:
                det = Gtk.Label(label=" \u00b7 ".join(detail_parts))
                det.set_halign(Gtk.Align.START)
                det.add_css_class("dim-label")
                det.add_css_class("caption")
                info.append(det)
            hbox.append(info)

            forget_btn = Gtk.Button(label="Forget")
            forget_btn.add_css_class("destructive-action")
            forget_btn.add_css_class("pill")
            forget_btn.set_valign(Gtk.Align.CENTER)
            forget_btn.connect("clicked",
                               lambda b, name=s["name"]: self._forget_network(name))
            hbox.append(forget_btn)

            row.set_child(hbox)
            self._saved_list.append(row)
        return False

    def _forget_network(self, name):
        """Forget a saved network."""
        def _do():
            encoded = urllib.parse.quote(name, safe="")
            result = api_call("DELETE", f"/network/wifi/saved/{encoded}")
            ok = result.get("status") == "ok"
            msg = result.get("message", "")
            def _update():
                if ok:
                    self._toast(f"Forgot network: {name}")
                else:
                    self._toast(f"Failed to forget: {msg}")
                self._refresh_saved()
            GLib.idle_add(_update)
        threading.Thread(target=_do, daemon=True).start()


if __name__ == "__main__":
    app = WifiManagerApp()
    app.run()
