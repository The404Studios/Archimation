    # ==========================================================================
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/ai-tray-indicator" <<'AITRAY'
#!/usr/bin/env python3
"""AI Control System Tray Indicator

Shows AI daemon status in the system tray with quick-action menu.
Uses AppIndicator3 if available, falls back to Gtk.StatusIcon.
"""
import subprocess
import gi

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib

try:
    gi.require_version('AppIndicator3', '0.1')
    from gi.repository import AppIndicator3
    HAS_INDICATOR = True
except (ValueError, ImportError):
    HAS_INDICATOR = False


class AiTrayIndicator:
    ICON_ONLINE = "network-transmit-receive-symbolic"
    ICON_OFFLINE = "network-offline-symbolic"
    ICON_ERROR = "dialog-warning-symbolic"

    def __init__(self):
        self._build_menu()

        if HAS_INDICATOR:
            self.indicator = AppIndicator3.Indicator.new(
                "ai-control-indicator",
                self.ICON_OFFLINE,
                AppIndicator3.IndicatorCategory.SYSTEM_SERVICES,
            )
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_menu(self.menu)
        else:
            # Fallback: legacy Gtk.StatusIcon (works on plain XFCE systray)
            self.status_icon = Gtk.StatusIcon.new_from_icon_name(self.ICON_OFFLINE)
            self.status_icon.set_tooltip_text("AI Control: checking...")
            self.status_icon.connect("popup-menu", self._on_popup)
            self.status_icon.set_visible(True)

        # Start periodic health check (every 5 seconds)
        GLib.timeout_add_seconds(5, self._check_status)
        # Run first check immediately
        GLib.idle_add(self._check_status)

    def _make_submenu(self, label, items):
        """Build a Gtk submenu. Use ("---","") for separators."""
        parent = Gtk.MenuItem(label=label)
        sub = Gtk.Menu()
        for lbl, cmd in items:
            if lbl == "---":
                sub.append(Gtk.SeparatorMenuItem())
            else:
                mi = Gtk.MenuItem(label=lbl)
                mi.connect("activate", self._run_cmd, cmd)
                sub.append(mi)
        parent.set_submenu(sub)
        return parent

    def _build_menu(self):
        import os
        home = os.environ.get("HOME", os.path.expanduser("~"))
        pic = home + "/Pictures"

        self.menu = Gtk.Menu()

        # --- Status display (non-clickable) ---
        self.status_item = Gtk.MenuItem(label="AI Daemon: Checking...")
        self.status_item.set_sensitive(False)
        self.menu.append(self.status_item)

        self.trust_item = Gtk.MenuItem(label="Trust Level: --")
        self.trust_item.set_sensitive(False)
        self.menu.append(self.trust_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        # --- Top-level favourites ---
        for lbl, cmd in [
            ("Open Contusion", "/usr/bin/contusion"),
            ("Services Manager", "/usr/bin/ai-services-manager"),
            ("AI Control Panel", "/usr/bin/ai-control-panel"),
            ("Take Screenshot", "/usr/bin/ai-screenshot"),
        ]:
            it = Gtk.MenuItem(label=lbl)
            it.connect("activate", self._run_cmd, cmd)
            self.menu.append(it)

        self.menu.append(Gtk.SeparatorMenuItem())

        # --- Quick Actions submenu ---
        self.menu.append(self._make_submenu("Quick Actions", [
            ("Open Terminal Here",
             "xfce4-terminal --working-directory=" + home),
            ("File Manager", "thunar"),
            ("Task Manager", "xfce4-taskmanager"),
            ("System Monitor",
             "xdg-open http://127.0.0.1:8420/contusion"),
            ("---", ""),
            ("Screenshot Region",
             "bash -c 'mkdir -p \"" + pic + "\" && "
             "scrot -s \"" + pic + "/screenshot_$(date +%%s).png\" && "
             "notify-send Screenshot \"Region saved to ~/Pictures\" "
             "-i applets-screenshooter'"),
            ("Screenshot Full", "/usr/bin/ai-screenshot"),
            ("---", ""),
            ("System Status",
             "terminator -e 'ai status; read -p \"Press Enter...\"'"),
        ]))

        # --- PE Tools submenu ---
        self.menu.append(self._make_submenu("PE Tools", [
            ("Run .exe…", "/usr/bin/ai-run-exe"),
            ("---", ""),
            ("PE Process Monitor",
             "terminator -e \"watch -n2 "
             "'ps aux | grep -E peloader | grep -v grep'; "
             "read -p 'Press Enter...'\""),
            ("Services Manager",
             "/usr/bin/ai-services-manager"),
            ("Driver Viewer",
             "terminator -e '"
             "echo === Loaded Kernel Modules ===; lsmod | head -40; echo; "
             "echo === PE Compat ===; lsmod | grep -i pe 2>/dev/null "
             "|| echo None; read -p \"Press Enter...\"'"),
        ]))

        # --- Network submenu ---
        self.menu.append(self._make_submenu("Network", [
            ("WiFi Manager", "/usr/bin/ai-wifi-manager"),
            ("Firewall Status",
             "bash -c '"
             "if systemctl is-active --quiet ufw 2>/dev/null; then "
             "notify-send Firewall \"UFW is ACTIVE\" -i security-high; "
             "elif systemctl is-active --quiet firewalld 2>/dev/null; then "
             "notify-send Firewall \"firewalld is ACTIVE\" -i security-high; "
             "elif systemctl is-active --quiet iptables 2>/dev/null; then "
             "notify-send Firewall \"iptables is ACTIVE\" -i security-high; "
             "else "
             "notify-send Firewall \"No firewall detected\" -i security-low; "
             "fi'"),
            ("Show IP Address",
             "bash -c '"
             "IP=$(ip -4 route get 1.1.1.1 2>/dev/null "
             "| head -1 | awk \"{print \$7}\"); "
             "notify-send \"IP Address\" \"${IP:-No network}\" "
             "-i network-wired'"),
            ("---", ""),
            ("Network Settings", "nm-connection-editor"),
        ]))

        self.menu.append(Gtk.SeparatorMenuItem())

        # --- System submenu ---
        self.menu.append(self._make_submenu("System", [
            ("Update System",
             "terminator -e 'sudo pacman -Syu; "
             "read -p \"Press Enter...\"'"),
            ("Clean Cache",
             "terminator -e 'sudo pacman -Sc; "
             "read -p \"Press Enter...\"'"),
            ("---", ""),
            ("Restart AI Daemon",
             "pkexec systemctl restart ai-control"),
            ("View AI Logs",
             "terminator -e 'journalctl -u ai-control -f'"),
            ("---", ""),
            ("Lock Screen", "xflock4"),
            ("Log Out", "xfce4-session-logout --logout"),
        ]))

        self.menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label="Quit Indicator")
        quit_item.connect("activate", lambda _w: Gtk.main_quit())
        self.menu.append(quit_item)

        self.menu.show_all()

    # -- callbacks ----------------------------------------------------------

    @staticmethod
    def _run_cmd(_widget, cmd):
        try:
            subprocess.Popen(cmd, shell=True)
        except Exception:
            pass

    def _on_popup(self, icon, button, time):
        """Gtk.StatusIcon fallback popup handler."""
        self.menu.popup(None, None, Gtk.StatusIcon.position_menu, icon, button, time)

    # -- health check -------------------------------------------------------

    def _check_status(self):
        try:
            r = subprocess.run(
                [
                    "curl", "-s", "-o", "/dev/null",
                    "-w", "%{http_code}",
                    "--connect-timeout", "2",
                    "http://127.0.0.1:8420/health",
                ],
                capture_output=True,
                text=True,
                timeout=4,
            )
            code = r.stdout.strip()
            if code == "200":
                self.status_item.set_label("AI Daemon: Online")
                self._set_icon(self.ICON_ONLINE)
                self._fetch_trust()
            else:
                self.status_item.set_label("AI Daemon: Error ({})".format(code))
                self.trust_item.set_label("Trust Level: --")
                self._set_icon(self.ICON_ERROR)
        except Exception:
            self.status_item.set_label("AI Daemon: Offline")
            self.trust_item.set_label("Trust Level: --")
            self._set_icon(self.ICON_OFFLINE)
        return True  # keep timer alive

    def _fetch_trust(self):
        """Best-effort trust level fetch (non-blocking would be nicer,
        but curl with 1s timeout is fast enough for a tray indicator)."""
        try:
            import json

            r = subprocess.run(
                [
                    "curl", "-s",
                    "--connect-timeout", "1",
                    "http://127.0.0.1:8420/trust/level",
                ],
                capture_output=True,
                text=True,
                timeout=3,
            )
            d = json.loads(r.stdout)
            level = d.get("level", d.get("trust_level", "unknown"))
            self.trust_item.set_label("Trust Level: {}".format(level))
        except Exception:
            self.trust_item.set_label("Trust Level: --")

    def _set_icon(self, icon_name):
        if HAS_INDICATOR:
            self.indicator.set_icon(icon_name)
        else:
            self.status_icon.set_from_icon_name(icon_name)
            tooltip = self.status_item.get_label()
            self.status_icon.set_tooltip_text(tooltip)


if __name__ == "__main__":
    AiTrayIndicator()
    Gtk.main()
AITRAY

