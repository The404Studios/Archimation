# Maintainer: AI Arch Linux Project
# PKGBUILD for ai-desktop-config - Full Windows-like desktop experience

pkgname=ai-desktop-config
pkgver=0.2.0
pkgrel=27
pkgdesc="AI Arch Linux desktop configuration: Windows-like XFCE desktop, .exe integration, gaming support, AI control panel, Contusion automation engine, WiFi manager, driver viewer, disk installer"
arch=('any')
url="https://github.com/ai-arch-linux/ai-desktop-config"
license=('GPL-3.0-or-later')
depends=(
    'pe-loader'
    'xfce4-session'
    'xfce4-panel'
    'xfce4-settings'
    'xfce4-whiskermenu-plugin'
    'xfce4-pulseaudio-plugin'
    'xfce4-battery-plugin'
    'xfce4-power-manager'
    'xfdesktop'
    'xfwm4'
    'thunar'
    'zenity'
    'ttf-dejavu'
    'papirus-icon-theme'
    'python-gobject'
    'gtk4'
    'libadwaita'
    'terminator'
    'ttf-jetbrains-mono'
    'fastfetch'
    'picom'
    'dunst'
    'scrot'
    'lightdm-gtk-greeter'
    'qt5ct'
    'kvantum-qt5'
    'i3lock'
    'xss-lock'
    'xdg-user-dirs'
    'xclip'
    'pacman-contrib'
    'libnotify'
)
optdepends=(
    'steam: gaming platform'
    'lutris: game manager'
    'pavucontrol: audio mixer'
    'redshift: night light'
    'blueman: bluetooth manager (autostart: blueman-applet.desktop)'
    'xfce4-clipman-plugin: clipboard manager with history (autostart: xfce4-clipman.desktop)'
    'network-manager-applet: WiFi/network tray icon (autostart: nm-applet.desktop)'
    'conky: desktop system monitor widget (autostart: conky.desktop)'
    'xsecurelock: alternative lock screen dimmer'
    'librsvg: SVG wallpaper rendering for lock screen'
    'arc-gtk-theme: alternate dark theme (AUR — optional)'
    'ttf-inter: Inter UI font (AUR — optional, GTK falls back to DejaVu)'
)
install=ai-desktop-config.install
provides=('ai-desktop-config')
source=()

package() {
    # ==========================================================================
    # WALLPAPER
    # ==========================================================================
    install -d "$pkgdir/usr/share/backgrounds/ai-arch"

    # Generate PNG fallback: diagonal gradient + noise texture (4K)
    python3 -c "
import random
from PIL import Image, ImageDraw
W, H = 3840, 2160
img = Image.new('RGB', (W, H))
c0, c1, c2 = (15,15,26), (26,27,46), (22,22,30)
for y in range(H):
    for x in range(W):
        t = (x/W + y/H) / 2.0
        if t < 0.4:
            s = t / 0.4
            r,g,b = [int(c0[i]+(c1[i]-c0[i])*s) for i in range(3)]
        else:
            s = (t - 0.4) / 0.6
            r,g,b = [int(c1[i]+(c2[i]-c1[i])*s) for i in range(3)]
        n = random.randint(-3, 3)
        img.putpixel((x, y), (max(0,min(255,r+n)), max(0,min(255,g+n)), max(0,min(255,b+n))))
# Radial glow overlay
glow = Image.new('RGBA', (W, H), (0,0,0,0))
gd = ImageDraw.Draw(glow)
cx, cy = W//2, int(H*0.45)
for rad in range(min(W,H)//2, 0, -3):
    a = int(16 * (1 - rad / (min(W,H)//2)) ** 2)
    gd.ellipse([cx-rad, cy-rad, cx+rad, cy+rad], fill=(122,162,247,a))
base = img.convert('RGBA')
img = Image.alpha_composite(base, glow).convert('RGB')
# Subtle dot grid
draw = ImageDraw.Draw(img)
for gx in range(0, W, 80):
    for gy in range(0, H, 80):
        px = img.getpixel((gx, gy))
        draw.point((gx, gy), fill=tuple(min(255, c+6) for c in px))
img.save('${pkgdir}/usr/share/backgrounds/ai-arch/default.png')
" 2>/dev/null || true
    # Always install the SVG wallpaper (4K, scalable, guaranteed to exist)
    install -Dm644 /dev/stdin "$pkgdir/usr/share/backgrounds/ai-arch/default.svg" <<'SVG'
<svg xmlns="http://www.w3.org/2000/svg" width="3840" height="2160" viewBox="0 0 3840 2160">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0f0f1a"/>
      <stop offset="40%" stop-color="#1a1b2e"/>
      <stop offset="100%" stop-color="#16161e"/>
    </linearGradient>
    <radialGradient id="glow" cx="50%" cy="45%" r="40%">
      <stop offset="0%" stop-color="#7aa2f7" stop-opacity="0.07"/>
      <stop offset="60%" stop-color="#7aa2f7" stop-opacity="0.03"/>
      <stop offset="100%" stop-color="#7aa2f7" stop-opacity="0"/>
    </radialGradient>
    <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
      <circle cx="40" cy="40" r="0.8" fill="#7aa2f7" opacity="0.03"/>
    </pattern>
    <filter id="blur"><feGaussianBlur stdDeviation="2"/></filter>
  </defs>
  <rect width="100%" height="100%" fill="url(#bg)"/>
  <rect width="100%" height="100%" fill="url(#glow)"/>
  <ellipse cx="1920" cy="972" rx="900" ry="500" fill="#7aa2f7" opacity="0.02" filter="url(#blur)"/>
  <rect width="100%" height="100%" fill="url(#grid)"/>
  <text x="50%" y="46%" text-anchor="middle" dominant-baseline="central" font-family="Inter, Segoe UI, sans-serif" font-size="120" font-weight="200" letter-spacing="24" fill="#7aa2f7" opacity="0.15">AI ARCH LINUX</text>
  <text x="50%" y="53%" text-anchor="middle" dominant-baseline="central" font-family="Inter, Segoe UI, sans-serif" font-size="28" font-weight="300" letter-spacing="8" fill="#565f89" opacity="0.10">Windows compatibility. AI control. Linux power.</text>
</svg>
SVG

    # ==========================================================================
    # DEFAULT MIME TYPE ASSOCIATIONS (double-click .exe → pe-loader)
    # ==========================================================================
    install -Dm644 /dev/stdin "$pkgdir/etc/skel/.config/mimeapps.list" <<'MIMEAPPS'
[Default Applications]
application/x-msdos-program=pe-loader.desktop
application/x-dosexec=pe-loader.desktop
application/x-msdownload=pe-loader.desktop
application/x-ms-dos-executable=pe-loader.desktop
application/vnd.microsoft.portable-executable=pe-loader.desktop
application/x-deb=ai-pkg-install.desktop
application/x-debian-package=ai-pkg-install.desktop
application/x-rpm=ai-pkg-install.desktop
application/vnd.arch-linux.package=ai-pkg-install.desktop
application/zip=org.gnome.FileRoller.desktop
application/x-7z-compressed=org.gnome.FileRoller.desktop
application/x-compressed-tar=org.gnome.FileRoller.desktop
application/gzip=org.gnome.FileRoller.desktop
application/x-tar=org.gnome.FileRoller.desktop
application/x-rar=org.gnome.FileRoller.desktop
application/x-bzip2-compressed-tar=org.gnome.FileRoller.desktop
inode/directory=thunar.desktop

[Added Associations]
application/x-msdos-program=pe-loader.desktop
application/x-dosexec=pe-loader.desktop
application/x-msdownload=pe-loader.desktop
application/x-ms-dos-executable=pe-loader.desktop
application/vnd.microsoft.portable-executable=pe-loader.desktop
application/x-deb=ai-pkg-install.desktop
application/x-debian-package=ai-pkg-install.desktop
