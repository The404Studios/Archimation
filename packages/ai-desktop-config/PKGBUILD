        theme_group = Adw.PreferencesGroup(title="Appearance")

        self._dark_switch = Adw.SwitchRow(title="Dark Theme", subtitle="Use dark colour scheme (recommended)")
        self._dark_switch.set_active(True)
        self._dark_switch.connect("notify::active", self._on_theme_toggled)
        theme_group.add(self._dark_switch)

        content.append(theme_group)

        # -- AI daemon section --
        ai_group = Adw.PreferencesGroup(title="AI Control Daemon")
        ai_group.set_description("The AI daemon provides desktop automation features")

        self._ai_switch = Adw.SwitchRow(title="Enable AI Daemon", subtitle="Start ai-control.service at boot")
        self._ai_switch.set_active(True)
        ai_group.add(self._ai_switch)

        content.append(ai_group)

        scroll.set_child(content)
        page.append(scroll)
        return page

    def _on_wifi_selected(self, listbox, row):
        if row is not None:
            self._selected_ssid = row.get_name()
            self._wifi_connect_btn.set_sensitive(True)
        else:
            self._selected_ssid = None
            self._wifi_connect_btn.set_sensitive(False)

    def _refresh_wifi(self):
        """Scan for WiFi networks via the AI daemon API."""
        def _do():
            _api_call("POST", "/network/wifi/scan")
            import time
            time.sleep(2)
            nets = _api_call("GET", "/network/wifi/networks")
            networks = nets.get("networks", []) if "error" not in nets else []
            GLib.idle_add(self._populate_wifi, networks)
        threading.Thread(target=_do, daemon=True).start()

    def _populate_wifi(self, networks):
        """Update the WiFi listbox with discovered networks."""
        self._wifi_networks = networks
        while True:
            row = self._wifi_list.get_row_at_index(0)
            if row is None:
                break
            self._wifi_list.remove(row)

        if not networks:
            self._wifi_list.set_placeholder(
                Gtk.Label(label="No WiFi networks found")
            )
            return False

        for net in sorted(networks, key=lambda n: n.get("signal", 0), reverse=True):
            ssid = net.get("ssid", "")
            if not ssid:
                continue
            signal = net.get("signal", 0)
            security = net.get("security", "")
            connected = net.get("active", False)

            row = Adw.ActionRow(title=ssid)
            row.set_name(ssid)

            if signal >= 75:
                icon_name = "network-wireless-signal-excellent-symbolic"
            elif signal >= 50:
                icon_name = "network-wireless-signal-good-symbolic"
            elif signal >= 25:
                icon_name = "network-wireless-signal-ok-symbolic"
            else:
                icon_name = "network-wireless-signal-weak-symbolic"

            sig_icon = Gtk.Image.new_from_icon_name(icon_name)
            sig_icon.set_pixel_size(20)
            row.add_prefix(sig_icon)

            parts = []
            if security:
                parts.append(security)
            if connected:
                parts.append("Connected")
            if parts:
                row.set_subtitle(" \u00b7 ".join(parts))

            if security and security.lower() not in ("", "open", "none", "--"):
                lock = Gtk.Image.new_from_icon_name("channel-secure-symbolic")
                lock.set_pixel_size(16)
                row.add_suffix(lock)

            self._wifi_list.append(row)

        return False

    def _on_wifi_connect(self, _btn):
        """Connect to the selected WiFi network."""
        ssid = self._selected_ssid
        if not ssid:
            return
        net = next((n for n in self._wifi_networks if n.get("ssid") == ssid), None)
        security = net.get("security", "") if net else ""
        needs_password = security and security.lower() not in ("", "open", "none", "--")
        if needs_password:
            self._show_password_dialog(ssid)
        else:
            self._do_wifi_connect(ssid, None)

    def _show_password_dialog(self, ssid):
        """Show a password entry dialog for a secured network."""
        dialog = Adw.MessageDialog(
            transient_for=self.win,
            heading=f"Connect to {ssid}",
            body="Enter the WiFi password:",
        )
        dialog.add_response("cancel", "Cancel")
        dialog.add_response("connect", "Connect")
        dialog.set_response_appearance("connect", Adw.ResponseAppearance.SUGGESTED)
        dialog.set_default_response("connect")
        dialog.set_close_response("cancel")

        entry = Gtk.PasswordEntry()
        entry.set_show_peek_icon(True)
        entry.set_margin_start(24)
        entry.set_margin_end(24)
        dialog.set_extra_child(entry)

        def _on_response(_dlg, response):
            if response == "connect":
                password = entry.get_text()
                self._do_wifi_connect(ssid, password)
        dialog.connect("response", _on_response)
        dialog.present()

    def _do_wifi_connect(self, ssid, password):
        """Perform the actual WiFi connection via API."""
        def _do():
            data = {"ssid": ssid}
            if password:
                data["password"] = password
            result = _api_call("POST", "/network/wifi/connect", data=data)
            ok = "error" not in result
            msg = result.get("message", result.get("error", "Unknown error"))
            def _update():
                if ok:
                    toast = Adw.Toast(title=f"Connected to {ssid}")
                else:
                    toast = Adw.Toast(title=f"Failed: {msg}")
                toast.set_timeout(3)
                self.toast_overlay.add_toast(toast)
                self._refresh_wifi()
            GLib.idle_add(_update)
        threading.Thread(target=_do, daemon=True).start()

    def _on_theme_toggled(self, switch, _pspec):
        """Toggle between light and dark themes."""
        dark = switch.get_active()
        try:
            style_mgr = Adw.StyleManager.get_default()
            if dark:
                style_mgr.set_color_scheme(Adw.ColorScheme.FORCE_DARK)
            else:
                style_mgr.set_color_scheme(Adw.ColorScheme.FORCE_LIGHT)
        except Exception:
            pass

